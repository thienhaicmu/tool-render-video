{
  "name": "yt-tiktok-desktop-shell",
  "version": "0.1.0",
  "description": "Render Studio Desktop Shell",
  "author": "Render Studio Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder --win nsis portable",
    "dist:win": "npm run dist",
    "logerror": "node scripts/logerror.js"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.renderstudio",
    "productName": "Render Studio Desktop",
    "forceCodeSigning": false,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/.venv/**",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "backend-bin",
        "to": "backend-bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ffmpeg-bin",
        "to": "ffmpeg-bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ]
  }
}
