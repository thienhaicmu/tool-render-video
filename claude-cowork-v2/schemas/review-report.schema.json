{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "review-report.schema.json",
  "title": "ReviewReport",
  "description": "Schema for the structured review report generated by the review engine.",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "run_id",
    "reviewed_at",
    "reviewer_mode",
    "verdict",
    "scope_fit_score",
    "safety_score",
    "logging_score",
    "overall_score",
    "acceptance_criteria_results",
    "scope_assessment",
    "safety_assessment",
    "logging_assessment",
    "summary",
    "recommendations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "task_id": {
      "type": "string",
      "minLength": 8
    },
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer_mode": {
      "type": "string",
      "enum": ["llm", "deterministic", "mock"]
    },
    "reviewer_model": {
      "type": "string",
      "description": "Model identifier if reviewer_mode is llm"
    },
    "verdict": {
      "type": "string",
      "enum": ["accepted", "accepted_with_followup", "changes_requested", "rejected"],
      "description": "Final review verdict"
    },
    "scope_fit_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "0-10 score for how well execution fit the defined scope"
    },
    "safety_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "0-10 score for safety of the execution (no regressions, secrets, etc.)"
    },
    "logging_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "0-10 score for logging quality in the changes produced"
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Weighted aggregate score"
    },
    "acceptance_criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "met", "evidence"],
        "properties": {
          "criterion": { "type": "string" },
          "met": {
            "type": "string",
            "enum": ["yes", "no", "partial", "not_verifiable"]
          },
          "evidence": { "type": "string" }
        }
      },
      "description": "Per-criterion evaluation"
    },
    "scope_assessment": {
      "type": "string",
      "description": "Narrative assessment of scope fit"
    },
    "safety_assessment": {
      "type": "string",
      "description": "Narrative assessment of safety"
    },
    "logging_assessment": {
      "type": "string",
      "description": "Narrative assessment of logging quality"
    },
    "review_checkpoint_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["checkpoint", "passed", "notes"],
        "properties": {
          "checkpoint": { "type": "string" },
          "passed": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "followup_tasks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested follow-up tasks if verdict is accepted_with_followup"
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Issues that must be resolved if verdict is changes_requested or rejected"
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "description": "Human-readable narrative summary of the review"
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Actionable recommendations for the engineering team"
    }
  }
}
