evel","axis":"sc1:primary","beat_ids":["b1"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh1","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"close","visual_id":"v_interior_stairs"},{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b2"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh2","lens":"wide","motion_intent":"pull_out","scene_id":"sc1","shot_size":"wide","visual_id":"v_interior_stairs"},{"angle":"over_shoulder","axis":"sc2:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v_lamp_room_flicker"},{"angle":"high","axis":"sc2:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"centered","eyeline":"environmental","id":"sh4","lens":"wide","motion_intent":"push_in","scene_id":"sc2","shot_size":"wide","visual_id":"v_lamp_room_flicker"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh5","lens":"portrait","motion_intent":"reveal","scene_id":"sc3","shot_size":"close","visual_id":"v_ghostly_encounter"},{"angle":"low","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh6","lens":"portrait","motion_intent":"static","scene_id":"sc3","shot_size":"close","visual_id":"v_ghostly_encounter"},{"angle":"high","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v_turning_the_lens"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"leading_lines","eyeline":"environmental","id":"sh8","lens":"portrait","motion_intent":"pull_out","scene_id":"sc4","shot_size":"close","visual_id":"v_turning_the_lens"},{"angle":"low","axis":"sc5:primary","beat_ids":["b9"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh9","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v_dawn_gallery"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"The dark lighthouse had been cursed for forty years.","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The lighthouse had been dark for forty years when Elias took the keeper's job. While the superstitious villagers called it cursed, he simply called it quiet."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_interior_stairs"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"On his very first night, climbing the dusty spiral stairs with his lantern, Elias found the old logbook of the previous keeper, Mara."},{"emotion":"surprised","pose":"stand","speaker_id":"elias","text":"The final entry is torn out. What happened to you here, Mara?"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_interior_stairs"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"For weeks Elias tended the restored lamp, its powerful beam sweeping across the black water. Yet, every single night at exactly 3:07, the light would flicker and dim."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_lamp_room_flicker"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"It was as if something invisible passed between the flame and the sea. Soon, he began to hear a woman's voice crying out in the wind, calling a name that was not his."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_lamp_room_flicker"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A ship was lost in the fog, and the light died.","id":"b5","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"One storm-lashed evening, a ship's horn wailed offshore, lost in the thick fog. Elias raced to the lamp, but the fire died completely, plunging him into darkness."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_ghostly_encounter"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"In the cold dark, he saw her: Mara, pale and translucent, standing right at the glass. She had drowned forty years ago, unable to light the lamp in time."},{"emotion":"sad","pose":"stand","speaker_id":"mara","text":"I couldn't save them... I cannot leave this place."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_ghostly_encounter"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"point","speaker_id":"","text":"Elias understood her pain. He reached out, took her cold, spectral hand, and together they threw their weight against the great brass lens."},{"emotion":"angry","pose":"point","speaker_id":"elias","text":"We can do this together. Help me turn the glass!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_turning_the_lens"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"The beam blazed out through the storm.","id":"b8","lines":[{"emotion":"happy","pose":"cheer","speaker_id":"","text":"By sheer force, they coaxed a spark back into the wick. The beam blazed out through the storm, and the ship's horn answered in gratitude as it steered safe past the rocks."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_turning_the_lens"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"At dawn, the lamp still burned brightly, but Mara was gone, her long vigil finally ended. Elias sat on the gallery deck, looking at the silver, peaceful sea."},{"emotion":"happy","pose":"stand","speaker_id":"elias","text":"Rest in peace, Mara. The lighthouse is finally free."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_dawn_gallery"}],"tone":"mysterious, haunting, redemptive","topic":"The Ghost of the Lighthouse","visuals":[{"character_ids":["elias"],"id":"v_interior_stairs","negative_prompt":"","prompt":"","setting_id":"lighthouse_interior","tier":"medium"},{"character_ids":["elias"],"id":"v_lamp_room_flicker","negative_prompt":"","prompt":"","setting_id":"lamp_room","tier":"medium"},{"character_ids":["elias","mara"],"id":"v_ghostly_encounter","negative_prompt":"","prompt":"","setting_id":"lamp_room","tier":"medium"},{"character_ids":["elias","mara"],"id":"v_turning_the_lens","negative_prompt":"","prompt":"","setting_id":"lamp_room","tier":"medium"},{"character_ids":["elias"],"id":"v_dawn_gallery","negative_prompt":"","prompt":"","setting_id":"gallery_deck","tier":"medium"}]}