_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ba năm ròng rã khổ luyện trên núi, Hàn Phong đã đột phá tầng thứ chín của Lưu Vân kiếm pháp và quyết định xuống núi báo thù."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_mo_su_phu"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tại tửu lâu Vọng Nguyệt ở Lạc Dương, Hàn Phong tình cờ gặp gỡ Tô Linh Nhi, một nữ hiệp áo trắng cũng mang mối thù giết cha."},{"emotion":"normal","pose":"stand","speaker_id":"to_linh_nhi","text":"Huynh cũng tìm Huyết Sát giáo sao? Chúng ta hãy cùng liên thủ, ta dùng ám khí hỗ trợ huynh."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_gap_linh_nhi"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm trăng tròn, hai người đột nhập tổng đàn Huyết Sát giáo, nhưng Mộ Dung Tuấn đã dàn trận chờ sẵn cùng trăm tên giáo chúng."},{"emotion":"angry","pose":"point","speaker_id":"mu_dung_tuan","text":"Ngươi tưởng một thanh kiếm gãy có thể đòi lại công đạo từ tay ta sao? Thật nực cười!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_doi_dau_tuan"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Cuộc chiến kéo dài ác liệt đến tận bình minh. Tô Linh Nhi không may trúng phải độc chưởng hiểm ác của kẻ thù và gục xuống."},{"emotion":"angry","pose":"stand","speaker_id":"han_phong","text":"Linh Nhi! Tên ác tặc kia, ta sẽ băm vằn ngươi ra trăm mảnh!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_linh_nhi_guc"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Vân Phá Thiên Khung!","id":"b6","lines":[{"emotion":"angry","pose":"stand","speaker_id":"","text":"Trong cơn phẫn nộ tột cùng, Hàn Phong đột phá tầng thứ mười của kiếm pháp. Một chiêu Vân Phá Thiên Khung chém ra, hủy diệt tất cả."},{"emotion":"surprised","pose":"stand","speaker_id":"mu_dung_tuan","text":"Không thể nào... Kiếm pháp này... Áaaaa!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_linh_nhi_guc"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Mộ Dung Tuấn tan thành tro bụi, đại điện sụp đổ. Mối thù đã báo, nhưng lòng Hàn Phong chỉ còn lại sự trống rỗng khôn cùng."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chàng bế Linh Nhi đang hôn mê lên vai, lặng lẽ bước đi hướng về phía ánh mặt trời mọc, tìm kiếm một con đường mới."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_chien_thang_trong_rong"}],"tone":"Trầm hùng, bi tráng, đầy cảm xúc","topic":"Hành Trình Báo Thù Của Hàn Phong","visuals":[{"character_ids":["han_phong"],"id":"v_mo_su_phu","negative_prompt":"","prompt":"","setting_id":"thanh_van_mon_ruins","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v_gap_linh_nhi","negative_prompt":"","prompt":"","setting_id":"vong_nguyet_lau","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi","mu_dung_tuan"],"id":"v_doi_dau_tuan","negative_prompt":"","prompt":"","setting_id":"huyet_sat_tong_dan","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v_linh_nhi_guc","negative_prompt":"","prompt":"","setting_id":"huyet_sat_tong_dan","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v_chien_thang_trong_rong","negative_prompt":"","prompt":"","setting_id":"tan_tich_binh_minh","tier":"medium"}]}