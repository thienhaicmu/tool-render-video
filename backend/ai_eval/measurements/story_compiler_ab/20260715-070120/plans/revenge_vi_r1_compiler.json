toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v_vong_nguyet"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b4"],"blocking":"establish participants and geography","camera_position":"profile","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh4","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v_huyet_sat_giao_doi_dau"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v_huyet_sat_giao_quyet_chien"},{"angle":"low","axis":"sc6:primary","beat_ids":["b6"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh6","lens":"portrait","motion_intent":"reveal","scene_id":"sc6","shot_size":"close","visual_id":"v_huyet_sat_giao_ket_thuc"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Thâm thù khắc cốt ghi tâm","id":"b1","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Lửa đỏ liếm rách màn đêm, thiêu rụi trăm năm cơ nghiệp của Thanh Vân môn thành tro bụi. Giữa tàn tích hoang tàn, một bóng người quỳ lặng câm bên nấm mộ đất mới đắp của sư phụ, bàn tay rớm máu siết chặt thanh kiếm gãy. Kẻ phản môn đoạt tổ, đại sư huynh Mộ Dung Tuấn, đã mở cổng dẫn Huyết Sát giáo tàn sát đồng môn, chỉ để lại một mối thâm thù khắc cốt ghi tâm."},{"emotion":"sad","pose":"stand","speaker_id":"han_phong","text":"Sư phụ, máu của người, của vạn vị sư huynh đệ... đệ tử quyết không để chảy hoài phí."}],"motion":"pan_up","narration":"","pause_after":0.7,"pose":"stand","reading_speed":0.88,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_thanh_van_mon"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ba năm ròng rã nếm mật nằm gai nơi thâm sơn cùng cốc, Hàn Phong đã luyện thành Lưu Vân kiếm pháp đến tầng thứ chín, kiếm khí xuất ra tựa mây cuộn gió gào. Chàng xuống núi mang theo thanh kiếm gãy, thẳng tiến về thành Lạc Dương sầm uất, nơi kẻ phản đồ Mộ Dung Tuấn nay đã là trưởng lão quyền thế của Huyết Sát giáo, một tay che trời."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_lac_duong"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng tơ trúc của tửu lâu Vọng Nguyệt không khỏa lấp được sát khí lạnh lẽo ngưng tụ trong mắt người lữ khách. Tại đây, Hàn Phong chạm mặt Tô Linh Nhi, nữ hiệp áo trắng mang huyết hải thâm thù, đang giong ruổi giang hồ truy tìm kẻ đã sát hại phụ thân nàng."},{"emotion":"angry","pose":"stand","speaker_id":"to_linh_nhi","text":"Kẻ thù của ta và ngươi tuy hai mà một. Kiếm của ngươi, ám khí của ta, đêm nay sẽ bắt chúng nợ máu phải trả bằng máu!"},{"emotion":"normal","pose":"stand","speaker_id":"han_phong","text":"Được! Đồng hành một chuyến, sống chết có nhau."}],"motion":"pan_up","narration":"","pause_after":0.7,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_vong_nguyet"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm trăng tròn lạnh lẽo như băng, hai bóng người phi thân qua tường cao, đột nhập vào tổng đàn Huyết Sát giáo. Nhưng đón chờ họ giữa đại điện âm u là trăm tên giáo chúng gươm giáo sáng lòa, cùng cái bóng tàn ác của Mộ Dung Tuấn đang ngự trên cao."},{"emotion":"normal","pose":"stand","speaker_id":"mu_dung_tuan","text":"Hàn Phong, tiểu sư đệ ngu muội của ta. Ngươi tưởng một thanh kiếm gãy có thể đòi lại công đạo sao?"},{"emotion":"angry","pose":"stand","speaker_id":"han_phong","text":"Kiếm gãy, nhưng mạng của ngươi đêm nay phải đứt!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_huyet_sat_giao_doi_dau"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"angry","pose":"stand","speaker_id":"","text":"Không một lời thừa thãi, Hàn Phong tuốt kiếm, ánh thép loang loáng quét ra như dải lưu vân xé rách màn đêm. Trận huyết chiến kinh thiên động địa kéo dài suốt đêm thâu, thây chất thành núi, máu nhuộm đỏ từng tấc đất khi bình minh bắt đầu ló rạng ở chân trời."},{"emotion":"sad","pose":"stand","speaker_id":"","text":"Trong một khoảnh khắc sơ hở, Tô Linh Nhi trúng phải độc chưởng hiểm độc, thổ huyết ngã gục ngay trước mắt chàng. Chứng kiến đồng minh ngã xuống, nỗi phẫn nộ tột cùng kích phát chân khí trong người Hàn Phong, giúp chàng đột phá tầng thứ mười tối cao của kiếm pháp mang tên Vân Phá Thiên Khung."},{"emotion":"angry","pose":"point","speaker_id":"han_phong","text":"Mộ Dung Tuấn! Đền mạng đi!"},{"emotion":"angry","pose":"stand","speaker_id":"","text":"Một kiếm vung lên, kiếm khí cuồn cuộn như thiên lôi giáng thế, đánh sập cả đại điện nguy nga, nghiền nát Mộ Dung Tuấn thành tro bụi trong tiếng gào thét tuyệt vọng."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_huyet_sat_giao_quyet_chien"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Ngoảnh lại hóa hư không","id":"b6","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Bão tan, chỉ còn lại sự im lặng rợn người giữa đống đổ nát hoang tàn. Hàn Phong đứng đó dưới ánh bình minh, mối thù lớn đã báo nhưng cõi lòng chàng chỉ còn lại sự trống rỗng đến cùng cực. Chàng cúi người, nhẹ nhàng bế Tô Linh Nhi đang hôn mê bất tỉnh lên, lặng lẽ bước đi hướng về phía mặt trời mọc."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v_huyet_sat_giao_ket_thuc"}],"tone":"Bi tráng, u tối, quyết liệt","topic":"Hàn Phong báo thù cho sư môn và tiêu diệt Mộ Dung Tuấn","visuals":[{"character_ids":["han_phong"],"id":"v_thanh_van_mon","negative_prompt":"","prompt":"","setting_id":"thanh_van_mon","tier":"medium"},{"character_ids":["han_phong"],"id":"v_lac_duong","negative_prompt":"","prompt":"","setting_id":"lac_duong","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v_vong_nguyet","negative_prompt":"","prompt":"","setting_id":"vong_nguyet","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi","mu_dung_tuan"],"id":"v_huyet_sat_giao_doi_dau","negative_prompt":"","prompt":"","setting_id":"huyet_sat_giao","tier":"medium"},{"character_ids":["han_phong","mu_dung_tuan"],"id":"v_huyet_sat_giao_quyet_chien","negative_prompt":"","prompt":"","setting_id":"huyet_sat_giao","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v_huyet_sat_giao_ket_thuc","negative_prompt":"","prompt":"","setting_id":"huyet_sat_giao","tier":"medium"}]}