rimary","beat_ids":["b17"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh17","lens":"portrait","motion_intent":"push_in","scene_id":"sc3","shot_size":"close","visual_id":"v3"},{"angle":"low","axis":"sc3:primary","beat_ids":["b18"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh18","lens":"portrait","motion_intent":"track_left","scene_id":"sc3","shot_size":"close","visual_id":"v3"},{"angle":"high","axis":"sc4:primary","beat_ids":["b19"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh19","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b20"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh20","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v5"},{"angle":"over_shoulder","axis":"sc6:primary","beat_ids":["b21"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh21","lens":"portrait","motion_intent":"reveal","scene_id":"sc6","shot_size":"close","visual_id":"v6"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm bão dữ dội trùm lên thành phố, những tiếng gió rít gào và mưa quất vào cửa kính bệnh viện không ngừng. Bác sĩ An, với mái tóc búi cao gọn gàng, đang kiểm tra lại các thiết bị trong phòng cấp cứu, gương mặt cô hiện rõ vẻ mệt mỏi nhưng ánh mắt vẫn đầy kiên định."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cánh cửa phòng cấp cứu bất ngờ mở ra, bác sĩ Khoa bước vào, áo blouse trắng phẳng phiu, mang theo hơi lạnh của cơn bão. Ánh mắt họ chạm nhau, một khoảnh khắc ngượng nghịu kéo dài, như thể thời gian đã ngừng lại giữa cơn bão tố."},{"emotion":"normal","pose":"stand","speaker_id":"khoa","text":"Chào An, anh đến nhận ca trực."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"An khẽ gật đầu, lòng cô dậy sóng những ký ức cũ về mối tình đã tan vỡ cách đây hai năm. Khoa, người từng là cả thế giới của cô, nay chỉ còn là đồng nghiệp, một vết sẹo âm ỉ trong tim cô mỗi khi họ đối mặt."},{"emotion":"normal","pose":"stand","speaker_id":"an","text":"Chào Khoa. Anh đến rồi à."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":0.88,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Đúng lúc đó, một tiếng nổ lớn vang lên từ bên ngoài, đèn điện trong phòng cấp cứu chập chờn rồi vụt tắt hẳn. Cả bệnh viện chìm trong bóng tối lờ mờ của đèn khẩn cấp, báo hiệu một đêm trực đầy thử thách."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Tiếng còi xe cấp cứu xé tan màn đêm, một đứa trẻ khoảng 5 tuổi được đưa vào trong tình trạng nguy kịch, sốt cao và khó thở. Mẹ đứa bé khóc nấc, van xin các bác sĩ cứu con mình."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mọi hiểu lầm cá nhân bị gạt sang một bên, An và Khoa lập tức lao vào công việc. Họ phối hợp nhịp nhàng, mỗi người một nhiệm vụ, như thể chưa từng có khoảng cách nào giữa họ. Tình trạng khẩn cấp đòi hỏi sự tập trung tuyệt đối."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Nhưng đứa trẻ không đáp ứng thuốc, tình trạng ngày càng xấu đi. Nhịp tim yếu dần, hơi thở gấp gáp. Cả căn phòng chìm trong không khí căng thẳng tột độ, mỗi giây phút đều là một cuộc chiến sinh tử."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Đột nhiên, hệ thống điện dự phòng cũng gặp sự cố, cả phòng cấp cứu chìm vào bóng tối hoàn toàn. Chỉ còn ánh sáng yếu ớt từ chiếc đèn pin trên trán của Khoa và An. Tiếng hoảng loạn của y tá vang lên."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong bóng tối, đôi tay họ vẫn không ngừng làm việc. An đưa dụng cụ, Khoa thực hiện thủ thuật, mỗi động tác đều ăn khớp đến kỳ lạ. Sự ăn ý cũ kỹ, từng được vun đắp từ những ngày tháng yêu nhau, nay lại bùng cháy mạnh mẽ trong cơn nguy biến."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"point","speaker_id":"an","text":"Em nghĩ chúng ta nên thử phương pháp này, Khoa. Tình trạng của bé rất đặc biệt."},{"emotion":"normal","pose":"stand","speaker_id":"khoa","text":"Không, theo kinh nghiệm của anh, cách này rủi ro cao. Chúng ta nên tập trung vào phác đồ chuẩn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một thoáng căng thẳng chợt hiện lên, gợi lại những bất đồng cũ. Nhưng nhìn đứa trẻ đang thoi thóp, họ hiểu rằng không có thời gian cho những tranh cãi cá nhân. Khoa hít một hơi sâu, gật đầu đồng ý với An, đặt niềm tin vào trực giác của cô."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Sau một hồi nỗ lực, đứa trẻ có dấu hiệu ổn định hơn, nhịp thở đều đặn trở lại. Cả hai thở phào nhẹ nhõm, nhưng chỉ vài phút sau, da bé bắt đầu nổi mẩn đỏ, báo hiệu một phản ứng dị ứng nghiêm trọng."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"point","speaker_id":"an","text":"Em từng thấy trường hợp này một lần rồi, Khoa. Đây không phải dị ứng thông thường, nó liên quan đến một loại virus hiếm gặp, thường bùng phát trong điều kiện thời tiết cực đoan."},{"emotion":"normal","pose":"stand","speaker_id":"khoa","text":"An, em biết là rất hiếm. Chúng ta nên tập trung vào những nguyên nhân phổ biến hơn."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"point","speaker_id":"an","text":"Nhưng em nhớ rất rõ, nó có một dấu hiệu đặc trưng là..."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"An kiên quyết, cô nhớ lại chi tiết nhỏ từ một bài báo khoa học cũ, liên kết nó với cơn bão đang diễn ra bên ngoài. Trực giác của cô mách bảo đây là chìa khóa."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Khoa nhìn An, ánh mắt anh dần thay đổi. Anh chợt nhớ đến một nghiên cứu ít người biết về các bệnh truyền nhiễm liên quan đến biến đổi khí hậu. Anh bắt đầu tin vào lời An nói."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Hồi sinh giữa bão tố","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ cùng nhau suy nghĩ, kết hợp trực giác nhạy bén của An và kiến thức sâu rộng của Khoa. Cuối cùng, một phác đồ điều trị mới được đưa ra, liều thuốc đặc biệt được chuẩn bị nhanh chóng trong ánh đèn pin chập chờn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Ánh sáng hy vọng","id":"b17","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Từng giọt thuốc được truyền vào cơ thể đứa trẻ, mỗi giây trôi qua là một sự chờ đợi nghẹt thở. An và Khoa nắm chặt tay nhau, không phải vì tình yêu, mà vì sự đồng điệu của hai trái tim đang cùng hướng về một mục tiêu duy nhất: cứu lấy sinh mạng bé bỏng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Niềm tin trở lại","id":"b18","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Dần dần, da đứa trẻ bớt mẩn đỏ, nhịp thở trở nên đều đặn và mạnh mẽ hơn. Một tiếng ho nhẹ vang lên, rồi bé mở mắt, yếu ớt nhìn xung quanh. Nụ cười rạng rỡ hiện trên gương mặt An và Khoa, một nụ cười của sự chiến thắng."}],"motion":"pan_left","narration":"","pause_after":0.7,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b19","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bão tan, bình minh ló dạng, hắt những tia nắng yếu ớt qua khung cửa sổ hành lang. An và Khoa đứng cạnh nhau, nhìn ra ngoài, không khí giữa họ không còn nặng nề như trước. Sự hiểu lầm cũ dường như đã tan biến cùng cơn bão."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":0.88,"shot_id":"sh19","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b20","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Đứa trẻ đã được chuyển sang phòng hồi sức, ngủ yên bình. Mẹ đứa bé đến cảm ơn họ rối rít, nước mắt hạnh phúc lăn dài trên má. An và Khoa nhìn nhau, ánh mắt chất chứa nhiều điều muốn nói."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh20","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b21","lines":[{"emotion":"sad","pose":"stand","speaker_id":"khoa","text":"An, anh xin lỗi về chuyện trước đây. Anh đã sai khi không tin tưởng em hoàn toàn."},{"emotion":"sad","pose":"stand","speaker_id":"an","text":"Em cũng xin lỗi, Khoa. Có lẽ em đã quá vội vàng kết luận."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ trao nhau một cái nhìn sâu sắc, như thể lời xin lỗi không cần nói ra cũng đã được thấu hiểu. Đêm bão tố đã không chỉ cứu một sinh mạng, mà còn thắp lại ngọn lửa hy vọng cho một tình yêu tưởng chừng đã lụi tàn."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh21","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v6"}],"tone":"romantic","topic":"Đêm Bão Tình Yêu","visuals":[{"character_ids":["an"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_cap_cuu","tier":"medium"},{"character_ids":["an","khoa"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_cap_cuu","tier":"medium"},{"character_ids":["an","khoa","dua_tre","me_dua_tre"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_cap_cuu","tier":"medium"},{"character_ids":["an","khoa"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"},{"character_ids":["an","khoa","dua_tre"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"phong_benh","tier":"medium"},{"character_ids":["an","khoa"],"id":"v6","negative_prompt":"","prompt":"","setting_id":"phong_benh","tier":"medium"}]}