ht","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh15","lens":"wide","motion_intent":"pull_out","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"environmental","id":"sh16","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"extreme_close","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b17"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh17","lens":"portrait","motion_intent":"push_in","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b18"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh18","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b19"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh19","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b20"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh20","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"low","axis":"sc5:primary","beat_ids":["b21"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh21","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b22"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh22","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm bão, bệnh viện chìm trong sự tĩnh lặng đáng sợ, chỉ có tiếng gió rít qua ô cửa sổ. Bác sĩ Nam ngồi một mình trong phòng trực, ánh mắt dõi ra màn mưa trắng xóa, lòng anh nặng trĩu những suy tư về quá khứ và những quyết định đã qua."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Người cũ gặp lại","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cánh cửa phòng trực khẽ mở, bác sĩ Mai bước vào, mang theo hơi lạnh từ hành lang. Ánh mắt họ chạm nhau trong khoảnh khắc, một sự ngượng nghịu khó tả lan tỏa trong không khí, phá vỡ sự tĩnh mịch của căn phòng."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Chào anh, Nam. Đêm nay chúng ta trực chung."},{"emotion":"normal","pose":"stand","speaker_id":"nam","text":"Chào Mai. Bão lớn thế này, chắc sẽ có nhiều việc."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lời nói của họ chuyên nghiệp và khách sáo, nhưng ẩn chứa một dòng điện ngầm của những cảm xúc chưa được giải tỏa, khiến không gian trở nên căng thẳng hơn."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng sấm vang dội, cắt ngang sự im lặng, như một lời cảnh báo về những gì sắp xảy ra. Cả hai đều cảm thấy một dự cảm không lành về đêm trực đầy thử thách này, không chỉ vì cơn bão mà còn vì sự hiện diện của đối phương."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng chuông cấp cứu vang lên, phá tan bầu không khí nặng nề. Một bệnh nhân bị thương nhẹ do ngã xe trong mưa được đưa vào. Nam và Mai lập tức vào vị trí, phối hợp nhịp nhàng như những cỗ máy được lập trình sẵn, không một lời thừa thãi."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"sad","pose":"stand","speaker_id":"nam","text":"Anh vẫn nhớ ánh mắt cô ấy khi mình nói lời chia tay. Anh đã quá tập trung vào sự nghiệp, nghĩ rằng tình yêu có thể chờ đợi. Giờ đây, anh hối hận vì đã không trân trọng những gì mình có."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong lúc làm việc, Nam chợt nhớ về quá khứ. Anh đã từng là người chủ động kết thúc mối tình đẹp ấy, vì những tham vọng cá nhân, để lại vết thương lòng sâu sắc cho Mai."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"sad","pose":"stand","speaker_id":"mai","text":"Anh ấy đã bỏ rơi mình khi mình cần nhất. Mình đã cố gắng quên đi, nhưng mỗi khi nhìn thấy anh ấy, vết sẹo cũ lại nhức nhối."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mai cũng chìm vào dòng ký ức. Cô vẫn còn nhớ rõ cảm giác bị bỏ rơi, nỗi đau khi tình yêu tan vỡ. Sự xuất hiện của Nam như một lời nhắc nhở không ngừng về những tổn thương chưa lành."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một trường hợp cấp cứu nặng hơn được đưa đến: một người đàn ông bị tai nạn giao thông nghiêm trọng. Nam và Mai lại sát cánh bên nhau, ánh mắt họ giao nhau đầy ăn ý, mỗi người một nhiệm vụ nhưng cùng chung một mục tiêu cứu người."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bên ngoài, cơn bão càng lúc càng dữ dội, gió giật mạnh làm rung chuyển cả tòa nhà. Đèn điện trong phòng cấp cứu chập chờn, rồi vụt tắt trong vài giây, khiến không khí càng thêm căng thẳng và lo lắng."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong một khoảnh khắc tĩnh lặng hiếm hoi, tay Nam vô tình chạm vào tay Mai khi họ cùng lấy dụng cụ. Một luồng điện nhẹ chạy qua, khiến cả hai giật mình rụt lại. Ánh mắt họ thoáng gặp nhau, chất chứa bao điều muốn nói nhưng không thể thốt nên lời."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"surprised","pose":"point","speaker_id":"lan","text":"Bác sĩ Nam, bác sĩ Mai! Có một bé gái bị sốt cao co giật do bão, tình trạng rất nguy kịch!"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng y tá Lan hốt hoảng vang lên, phá vỡ sự tĩnh lặng. Một trường hợp cấp cứu đặc biệt nghiêm trọng: một bé gái tên An, đang trong tình trạng nguy kịch do cơn bão gây ra, cần được cấp cứu ngay lập tức."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Cứu sống sinh linh bé bỏng","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bé An được đưa vào, gương mặt xanh xao, cơ thể co giật dữ dội. Mọi khúc mắc cá nhân dường như tan biến, Nam và Mai lập tức lao vào cuộc chiến giành giật sự sống cho đứa trẻ, ánh mắt họ chỉ còn sự tập trung cao độ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"point","speaker_id":"nam","text":"Thuốc chống co giật!"},{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Sẵn sàng!"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ làm việc như một thể thống nhất, mỗi động tác đều chính xác và nhanh gọn. Nam ra lệnh, Mai thực hiện, không cần một lời giải thích, sự ăn ý của họ khiến y tá Lan cũng phải kinh ngạc."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đột nhiên, máy monitor báo động, nhịp tim bé An yếu dần. Một biến chứng bất ngờ xảy ra, đòi hỏi một quyết định táo bạo. Nam nhìn Mai, ánh mắt anh đầy tin tưởng, và cô gật đầu, hiểu ý anh muốn làm gì."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nam","text":"Chúng ta phải làm ngay!"},{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Được!"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Với sự phối hợp ăn ý, họ đã vượt qua được biến chứng, nhịp tim bé An dần ổn định trở lại. Tuy nhiên, đứa bé vẫn còn rất yếu, cần được theo dõi sát sao từng phút từng giây trong đêm bão này."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm dần về khuya, cơn bão vẫn hoành hành dữ dội. Bất ngờ, bé An lại lên cơn co giật dữ dội hơn, tình trạng nguy kịch hơn lúc trước. Máy monitor kêu tít tít liên hồi, báo hiệu một tình huống khẩn cấp."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Sự thật được hé lộ","id":"b17","lines":[{"emotion":"sad","pose":"stand","speaker_id":"nam","text":"Anh xin lỗi, Mai. Anh đã sai khi để em một mình."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong khoảnh khắc sinh tử, Nam bất ngờ thốt lên lời xin lỗi. Anh nhận ra rằng, dù có thành công đến đâu, anh cũng không thể sống thiếu Mai. Lời nói của anh như một lời thú tội muộn màng, nhưng chân thành."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b18","lines":[{"emotion":"sad","pose":"stand","speaker_id":"mai","text":"Em cũng xin lỗi vì đã không hiểu cho anh."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mai nhìn Nam, ánh mắt cô đầy nước mắt nhưng cũng chứa đựng sự thấu hiểu. Cô nhận ra rằng, nỗi đau của anh cũng lớn như của cô. Trong khoảnh khắc đó, mọi hiểu lầm, mọi nỗi đau đều tan biến, chỉ còn lại sự chân thành."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b19","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Với sự giải tỏa cảm xúc, họ dồn hết tâm trí vào việc cứu bé An. Bằng tất cả kinh nghiệm và tình yêu thương, họ đã cùng nhau vượt qua thời khắc nguy hiểm nhất, đưa bé An thoát khỏi lưỡi hái tử thần. Tiếng monitor dần đều, báo hiệu sự sống đã trở lại."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh19","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b20","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bình minh hé rạng sau cơn bão, ánh nắng ban mai chiếu rọi hành lang bệnh viện. Bé An đã qua cơn nguy kịch và đang ngủ yên bình. Nam và Mai đứng cạnh nhau, nhìn đứa bé, lòng họ tràn ngập sự nhẹ nhõm và một cảm giác bình yên."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh20","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b21","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nam","text":"Mai, chúng ta có thể bắt đầu lại không?"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nam quay sang Mai, ánh mắt anh tràn đầy hy vọng. Anh không còn là người đàn ông chỉ biết đến sự nghiệp nữa. Anh đã học được bài học quý giá về tình yêu và sự tha thứ."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh21","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b22","lines":[{"emotion":"happy","pose":"stand","speaker_id":"mai","text":"Em nghĩ là có."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mai mỉm cười, nụ cười rạng rỡ sau bao năm. Cô nắm lấy tay Nam, một cái nắm tay nhẹ nhàng nhưng chứa đựng tất cả sự tin tưởng và tình yêu. Cơn bão đã qua, và tình yêu của họ đã được hàn gắn, mạnh mẽ hơn bao giờ hết."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh22","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"romantic","topic":"Tình Yêu Trong Bão Đêm","visuals":[{"character_ids":["nam"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_truc","tier":"medium"},{"character_ids":["nam","mai"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_truc","tier":"medium"},{"character_ids":["nam","mai","lan"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_cap_cuu","tier":"medium"},{"character_ids":["nam","mai","be_an","lan"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"phong_cap_cuu","tier":"medium"},{"character_ids":["nam","mai"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"}]}