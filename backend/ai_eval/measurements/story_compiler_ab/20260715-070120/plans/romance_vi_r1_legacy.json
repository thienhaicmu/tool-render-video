{"art_style":"modern anime","aspect_ratio":"16:9","chapter_no":0,"character_states":[{"character_id":"mai","continuity_notes":"Keep appearance and screen side stable within sc2","emotion":"normal","objective":"advance the scene objective","position":"left","scene_id":"sc2"},{"character_id":"nam","continuity_notes":"Keep appearance and screen side stable within sc2","emotion":"normal","objective":"advance the scene objective","position":"center","scene_id":"sc2"},{"character_id":"nam","continuity_notes":"Keep appearance and screen side stable within sc3","emotion":"normal","objective":"advance the scene objective","position":"center","scene_id":"sc3"},{"character_id":"mai","continuity_notes":"Keep appearance and screen side stable within sc3","emotion":"normal","objective":"advance the scene objective","position":"left","scene_id":"sc3"},{"character_id":"lan","continuity_notes":"Keep appearance and screen side stable within sc3","emotion":"normal","objective":"advance the scene objective","position":"center","scene_id":"sc3"},{"character_id":"nam","continuity_notes":"Keep appearance and screen side stable within sc4","emotion":"normal","objective":"advance the scene objective","position":"center","scene_id":"sc4"},{"character_id":"mai","continuity_notes":"Keep appearance and screen side stable within sc4","emotion":"normal","objective":"advance the scene objective","position":"left","scene_id":"sc4"},{"character_id":"nam","continuity_notes":"Keep appearance and screen side stable within sc5","emotion":"normal","objective":"resolve the central conflict","position":"center","scene_id":"sc5"},{"character_id":"mai","continuity_notes":"Keep appearance and screen side stable within sc5","emotion":"normal","objective":"resolve the central conflict","position":"left","scene_id":"sc5"}],"characters":[{"age":"30","archetype":"doctor","asset":"","canonical_desc":"Nam, khoảng 30 tuổi, tóc đen cắt gọn, dáng người cao ráo, mặc áo blouse trắng sạch sẽ. Ánh mắt anh thường đượm vẻ ưu tư nhưng rất kiên định khi làm việc.","gender":"male","id":"nam","name":"Bác sĩ Nam","voice_gender":"male","voice_style":""},{"age":"29","archetype":"doctor","asset":"","canonical_desc":"Mai, khoảng 29 tuổi, tóc dài ngang vai buộc gọn gàng, gương mặt thanh tú nhưng thường mang nét lạnh lùng, nghiêm nghị. Cô mặc áo blouse trắng, toát lên vẻ chuyên nghiệp.","gender":"female","id":"mai","name":"Bác sĩ Mai","voice_gender":"female","voice_style":""},{"age":"6","archetype":"child","asset":"","canonical_desc":"Bé An, khoảng 6 tuổi, tóc ngắn, gương mặt nhỏ nhắn, xanh xao vì bệnh. Bé nằm trên giường bệnh với vẻ yếu ớt.","gender":"female","id":"be_an","name":"Bé An","voice_gender":"female","voice_style":""},{"age":"25","archetype":"cafe_staff","asset":"","canonical_desc":"Y tá Lan, khoảng 25 tuổi, tóc búi cao, gương mặt hiền lành, luôn tận tâm với công việc. Cô mặc đồng phục y tá màu xanh.","gender":"female","id":"lan","name":"Y tá Lan","voice_gender":"female","voice_style":""}],"genre_key":"ngontinh","language":"vi","reading_pace":"normal","region":"vi","relationships":[],"render":{"asset_status":{},"beat_audio":{},"cues":[],"masters":{},"refs":{},"total_sec":0.0,"visual_assets":{},"voices":{}},"scenes":[{"beat_ids":["b1"],"continuity_key":"phong_truc","entry_state":"","exit_state":"","id":"sc1","participant_ids":[],"purpose":"setup","sequence_id":"seq1","setting_id":"phong_truc","shot_ids":["sh1"],"time_of_day":""},{"beat_ids":["b2","b3","b4"],"continuity_key":"phong_truc","entry_state":"","exit_state":"","id":"sc2","participant_ids":["mai","nam"],"purpose":"setup","sequence_id":"seq1","setting_id":"phong_truc","shot_ids":["sh2","sh3","sh4"],"time_of_day":""},{"beat_ids":["b5","b6","b7","b8","b9","b10","b11"],"continuity_key":"phong_cap_cuu","entry_state":"","exit_state":"","id":"sc3","participant_ids":["nam","mai","lan"],"purpose":"conflict","sequence_id":"seq2","setting_id":"phong_cap_cuu","shot_ids":["sh5","sh6","sh7","sh8","sh9","sh10","sh11"],"time_of_day":""},{"beat_