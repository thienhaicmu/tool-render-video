n":"front","composition":"symmetrical","eyeline":"environmental","id":"sh1","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"close","visual_id":"v1_stairs_discovery"},{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b2"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh2","lens":"wide","motion_intent":"pull_out","scene_id":"sc1","shot_size":"wide","visual_id":"v1_stairs_discovery"},{"angle":"over_shoulder","axis":"sc2:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2_gallery_watch"},{"angle":"high","axis":"sc2:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"centered","eyeline":"toward the opposing third","id":"sh4","lens":"wide","motion_intent":"push_in","scene_id":"sc2","shot_size":"wide","visual_id":"v2_gallery_watch"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3_ghostly_encounter"},{"angle":"low","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh6","lens":"portrait","motion_intent":"static","scene_id":"sc3","shot_size":"close","visual_id":"v3_ghostly_encounter"},{"angle":"high","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh7","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"close","visual_id":"v4_turning_the_lens"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"leading_lines","eyeline":"environmental","id":"sh8","lens":"wide","motion_intent":"pull_out","scene_id":"sc4","shot_size":"wide","visual_id":"v4_turning_the_lens"},{"angle":"low","axis":"sc5:primary","beat_ids":["b9"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh9","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v5_morning_peace"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"The Cursed Light","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The lighthouse had been dark for forty years when Elias took the keeper's job. The villagers called it cursed, but he only sought the quiet."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1_stairs_discovery"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"elias","text":"Climbing the spiral stairs on my first night, I found the old logbook left by Mara, the previous keeper. Its final entry was violently torn out."}],"motion":"zoom_out","narration":"","pause_after":0.7,"pose":"stand","reading_speed":0.88,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1_stairs_discovery"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"For weeks Elias tended the restored lamp, its powerful beam sweeping across the endless black water. Yet, a strange pattern emerged."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2_gallery_watch"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"sad","pose":"stand","speaker_id":"elias","text":"Every single night at exactly 3:07, the light flickers and dims on its own, and I hear a woman's voice in the wind calling a name that isn't mine."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2_gallery_watch"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"One storm-lashed evening, a ship's horn wailed desperately offshore, lost in the thick fog. Elias raced to the lamp, but it died completely."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3_ghostly_encounter"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"sad","pose":"stand","speaker_id":"mara","text":"I drowned in the cold waves forty years ago, unable to light the lamp in time. I have kept vigil ever since, trapped by my failure."}],"motion":"static","narration":"","pause_after":0.7,"pose":"stand","reading_speed":0.88,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3_ghostly_encounter"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Saving the Ship","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Understanding her pain, Elias took her cold, spectral hand. Together, living and dead turned the great brass lens by sheer force."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4_turning_the_lens"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"happy","pose":"cheer","speaker_id":"","text":"A spark caught, and the beam blazed out through the storm. Far out on the water, the ship's horn answered in gratitude as it steered safe past the rocks."}],"motion":"zoom_out","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4_turning_the_lens"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"happy","pose":"stand","speaker_id":"elias","text":"At dawn, the lamp still burned, but Mara was finally gone. Sitting on the gallery looking at the silver sea, the lighthouse felt not cursed, but free."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5_morning_peace"}],"tone":"mysterious, haunting, yet hopeful","topic":"The Vigil of the Lighthouse","visuals":[{"character_ids":["elias"],"id":"v1_stairs_discovery","negative_prompt":"","prompt":"","setting_id":"lighthouse_interior","tier":"medium"},{"character_ids":["elias"],"id":"v2_gallery_watch","negative_prompt":"","prompt":"","setting_id":"lighthouse_gallery","tier":"medium"},{"character_ids":["elias","mara"],"id":"v3_ghostly_encounter","negative_prompt":"","prompt":"","setting_id":"lighthouse_interior","tier":"medium"},{"character_ids":["elias","mara"],"id":"v4_turning_the_lens","negative_prompt":"","prompt":"","setting_id":"lighthouse_interior","tier":"medium"},{"character_ids":["elias"],"id":"v5_morning_peace","negative_prompt":"","prompt":"","setting_id":"lighthouse_gallery","tier":"medium"}]}