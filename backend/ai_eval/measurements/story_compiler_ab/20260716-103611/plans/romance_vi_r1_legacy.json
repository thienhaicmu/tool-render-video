"id":"sh7","lens":"portrait","motion_intent":"static","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh8","lens":"normal","motion_intent":"track_right","scene_id":"sc1","shot_size":"medium","visual_id":"v1"},{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh9","lens":"wide","motion_intent":"pull_out","scene_id":"sc1","shot_size":"wide","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Tình yêu trong bão tố","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong một đêm bão tố, bệnh viện trở nên nhộn nhịp hơn bao giờ hết. Những tiếng còi xe cứu thương vang lên liên tục."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Minh, em cần anh giúp đỡ! Có một ca cấp cứu đang đến!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Được rồi, Lan! Chúng ta sẽ cùng nhau xử lý!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cơn bão ngoài trời gió mạnh, mưa rơi như trút nước. Bên trong bệnh viện, mọi người đều bận rộn với công việc."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Hãy nhanh lên! Chúng ta không có nhiều thời gian!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Tôi sẽ chuẩn bị dụng cụ! Em hãy theo dõi tình trạng bệnh nhân!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hai bác sĩ làm việc không ngừng nghỉ, nhưng trong lòng họ vẫn còn những kỷ niệm đau thương."},{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Minh, em vẫn còn nhớ ngày đó không? Ngày mà chúng ta đã quyết định chia tay?"},{"emotion":"angry","pose":"stand","speaker_id":"minh","text":"Đừng nhắc đến chuyện đó nữa, Lan. Chúng ta cần tập trung vào công việc!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một cơn gió mạnh thổi qua, làm cho cửa sổ rung lên. Tình hình trở nên căng thẳng hơn khi bệnh nhân được đưa vào."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Chúng ta phải làm ngay! Bệnh nhân này cần phẫu thuật gấp!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Tôi sẽ gọi đội phẫu thuật ngay bây giờ!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong lúc phẫu thuật, cả hai bác sĩ đều tập trung cao độ, nhưng những cảm xúc vẫn trào dâng trong lòng họ."},{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Minh, em xin lỗi vì đã không tin anh lúc đó. Em đã hiểu lầm."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Em không cần phải xin lỗi. Chúng ta đều đã mắc sai lầm."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Phẫu thuật diễn ra suôn sẻ, nhưng ngoài trời, bão vẫn đang hoành hành. Tình yêu của họ cũng vậy, vẫn còn nhiều điều chưa nói."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Chúng ta có thể bắt đầu lại không, Minh? Em không muốn mất anh lần nữa."},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Nếu em thật sự muốn, anh sẽ không bao giờ để em đi nữa."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sau ca phẫu thuật, bệnh nhân đã ổn định. Hai bác sĩ nhìn nhau, ánh mắt họ đầy hy vọng."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Chúng ta đã làm được, Minh! Cảm ơn anh vì đã ở đây."},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Cảm ơn em, Lan. Anh cũng rất vui khi được làm việc cùng em."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cơn bão đã qua đi, ánh sáng mặt trời bắt đầu chiếu rọi vào bệnh viện. Tình yêu của họ cũng bắt đầu nở rộ."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Chúng ta hãy cùng nhau xây dựng lại từ đầu, được không?"},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Đúng vậy, Lan. Anh sẽ không bao giờ để em đi nữa."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hai bác sĩ cùng nhau bước ra khỏi bệnh viện, nắm tay nhau. Họ đã vượt qua bão tố và tìm lại được tình yêu."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Em yêu anh, Minh!"},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Anh cũng yêu em, Lan!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"tình cảm","topic":"Tình yêu trong bão tố","visuals":[{"character_ids":["lan","minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"hospital","tier":"medium"}]}