raphy","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh1","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"high","axis":"sc2:primary","beat_ids":["b2"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh2","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"negative_space","eyeline":"toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b4"],"blocking":"establish participants and geography","camera_position":"profile","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh4","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b5"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh5","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh6","lens":"portrait","motion_intent":"track_left","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b7"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"environmental","id":"sh7","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"environmental","id":"sh8","lens":"normal","motion_intent":"track_right","scene_id":"sc4","shot_size":"medium","visual_id":"v4"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Khởi đầu bi thương","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Giữa khung cảnh đổ nát, Hàn Phong quỳ bên nấm mộ của sư phụ, nắm chặt thanh kiếm gãy trong tay. Gió thổi qua, mang theo hơi hướm của khói còn vương vấn từ đêm định mệnh ấy. Thanh Vân môn đã chìm trong biển lửa, ngọn lửa phản bội của Mộ Dung Tuấn."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ba năm đã trôi qua, Hàn Phong xuống núi, bước chân vững chãi nhưng lòng nặng trĩu. Tuyệt kỹ 'Lưu Vân kiếm pháp' đã đến tầng thứ chín, như dòng nước chảy không ngừng, dẫn dắt chàng đến thành Lạc Dương. Ở đó, Mộ Dung Tuấn, người đã phản bội, giờ là trưởng lão Huyết Sát giáo."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong ánh đèn mờ ảo của tửu lâu Vọng Nguyệt, Hàn Phong bắt gặp ánh mắt kiên nghị của Tô Linh Nhi. Áo trắng như sương, nàng cũng đang mang một nỗi hận không thể nguôi ngoai."},{"emotion":"normal","pose":"stand","speaker_id":"to_linh_nhi","text":"Ngươi cũng tìm Mộ Dung Tuấn?"},{"emotion":"normal","pose":"stand","speaker_id":"han_phong","text":"Chúng ta cùng chung mối thù, hãy liên thủ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm trăng tròn, bóng tối bao trùm, hai người đột nhập tổng đàn Huyết Sát giáo. Ánh trăng soi sáng con đường, nhưng con tim họ bừng cháy bởi lòng căm hận."},{"emotion":"normal","pose":"stand","speaker_id":"mo_dung_tuan","text":"Ngươi tưởng một thanh kiếm gãy có thể đòi lại công đạo sao?"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hàn Phong không cần đáp lại bằng lời. Thanh kiếm rút ra, ánh thép lóe lên như dòng mây cuộn, sự im lặng trước bão tố."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.12,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trận chiến kéo dài, tiếng thép chạm nhau như bản hoà ca bi tráng. Khi bình minh ló dạng, Tô Linh Nhi trúng độc chưởng, gục xuống trong nỗi đau đớn."}],"motion":"zoom_in","narration":"","pause_after":0.7,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Giây phút quyết định","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong cơn phẫn nộ, Hàn Phong như bừng tỉnh. Tầng thứ mười của 'Lưu Vân kiếm pháp' - 'Vân Phá Thiên Khung' - hiển hiện trong tâm trí. Một đường kiếm tuyệt mỹ, đại điện sụp đổ, Mộ Dung Tuấn tan thành tro bụi."}],"motion":"pan_left","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.12,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hàn Phong đứng giữa tàn tích, ánh sáng bình minh chiếu lên gương mặt lấm máu của chàng. Mối thù đã báo, nhưng lòng trống rỗng, không niềm vui, không sự thỏa mãn."}],"motion":"static","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chàng bế Linh Nhi đã hôn mê lên vai, bước đi giữa tàn tích, hướng về phía mặt trời mọc. Một con đường mới có lẽ vẫn còn, cho kẻ sống sót giữa gió sương và ánh sáng tương lai."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":0.88,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"}],"tone":"Bi thương","topic":"Báo thù và sự sống sót","visuals":[{"character_ids":["han_phong"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"thanh_van_mon","tier":"medium"},{"character_ids":["han_phong"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"lac_duong","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"tu_lau_vong_nguyet","tier":"medium"},{"character_ids":["han_phong","mo_dung_tuan","to_linh_nhi"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"tong_dan_huyet_sat_giao","tier":"medium"}]}