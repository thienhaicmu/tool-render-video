camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh13","lens":"portrait","motion_intent":"static","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"high","axis":"sc1:primary","beat_ids":["b14"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh14","lens":"normal","motion_intent":"track_right","scene_id":"sc1","shot_size":"medium","visual_id":"v1"},{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh15","lens":"wide","motion_intent":"pull_out","scene_id":"sc1","shot_size":"wide","visual_id":"v1"},{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh16","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"extreme_close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Trong một ngôi nhà nhỏ, Ngọc đang chuẩn bị cho ngày tốt nghiệp của mình. Cô cảm thấy hồi hộp và hạnh phúc."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc","text":"Bố ơi, con sắp tốt nghiệp rồi! Con muốn có một bữa tiệc nhỏ tại nhà."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"hoang","text":"Bố sẽ làm món phở mà mẹ con thích nhất. Đây là lời hứa của bố với mẹ con."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hoàng, người cha ít nói, quyết định học nấu món phở để giữ lời hứa với con gái."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hoàng bắt đầu tìm kiếm công thức nấu phở trên mạng. Ông cảm thấy hồi hộp và lo lắng."},{"emotion":"normal","pose":"stand","speaker_id":"hoang","text":"Món phở này không dễ làm như mình nghĩ. Mình phải cố gắng thật nhiều!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày hôm sau, Hoàng bắt đầu chuẩn bị nguyên liệu. Ông chọn những nguyên liệu tươi ngon nhất."},{"emotion":"normal","pose":"stand","speaker_id":"hoang","text":"Mình sẽ làm món phở thật ngon để Ngọc vui lòng."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Trong khi nấu, Hoàng nhớ về những kỷ niệm với vợ. Ông cảm thấy nỗi nhớ trào dâng."},{"emotion":"normal","pose":"stand","speaker_id":"hoang","text":"Mẹ con sẽ tự hào về món phở này. Mình sẽ làm hết sức mình!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hoàng nấu phở với tâm huyết, từng bước một. Ông cảm thấy gần gũi với vợ hơn."},{"emotion":"normal","pose":"stand","speaker_id":"hoang","text":"Món phở này không chỉ là món ăn, mà còn là tình yêu của gia đình."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Cuối cùng, món phở cũng đã hoàn thành. Hoàng dọn ra bàn ăn, lòng đầy hồi hộp."},{"emotion":"happy","pose":"stand","speaker_id":"hoang","text":"Ngọc, đến giờ ăn rồi! Bố đã làm món phở mà mẹ con thích!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"happy","pose":"stand","speaker_id":"ngoc","text":"Wow, món phở trông thật ngon! Con cảm ơn bố rất nhiều!"},{"emotion":"happy","pose":"stand","speaker_id":"","text":"Ngọc ngồi xuống bàn, ánh mắt lấp lánh. Cô cảm nhận được tình yêu trong từng bát phở."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Khi ăn, Ngọc nhớ về mẹ. Cô cảm thấy mẹ đang ở bên cạnh mình."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc","text":"Con cảm thấy mẹ đang nhìn chúng ta. Món phở thật tuyệt vời!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"hoang","text":"Mẹ con luôn ở trong tim chúng ta. Hãy cùng nhau giữ gìn những kỷ niệm."},{"emotion":"happy","pose":"stand","speaker_id":"","text":"Hoàng mỉm cười, cảm nhận được sự kết nối giữa ba người trong bữa ăn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Bữa tiệc nhỏ trở thành một kỷ niệm đẹp trong lòng cả hai cha con. Họ cùng nhau cười và chia sẻ."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc","text":"Bố, con yêu món phở này! Cảm ơn bố đã làm cho con!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Hoàng và Ngọc cùng nhau dọn dẹp sau bữa ăn. Họ cảm thấy hạnh phúc và gần gũi hơn."},{"emotion":"happy","pose":"stand","speaker_id":"hoang","text":"Chúng ta sẽ cùng nhau nấu món phở này mỗi năm nhé!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày tốt nghiệp đã trôi qua, nhưng tình yêu và kỷ niệm vẫn mãi còn."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc","text":"Con sẽ luôn nhớ về mẹ và món phở này!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Hoàng nhìn Ngọc, lòng tràn đầy tự hào. Ông biết rằng mình đã giữ lời hứa."},{"emotion":"happy","pose":"stand","speaker_id":"hoang","text":"Mẹ con sẽ luôn tự hào về con, Ngọc ạ!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tình yêu gia đình luôn là điều quý giá nhất. Hoàng và Ngọc đã cùng nhau vượt qua nỗi đau."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc","text":"Chúng ta sẽ luôn bên nhau, phải không bố?"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Và như vậy, món phở không chỉ là món ăn, mà còn là biểu tượng của tình yêu và kỷ niệm."},{"emotion":"happy","pose":"stand","speaker_id":"hoang","text":"Đúng vậy, Ngọc. Tình yêu gia đình sẽ mãi mãi tồn tại!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"tâm tình","topic":"Người cha và món phở","visuals":[{"character_ids":["ngoc","hoang"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"home","tier":"medium"}]}