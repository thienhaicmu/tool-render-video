he opposing third","id":"sh5","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh6","lens":"normal","motion_intent":"track_left","scene_id":"sc5","shot_size":"medium","visual_id":"v5"},{"angle":"low","axis":"sc5:primary","beat_ids":["b7"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh7","lens":"portrait","motion_intent":"static","scene_id":"sc5","shot_size":"close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Khởi đầu bi thương","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hàn Phong quỳ bên nấm mộ của sư phụ, nắm chặt thanh kiếm gãy trong tay. Gió thổi qua, lạnh như lưỡi dao cắt vào lòng."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm đó, cả Thanh Vân môn chìm trong biển lửa, phản bội của Mộ Dung Tuấn như móng vuốt dã thú xé toạc tâm can."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chỉ mình chàng sống sót, mang theo những mảnh vỡ của một ngày xưa."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ba năm sau, Hàn Phong xuống núi. Trong ánh mắt chàng, quyết tâm sáng như thép."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lưu Vân kiếm pháp đã chín, như dòng mây uốn lượn trong tâm trí."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chàng lần theo dấu vết của Huyết Sát giáo đến thành Lạc Dương, nơi Mộ Dung Tuấn giờ đã thành trưởng lão quyền uy."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tại tửu lâu Vọng Nguyệt, trong ánh sáng mờ nhạt của ngọn đèn, chàng gặp Tô Linh Nhi."},{"emotion":"normal","pose":"stand","speaker_id":"to_linh_nhi","text":"Ta đang tìm kẻ thù của mình. Chúng ta có lẽ có chung mục tiêu."},{"emotion":"normal","pose":"stand","speaker_id":"han_phong","text":"Vậy thì chúng ta sẽ liên thủ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm trăng tròn, hai bóng hình âm thầm đột nhập tổng đàn Huyết Sát giáo. Ánh trăng soi sáng những bước chân lặng lẽ như mèo rừng."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong đại điện, Mộ Dung Tuấn đã chờ sẵn, xung quanh là trăm tên giáo chúng, nhẫn tâm như bầy quạ đen giữa đêm."},{"emotion":"normal","pose":"stand","speaker_id":"mo_dung_tuan","text":"Ngươi tưởng một thanh kiếm gãy có thể đòi lại công đạo sao?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Trận chiến quyết định","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hàn Phong không đáp. Chàng rút kiếm, ánh thép loé lên như dòng mây cuộn, cuốn vào trận chiến giằng co."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trận chiến kéo dài, từng nhịp thở đếm ngược tới bình minh lạnh lẽo."},{"emotion":"normal","pose":"stand","speaker_id":"to_linh_nhi","text":"Linh Nhi trúng độc chưởng, gục xuống, cả thế giới như dừng lại trong một khoảnh khắc."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong cơn phẫn nộ, Hàn Phong lĩnh ngộ tầng thứ mười của kiếm pháp — 'Vân Phá Thiên Khung'."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một kiếm chém ra, mạnh mẽ như sấm rền ngang trời."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cả đại điện sụp đổ, Mộ Dung Tuấn tan thành tro bụi, sự phản bội cũng biến mất vào hư vô."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bình minh chiếu lên gương mặt lấm máu của Hàn Phong, ánh sáng mới mà trống rỗng như một lời hứa chưa thực hiện."},{"emotion":"normal","pose":"stand","speaker_id":"han_phong","text":"Chàng bế Linh Nhi đã hôn mê lên vai, bước đi giữa tàn tích, hướng về phía mặt trời mọc."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nơi đó, có lẽ vẫn còn một con đường khác cho kẻ sống sót, một hy vọng mỏng manh như ánh dương le lói."}],"motion":"static","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"U ám","topic":"Báo thù và sự sống sót","visuals":[{"character_ids":["han_phong"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"thanh_van_mon","tier":"medium"},{"character_ids":["han_phong"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"lac_duong","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"tu_lau_vong_nguyet","tier":"medium"},{"character_ids":["han_phong","mo_dung_tuan"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"tong_dan_huyet_sat_giao","tier":"medium"},{"character_ids":["han_phong","to_linh_nhi"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"tong_dan_huyet_sat_giao","tier":"medium"}]}