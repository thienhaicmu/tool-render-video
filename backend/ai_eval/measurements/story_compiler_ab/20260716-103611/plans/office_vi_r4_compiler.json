ocking":"establish participants and geography","camera_position":"profile","composition":"negative_space","eyeline":"toward the opposing third","id":"sh8","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh9","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b10"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh10","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b11"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh11","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"low","axis":"sc5:primary","beat_ids":["b12"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"centered","eyeline":"toward the opposing third","id":"sh12","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b13"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh13","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"extreme_close","visual_id":"v5"},{"angle":"high","axis":"sc5:primary","beat_ids":["b14"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh14","lens":"wide","motion_intent":"push_in","scene_id":"sc5","shot_size":"wide","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Khởi đầu mối quan hệ","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trên bàn làm việc ngổn ngang giấy tờ, Hương nhìn chăm chú vào màn hình máy tính. Mặc dù đã nộp đơn nghỉ việc từ tuần trước, cô vẫn cảm thấy nặng lòng. Mọi thứ sẽ ổn thôi, cô tự nhủ."},{"emotion":"surprised","pose":"stand","speaker_id":"huong","text":"Sao báo cáo này lại đúng hết?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cô nhăn mặt, nhớ lại từng lần sai sót đã làm mình mất mặt trước sếp. Nhưng bây giờ, mọi thứ được sửa sang hoàn hảo."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trên đường về, Hương tình cờ nghe được cuộc trò chuyện giữa hai đồng nghiệp."},{"emotion":"normal","pose":"stand","speaker_id":"dong_nghiep_1","text":"Cậu biết không, ai cũng nghĩ Hương giỏi lắm. Thực ra, toàn Thái sửa giúp cô ấy đấy."},{"emotion":"surprised","pose":"stand","speaker_id":"dong_nghiep_2","text":"Thái à? Sao lại là anh ta?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hương khựng lại, trái tim đập mạnh. Thái, người mà cô luôn nghĩ là lạnh lùng, hóa ra đã âm thầm giúp đỡ mình. Nhưng tại sao?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày hôm sau, Hương quyết định tìm Thái để hỏi cho rõ. Cô bước vào phòng họp nơi Thái đang ngồi một mình, mắt dán vào màn hình laptop."},{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Thái, tại sao anh sửa lỗi cho tôi mà không nói?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"thai","text":"Vì tôi thấy cô có tiềm năng. Chỉ cần chút trợ giúp, cô sẽ làm được."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Cảm ơn anh... Nhưng giờ tôi nghe nói anh đang bị đổ lỗi cho việc gì đó không hay."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cả hai tiếp tục câu chuyện ở quầy cà phê khi Thái giải thích về những lời buộc tội sai trái từ đồng nghiệp."},{"emotion":"angry","pose":"stand","speaker_id":"thai","text":"Họ đổ cho tôi lấy cắp dữ liệu. Tôi không làm thế!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Tôi sẽ giúp anh chứng minh sự trong sạch."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong ánh mắt Thái, sự bất ngờ xen lẫn chút hy vọng. Hương nhận ra đây là cơ hội để đền đáp lại Thái."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hương và Thái làm việc muộn để tìm bằng chứng. Ánh đèn từ màn hình chiếu sáng khuôn mặt căng thẳng của họ."},{"emotion":"happy","pose":"stand","speaker_id":"huong","text":"Tôi tìm thấy rồi! Đây là chứng cứ để minh oan cho anh."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"thai","text":"Cảm ơn cô, Hương."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cả hai bước ra ngoài, ánh trăng lấp lánh trên bầu trời. Họ biết rằng sau ngày mai, mọi thứ sẽ khác. Nhưng điều quan trọng là họ đã tìm thấy sự tin tưởng ở nhau."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Từ góc khuất của hành lang, một đồng nghiệp khác đang nhìn theo cặp đôi, vẻ mặt đầy sự ghen tị và tiếc nuối."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"tâm trạng","topic":"Mối quan hệ đồng nghiệp","visuals":[{"character_ids":["huong"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"van_phong","tier":"medium"},{"character_ids":["huong","dong_nghiep_1","dong_nghiep_2"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"},{"character_ids":["huong","thai"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_hop","tier":"medium"},{"character_ids":["huong","thai"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"quay_ca_phe","tier":"medium"},{"character_ids":["huong","thai"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"van_phong_toi","tier":"medium"}]}