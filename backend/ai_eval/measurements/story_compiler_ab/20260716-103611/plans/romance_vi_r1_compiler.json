_id":"v2"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b3"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"symmetrical","eyeline":"environmental","id":"sh3","lens":"wide","motion_intent":"pull_out","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b4"],"blocking":"establish participants and geography","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh4","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"toward the opposing third","id":"sh6","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b7"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh7","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b8"],"blocking":"establish participants and geography","camera_position":"profile","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh8","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh9","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Đêm dài chờ đợi","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hương và Minh đứng đối diện nhau trong căn phòng trực, ánh đèn lạnh lẽo phản chiếu lên những tấm kính cửa sổ. Cơn bão ngoài kia như muốn xé toạc mọi thứ, nhưng bên trong, không khí căng thẳng còn lớn hơn cả thiên nhiên."},{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Đêm nay có vẻ sẽ dài lắm."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Chúng ta đã quen rồi."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một bé gái bị tai nạn xe đạp được đưa vào trong tình trạng nguy kịch. Đôi mắt của Hương lóe lên quyết tâm khi cô bắt tay vào cứu chữa. Minh, với sự điềm tĩnh chín chắn, đứng bên cạnh hỗ trợ."},{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Minh, cần máu nhóm B ngay!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Đã gọi phòng máu, họ đang mang lên."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hai con người, từng thân thuộc như hơi thở, giờ lại phối hợp nhịp nhàng như không hề có sự chia cắt nào. Phía ngoài, tiếng sấm rền vang như nhịp trống giục giã."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Giờ đây, trong khoảnh khắc ngắn ngủi của sự yên lặng, Hương và Minh đứng cạnh nhau, mệt mỏi nhưng không thể phủ nhận sự hòa hợp khi cùng cứu sống bé gái ấy."},{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Em không nghĩ mình có thể làm được nếu không có anh."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Anh cũng vậy. Chúng ta từng là đội tốt nhất."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lời nói của Minh như mở ra một cánh cửa cũ, nơi kỷ niệm ùa về như dòng nước lũ. Nhưng liệu có nên bước qua không?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cơn bão đã giảm bớt, nhưng cả hai vẫn còn thức. Họ ngồi cùng nhau, nhìn ra màn mưa ngoài cửa sổ. Một cuộc đối thoại đã lâu không diễn ra, mà giờ đây, cảm giác như một điều tất yếu phải xảy ra."},{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Anh còn giận em vì chuyện đó không?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Không, chỉ là anh chưa bao giờ hiểu tại sao em lại rời đi."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Những lời nói ấy như chìa khóa mở ra tất cả. Họ bắt đầu chia sẻ, từng lời từng câu, để hiểu và hàn gắn những gì đã mất. Cơn bão ngoài kia dần tan, để lại bầu trời sáng hơn."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bầu trời sau bão trong trẻo lạ thường. Minh và Hương bước ra khỏi bệnh viện, ánh nắng ấm áp chiếu sáng lên khuôn mặt họ."},{"emotion":"normal","pose":"stand","speaker_id":"huong","text":"Chúng ta có thể làm lại từ đầu không?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Chúng ta sẽ là đội tốt nhất, lần này anh hứa."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ nắm tay nhau, bước đi dưới ánh mặt trời, để lại đằng sau cơn bão và những hiểu lầm. Một khởi đầu mới đang chờ đợi phía trước."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"tình cảm","topic":"Câu chuyện tình yêu giữa Hương và Minh","visuals":[{"character_ids":["huong","minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"benh_vien_phong_cho","tier":"medium"},{"character_ids":["huong","minh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_cap_cuu","tier":"medium"},{"character_ids":["huong","minh"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"hanh_lang_benh_vien","tier":"medium"},{"character_ids":["huong","minh"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"phong_truc_dem","tier":"medium"},{"character_ids":["huong","minh"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"cua_benh_vien_sang_som","tier":"medium"}]}