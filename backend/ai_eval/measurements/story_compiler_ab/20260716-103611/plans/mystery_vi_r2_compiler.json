"camera_position":"three_quarter","composition":"centered","eyeline":"toward the opposing third","id":"sh13","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b14"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh14","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v1"},{"angle":"high","axis":"sc5:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh15","lens":"normal","motion_intent":"track_right","scene_id":"sc5","shot_size":"medium","visual_id":"v1"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"environmental","id":"sh16","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"","id":"b1","lines":[],"motion":"pan_up","narration":"Ánh nắng len lỏi qua cửa sổ bụi bặm, đọng lại trên những chiếc đồng hồ cũ kĩ xếp hàng chờ sửa. Ông Thanh, người thợ sửa đồng hồ, chăm chú ngắm nghía từng bánh răng, từng kim đồng hồ.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ong_thanh","text":"Lạ thật, sao mỗi chiếc đồng hồ đều có một phút kỷ niệm?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[],"motion":"pan_right","narration":"Ông Thanh phát hiện ra rằng trong mỗi chiếc đồng hồ hỏng, có một khoảng khắc ký ức của chủ nhân chúng. Một ngày, ông tò mò mở thử một ký ức và thấy hình ảnh của em trai mình, Hoàng, người đã mất tích cách đây hai năm.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[],"motion":"pan_up","narration":"Ông Thanh ngồi trong căn phòng chật hẹp của mình, xung quanh là những chiếc đồng hồ đã qua tay ông sửa. Mỗi lần mở một chiếc đồng hồ mới, ông lại hồi hộp chờ đợi.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ong_thanh","text":"Em trai mình... có liên quan gì đến những ký ức này?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[],"motion":"zoom_in","narration":"Ông bắt đầu ráp nối từng mảnh ký ức, dần dần bức tranh về cuộc sống của Hoàng hiện ra trước mắt. Mỗi ký ức là một manh mối, đưa ông dần đến gần hơn với sự thật.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[],"motion":"pan_up","narration":"Trong một ký ức, ông Thanh thấy Hoàng gặp gỡ một người đàn ông lạ trong công viên. Hình ảnh đó khiến ông không khỏi băn khoăn.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ong_thanh","text":"Người đàn ông này là ai, tại sao họ gặp nhau ở đây?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[],"motion":"pan_right","narration":"Ông quyết tâm tìm ra người đàn ông đó. Ông đến công viên hàng ngày, hy vọng tìm được dấu vết của người ấy.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[],"motion":"pan_up","narration":"Tại một quán cà phê gần công viên, ông Thanh ngồi chờ. Sau vài tuần, ông thấy người đàn ông trong ký ức bước vào.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ong_thanh","text":"Đây chính là cơ hội."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[],"motion":"zoom_in","narration":"Ông tiếp cận người đàn ông và hỏi thẳng về Hoàng. Người đàn ông ban đầu lúng túng, nhưng rồi thở dài và quyết định kể lại câu chuyện.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguoi_an_ong","text":"Hoàng đã dấn quá sâu, và rồi biến mất..."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[],"motion":"pan_up","narration":"Trở lại tiệm đồng hồ, ông Thanh cẩn thận ráp nối những mảnh ghép cuối cùng. Sự thật về cuộc sống bí ẩn của Hoàng hiện ra, với những lựa chọn và sai lầm đã dẫn đến biến cố.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ong_thanh","text":"Có lẽ đó là con đường mà em đã chọn..."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[],"motion":"zoom_out","narration":"Dù bàng hoàng, ông Thanh hiểu rằng mỗi ký ức trong chiếc đồng hồ là một phần của cuộc đời Hoàng, một phần ông cần trân trọng và giữ gìn. Chiếc đồng hồ cuối cùng khép lại, nhưng kỷ niệm về Hoàng sẽ mãi mãi ở lại trong lòng ông.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"","topic":"","visuals":[{"character_ids":[],"id":"v1","negative_prompt":"","prompt":"","setting_id":"tiem_ong_ho_nho","tier":"medium"},{"character_ids":[],"id":"v2","negative_prompt":"","prompt":"","setting_id":"can_phong_nho","tier":"medium"},{"character_ids":[],"id":"v3","negative_prompt":"","prompt":"","setting_id":"cong_vien_vang_ve","tier":"medium"},{"character_ids":[],"id":"v4","negative_prompt":"","prompt":"","setting_id":"quan_ca_phe","tier":"medium"}]}