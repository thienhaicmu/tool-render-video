er_id":"mai","text":"Bố ơi, con sắp tốt nghiệp rồi! Con muốn ăn phở do chính tay bố nấu!"},{"emotion":"normal","pose":"stand","speaker_id":"ba_hai","text":"Bố sẽ cố gắng, Mai. Bố hứa sẽ nấu món phở ngon nhất cho con."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bố Hải bắt đầu tìm hiểu công thức nấu phở. Ông lật từng trang sách nấu ăn, cảm thấy hồi hộp."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Ông thử nghiệm nhiều lần, nhưng mỗi lần đều không đạt yêu cầu. Sự thất vọng dâng trào."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"angry","pose":"stand","speaker_id":"ba_hai","text":"Tại sao mình không thể làm được? Mình phải làm cho Mai một bữa tiệc thật đặc biệt!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một đêm, ông mơ thấy vợ mình, bà mỉm cười và nói: 'Hãy nấu bằng cả trái tim'."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ba_hai","text":"Sáng hôm sau, ông quyết tâm bắt tay vào nấu phở một lần nữa, lần này với tâm thế khác."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Bữa tiệc phở!","id":"b9","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Bố Hải nấu phở với tất cả tình yêu thương. Mùi hương thơm ngào ngạt lan tỏa khắp nhà."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"happy","pose":"stand","speaker_id":"mai","text":"Bố ơi, con ngửi thấy mùi phở! Thật tuyệt vời!"},{"emotion":"normal","pose":"stand","speaker_id":"ba_hai","text":"Đây là món phở của bố, dành riêng cho con."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Mai ngồi xuống bàn, ánh mắt sáng lên khi nhìn bát phở nóng hổi. Cô cảm nhận được tình yêu trong từng miếng ăn."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"happy","pose":"stand","speaker_id":"mai","text":"Bố ơi, phở ngon quá! Con cảm ơn bố rất nhiều!"},{"emotion":"happy","pose":"stand","speaker_id":"ba_hai","text":"Bố rất vui khi con thích. Đây là món quà từ bố."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Bữa tiệc phở kết thúc trong tiếng cười và niềm hạnh phúc. Bố Hải cảm thấy nhẹ nhõm, như thể vợ mình đang ở bên cạnh."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Mai ôm chầm lấy bố, nước mắt rưng rưng. Cô biết rằng tình yêu của bố sẽ mãi mãi ở bên mình."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"ba_hai","text":"Bố sẽ luôn ở đây, Mai. Dù có chuyện gì xảy ra, tình yêu của bố sẽ không bao giờ phai nhạt."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Câu chuyện của bố Hải và Mai không chỉ là về món phở, mà còn là về tình yêu và sự kết nối giữa cha và con."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"}],"tone":"cảm động","topic":"Người cha và món phở","visuals":[{"character_ids":["ba_hai"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_bep","tier":"medium"},{"character_ids":["mai"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_khach","tier":"medium"},{"character_ids":["ba_hai","mai"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_bep","tier":"medium"}]}