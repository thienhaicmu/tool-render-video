auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cô ấy cảm thấy áp lực từ công việc, đặc biệt là khi sếp Anh luôn theo dõi từng bước đi của cô."},{"emotion":"happy","pose":"stand","speaker_id":"hieu","text":"Đừng lo lắng quá, Lan. Mọi người đều mắc sai lầm mà."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hiếu, đồng nghiệp của Lan, luôn cố gắng động viên cô, nhưng Lan vẫn cảm thấy nặng nề trong lòng."},{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Cảm ơn Hiếu, nhưng tôi không thể thoát khỏi cảm giác tội lỗi này."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong giờ nghỉ, Lan và Hiếu ngồi trò chuyện trong phòng nghỉ, cố gắng tìm cách giải quyết vấn đề."},{"emotion":"surprised","pose":"stand","speaker_id":"hieu","text":"Có thể ai đó đang cố tình đổ lỗi cho bạn. Bạn có nghĩ vậy không?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan ngạc nhiên trước ý kiến của Hiếu, cô chưa bao giờ nghĩ đến khả năng đó."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Nếu đúng như vậy, tôi phải tìm ra người đó."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan quyết định đối mặt với trưởng phòng Anh trong cuộc họp tiếp theo, cô cảm thấy hồi hộp và lo lắng."},{"emotion":"angry","pose":"stand","speaker_id":"anh","text":"Tôi không thể chấp nhận những sai lầm này, Lan. Bạn phải chịu trách nhiệm!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ánh mắt của Anh sắc lạnh, khiến Lan cảm thấy như bị dồn vào chân tường."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Tôi đã làm việc chăm chỉ, và tôi không phải là người duy nhất mắc lỗi."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Sự thật bị phơi bày!","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuối cùng, Lan quyết định tìm kiếm sự thật và phát hiện ra rằng Hiếu đã âm thầm sửa chữa những sai lầm của cô."},{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Tại sao bạn không nói cho tôi biết, Hiếu?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Hiếu nhìn Lan với ánh mắt buồn bã, anh không biết phải giải thích như thế nào."},{"emotion":"sad","pose":"stand","speaker_id":"hieu","text":"Tôi chỉ muốn giúp bạn, nhưng tôi không muốn bạn cảm thấy mình yếu đuối."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan cảm thấy tức giận nhưng cũng hiểu được ý tốt của Hiếu."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Tôi cần bạn bên cạnh, không phải giấu giếm."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cả hai quyết định cùng nhau đối mặt với trưởng phòng Anh và làm rõ mọi chuyện."},{"emotion":"happy","pose":"stand","speaker_id":"hieu","text":"Chúng ta sẽ không để ai đổ lỗi cho bạn nữa!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuộc họp tiếp theo diễn ra, Lan và Hiếu đứng cạnh nhau, quyết tâm bảo vệ sự thật."},{"emotion":"angry","pose":"stand","speaker_id":"anh","text":"Tôi không muốn nghe lý do, Lan. Bạn đã thất bại."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan tự tin đứng lên, nhìn thẳng vào 