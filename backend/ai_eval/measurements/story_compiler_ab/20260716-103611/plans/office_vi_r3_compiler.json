:["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"symmetrical","eyeline":"environmental","id":"sh4","lens":"portrait","motion_intent":"static","scene_id":"sc2","shot_size":"close","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"high","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh6","lens":"wide","motion_intent":"pull_out","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"centered","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"environmental","id":"sh8","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b9"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh9","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b10"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh10","lens":"portrait","motion_intent":"static","scene_id":"sc5","shot_size":"close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Một bức thư nặc danh!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng máy in kêu rì rì giữa không gian văn phòng. Lan đang thu dọn bàn làm việc, chuẩn bị ra đi sau giờ nghỉ trưa. Một bức thư nặc danh trượt khỏi xấp hồ sơ cũ trên bàn."},{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Cái gì đây?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan mở phong bì, bên trong là những tài liệu bị sửa chữa tinh vi mà cô không hề hay biết. Cô nhìn quanh, thấy Hùng, đồng nghiệp nổi tiếng kín tiếng, đang chăm chú trước máy tính."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan hẹn gặp Hùng trong phòng họp vắng lặng. Ánh sáng từ cửa sổ hắt lên bàn gỗ bóng loáng."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Anh sửa những sai sót của tôi, đúng không?"},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Tôi chỉ muốn mọi thứ suôn sẻ hơn. Không ai cần phải biết."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan ngước nhìn Hùng, cảm thấy nặng lòng. Hóa ra, sự hoàn hảo của cô suốt bao năm qua đều nhờ anh. Nhưng bây giờ, người ta đổ lỗi cho anh về thất thoát tài chính mới đây."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan đi nhanh qua hành lang, nắm trong tay những chứng cứ từ bức thư. Cô ngừng lại khi gặp sếp lớn đang tiến tới."},{"emotion":"normal","pose":"stand","speaker_id":"sep","text":"Lan, tôi cần nói chuyện với cô về Hùng."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Tôi có điều cần giải thích với ông."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sếp nhìn Lan, vẻ mặt không thể đọc vị. Tim Lan đập thình thịch, hiểu rằng cô phải đứng ra bảo vệ Hùng."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong phòng sếp, Lan đặt những tài liệu lên bàn, giải thích mọi thứ một cách rõ ràng. Sếp ngồi đối diện, lắng nghe chăm chú."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Chính tôi mới là người đáng trách. Hùng đã giúp tôi không biết bao lần."},{"emotion":"normal","pose":"stand","speaker_id":"sep","text":"Cảm ơn Lan. Tôi sẽ xem xét lại sự việc."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan thở phào, cảm nhận gánh nặng trong lòng đã vơi bớt. Cô biết, sự thật đã được đưa ra ánh sáng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chiều đó, Lan và Hùng ngồi trong quán cà phê quen thuộc. Tiếng nhạc nhẹ nhàng vang lên, xua tan mọi căng thẳng."},{"emotion":"happy","pose":"stand","speaker_id":"hung","text":"Cảm ơn cô đã tin tưởng."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Là tôi phải cảm ơn anh. Nếu không có anh, tôi sẽ không biết bản thân mình đã thành công nhờ ai."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hai người nhìn nhau, cười nhẹ. Bên ngoài, ánh nắng buổi chiều vàng rực trải dài qua ô cửa kính, như một lời hứa về khởi đầu mới."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"drama","topic":"Sự thật và lòng tin","visuals":[{"character_ids":["lan"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"van_phong","tier":"medium"},{"character_ids":["lan","hung"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_hop","tier":"medium"},{"character_ids":["lan","sep"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"},{"character_ids":["lan","sep"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"phong_sep","tier":"medium"},{"character_ids":["lan","hung"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"quan_ca_phe","tier":"medium"}]}