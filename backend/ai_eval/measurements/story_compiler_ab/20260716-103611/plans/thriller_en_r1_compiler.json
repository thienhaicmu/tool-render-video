imary","beat_ids":["b1"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh1","lens":"wide","motion_intent":"reveal","scene_id":"sc1","shot_size":"wide","visual_id":"v1"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b2"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh2","lens":"portrait","motion_intent":"reveal","scene_id":"sc2","shot_size":"close","visual_id":"v2"},{"angle":"low","axis":"sc2:primary","beat_ids":["b3"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh3","lens":"portrait","motion_intent":"static","scene_id":"sc2","shot_size":"close","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc2:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh4","lens":"normal","motion_intent":"track_right","scene_id":"sc2","shot_size":"medium","visual_id":"v2"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"low","axis":"sc4:primary","beat_ids":["b6"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh6","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b7"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh7","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The dim glow of screens flickered across Jace's face as he scanned the live feed of the railway network. A sudden crackle shattered the rhythmic hum of the control room. The voice was faint, distorted by decades of static, yet unmistakably urgent."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A ghostly call!","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"old_radio_voice","text":"This is train 107. We're off schedule... need assistance. Anyone copy?"},{"emotion":"surprised","pose":"stand","speaker_id":"jace","text":"Train 107, confirm your location. Over."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Jace's fingers froze over the keyboard. Train 107 hadn't been mentioned since the accident thirty years ago. Yet here it was, calling from nowhere, a ghostly echo trapped in time."},{"emotion":"normal","pose":"stand","speaker_id":"old_radio_voice","text":"Fog... we can't see... please, help us!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The monitors blinked, and Jace’s heart raced against the rising tension. His mind spun stories of haunted tracks and forgotten tragedies. The room felt colder, the air thick with whispers of the past."},{"emotion":"normal","pose":"stand","speaker_id":"jace","text":"Train 107, proceed with caution. I'm routing help to your last known position. Stay on the line."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Jace's voice bridged the years, reaching into the heart of the marshlands. Outside, fog rolled over the tracks, thick and impenetrable. The past and present collided in a symphony of grinding steel and spectral cries."},{"emotion":"normal","pose":"stand","speaker_id":"old_radio_voice","text":"We see a light... thank you."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Silence returned to the control room as the connection faded. Jace leaned back, heart still pounding, eyes fixed on the empty monitors. The ghost train's call had ceased, but the mystery lingered like a forgotten dream."},{"emotion":"normal","pose":"stand","speaker_id":"jace","text":"Maybe some things aren't meant to be solved."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As the first light of dawn seeped through the windows, Jace understood that some echoes of the past were best left unanswered, their stories woven into the fabric of the railways."}],"motion":"zoom_in","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"}],"tone":"tense","topic":"The Ghost Train","visuals":[{"character_ids":["jace"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"control_room","tier":"medium"},{"character_ids":["jace","old_radio_voice"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"control_room_intense","tier":"medium"},{"character_ids":["old_radio_voice"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"marshlands","tier":"medium"},{"character_ids":["jace"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"control_room_calm","tier":"medium"}]}