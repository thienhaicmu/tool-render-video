the active speaker on the dominant third","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh4","lens":"portrait","motion_intent":"reveal","scene_id":"sc3","shot_size":"extreme_close","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh6","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh7","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Ngày mai là ngày của con","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ánh nắng xuyên qua cửa sổ, chiếu thẳng vào gian bếp nhỏ ấm cúng. Trên bàn, bát phở nghi ngút khói, hương thơm quế và hồi tỏa ra khắp phòng. Ông Minh ngắm nhìn tô phở với ánh mắt trầm ngâm."},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Ngày mai là ngày của con rồi, Mai."},{"emotion":"happy","pose":"stand","speaker_id":"mai","text":"Ba, ba không cần phải lo đâu. Con biết ba sẽ làm được."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Dưới ánh đèn vàng, sách nấu ăn mở rộng trên bàn. Ông Minh đeo kính đọc từng chữ, tập trung tối đa. Nước trong nồi sôi sùng sục, ông cẩn thận bỏ từng thanh quế, mẩu hồi vào nồi. Tiếng đồng hồ tích tắc nhắc nhở thời gian không ngừng trôi."},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Phải giống hệt cách mẹ con đã làm."},{"emotion":"happy","pose":"stand","speaker_id":"mai","text":"Con tin ở ba."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày tốt nghiệp của Mai. Bức tường treo đầy hình ảnh gia đình. Mai trong bộ đồng phục tốt nghiệp, đứng trước gương nở nụ cười rạng rỡ."},{"emotion":"surprised","pose":"stand","speaker_id":"mai","text":"Ba, con sắp đi rồi."},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Mẹ con sẽ tự hào về con lắm."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông Minh chậm rãi đứng dậy, quay về phía bếp. Ông dọn chén đĩa, mỗi động tác đều cẩn thận, như thể đang chuẩn bị cho một điều quan trọng hơn hết thảy."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sân trường rực rỡ ánh đèn và tiếng cười nói. Nhưng trong góc khuất, ông Minh trao cho con gái tô phở, mặt nước trong veo lấp lánh dưới ánh đèn."},{"emotion":"happy","pose":"stand","speaker_id":"mai","text":"Ba, giống hệt như cách mẹ đã làm."},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Món quà của mẹ cho con."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mai húp từng muỗng, mắt rưng rưng. Hai cha con ngồi bên nhau, không cần thêm lời nào để hiểu lòng nhau."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sáng hôm sau, ông Minh đứng một mình trong bếp. Ông đổ nước vào nồi, tiếp tục công việc, từng động tác trở nên quen thuộc hơn. Trên bàn, bức ảnh của bà treo trên tường, nhìn ông với nụ cười dịu dàng. Ông Minh khẽ gật đầu, lòng nhẹ nhõm như vừa hoàn thành một hành trình dài."},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Món phở của chúng ta, vẫn sẽ sống mãi."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"ấm áp","topic":"Món phở gia đình","visuals":[{"character_ids":["ong_minh","mai"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"nha_bep_sang","tier":"medium"},{"character_ids":["ong_minh","mai"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"nha_bep_toi","tier":"medium"},{"character_ids":["ong_minh","mai"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_khach_chieu","tier":"medium"},{"character_ids":["ong_minh","mai"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"san_truong_toi","tier":"medium"}]}