_intent":"push_in","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b8"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh8","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"low","axis":"sc3:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh9","lens":"portrait","motion_intent":"static","scene_id":"sc3","shot_size":"close","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b10"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh10","lens":"normal","motion_intent":"track_right","scene_id":"sc3","shot_size":"medium","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b11"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh11","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b12"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"toward the opposing third","id":"sh12","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"extreme_close","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b13"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh13","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b14"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh14","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh15","lens":"portrait","motion_intent":"static","scene_id":"sc5","shot_size":"close","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh16","lens":"portrait","motion_intent":"track_right","scene_id":"sc5","shot_size":"close","visual_id":"v5"},{"angle":"low","axis":"sc5:primary","beat_ids":["b17"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh17","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A world awaits!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Illuminated by the flickering light of a lone candle, Liora's fingers danced across the map with deliberate grace. Each stroke of her quill whispered secrets onto the parchment, crafting lands unseen by any eye but hers. Here, where imagination met ink, every lie could become a truth, every drawn island a birth."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"happy","pose":"stand","speaker_id":"liora","text":"Another world, another mystery. What shall we call you?"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Her eyes sparkled with mischief as she christened the imaginary isle 'Fallow's Reach.' She felt a familiar surge, a tingling that crept from her fingertips to her heart. But her work was far from over. Liora knew that with each creation, the map's magic would stretch and strain, leaving reality warped and wild."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"In the bustling port, sailors spoke in hushed tones of new islands sprouting like spring daisies. Liora wandered among them, her heart a mix of pride and fear, for every new isle meant unchecked power and consequence."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"old_sailor","text":"Fallow's Reach, they say, wasn't there last week. Magic, no doubt."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"liora","text":"What if the islands are not as they seem? Could they be dangerous?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The sailor's eyes met hers, a knowing glance. Liora's heart raced, the thrill of creation shadowed by the weight of responsibility."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Deep within a forest on one of her islands, Liora stumbled upon something unexpected. A voice, soft and pleading, echoed through the tangled canopy."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"mysterious_voice","text":"Erase me. I am not meant to be."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Liora's breath caught as the trees whispered her name, their leaves rustling like secrets told in the night. This island was alive, aware, and in pain."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Back in her study, Liora struggled against the hum of magic that clung to her quill. She hesitated, the weight of her choice pressing down like a storm."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"her_reflection","text":"Can creation be undone without consequence?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"She drew a single line through Fallow's Reach, watching as the ink bled across the map, erasing an existence she had brought to life."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The harbor was eerily quiet, the rumor of islands fading like the tide. Liora stood on the pier, the map tucked under her arm, lighter yet heavier all at once."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"sad","pose":"stand","speaker_id":"old_sailor","text":"Fallow's Reach is gone. Just a sailor’s tale now."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A lesson learned!","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"liora","text":"Not just a tale. A lesson in the power of creation."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b17","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As the sun dipped below the horizon, Liora realized her work had taken on a life of its own. With every stroke of her quill, she would forever tread the fine line between dream and reality, knowing that even lies can leave a lasting mark."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"mysterious","topic":"The Power of Creation","visuals":[{"character_ids":["liora"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"dusty_cartography_lab","tier":"medium"},{"character_ids":["liora","old_sailor"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"bustling_port","tier":"medium"},{"character_ids":["liora","mysterious_voice"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"darkened_forest","tier":"medium"},{"character_ids":["liora","her_reflection"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"candlelit_study","tier":"medium"},{"character_ids":["liora","old_sailor"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"calm_harbor","tier":"medium"}]}