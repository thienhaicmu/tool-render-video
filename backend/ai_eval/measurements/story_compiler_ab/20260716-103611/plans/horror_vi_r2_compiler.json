wide","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh8","lens":"portrait","motion_intent":"static","scene_id":"sc3","shot_size":"close","visual_id":"v3"},{"angle":"high","axis":"sc3:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh9","lens":"normal","motion_intent":"track_right","scene_id":"sc3","shot_size":"medium","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b10"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"centered","eyeline":"environmental","id":"sh10","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v2"},{"angle":"low","axis":"sc4:primary","beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh11","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"close","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b12"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"symmetrical","eyeline":"environmental","id":"sh12","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b13"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh13","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v1"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b14"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh14","lens":"portrait","motion_intent":"static","scene_id":"sc5","shot_size":"close","visual_id":"v1"},{"angle":"low","axis":"sc5:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh15","lens":"normal","motion_intent":"track_right","scene_id":"sc5","shot_size":"medium","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Cơn ác mộng bắt đầu!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ánh sáng mờ nhạt từ màn hình máy tính nhảy múa trên khuôn mặt của Nam, người bảo vệ ca đêm. Anh ta ngồi không yên, mắt dán vào hình ảnh từ camera an ninh, nơi một bóng hình di chuyển trong hành lang trống rỗng. Đó là chính anh, nhưng cách đó mười phút. Tiếng gió thổi ngoài cửa sổ như tiếng thì thầm ma quái."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"nam","text":"Làm thế nào... điều này có thể?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nam lướt qua từng khung hình, nhưng dù qua bao nhiêu camera, bóng hình đó vẫn dẫn trước. Anh cảm thấy như bị một cơn ác mộng bủa vây, không lối thoát."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nam bước ra hành lang, nơi ánh sáng nhạt nhòa từ đèn hắt xuống sàn. Tiếng bước chân của anh vang vọng, nhưng không có ai khác. Dường như thời gian ở đây đã bị bẻ cong, và không gian chỉ còn là một mê cung không lối thoát."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"nam","text":"Có ai đó không?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Không có câu trả lời, chỉ có tiếng đập nhẹ nhàng của chiếc đồng hồ treo tường. Một cánh cửa phía trước khẽ mở ra, hé lộ bóng tối sâu thẳm bên trong."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nam bước vào phòng lưu trữ, nơi những hộc tủ xếp hàng dài hai bên tường. Một sự lạnh lẽo bất thường xâm chiếm không gian. Anh nhìn thấy chính mình qua màn hình nhỏ của camera, nhưng hình ảnh đó không theo sau anh mà đứng lặng như đang chờ đợi."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"nam","text":"Ngươi là ai?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hình ảnh trên màn hình mỉm cười, một nụ cười lạnh lùng. Nam lùi lại, nhưng cánh cửa sau lưng anh đóng sầm lại, nhốt anh trong bóng tối. Tiếng thở của anh trở nên nặng nề."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nam chạy khỏi phòng, lòng hoảng loạn. Hành lang kéo dài vô tận như giấc mơ không hồi kết. Bóng của anh trên camera vẫn trước mặt, dõi theo từng bước. Nhưng giờ đây, một bóng hình lạ khác xuất hiện phía sau anh."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Bóng hình lạ xuất hiện!","id":"b11","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"nam","text":"Không thể thế được!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng bước chân lớn dần, theo sát phía sau. Nam lao về phía trước, nhưng chân như bị kéo lại, không thể thoát khỏi vòng lặp kỳ dị này."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nam trở lại phòng giám sát, nơi mọi thứ bắt đầu. Nhưng giờ đây, các màn hình tối đen, không còn hình ảnh. Anh đứng giữa căn phòng, cảm nhận sự hiện diện của một điều gì đó không thể giải thích. Không có lối thoát, chỉ còn lại sự im lặng đáng sợ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"nam","text":"Tôi đã ở đây rồi..."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một cơn gió lạnh thổi qua, tắt đi ngọn đèn cuối cùng. Trong bóng tối, Nam nhận ra mình đã trở thành một phần của vòng lặp vô tận."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"horror","topic":"Cơn ác mộng trong bóng tối","visuals":[{"character_ids":["nam"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_giam_sat","tier":"medium"},{"character_ids":["nam"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"},{"character_ids":["nam"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_luu_tru","tier":"medium"}]}