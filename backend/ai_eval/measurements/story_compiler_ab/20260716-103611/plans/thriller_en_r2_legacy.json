rd","camera_position":"front","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh14","lens":"normal","motion_intent":"track_left","scene_id":"sc1","shot_size":"medium","visual_id":"v1"},{"angle":"over_shoulder","axis":"sc1:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh15","lens":"portrait","motion_intent":"static","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"high","axis":"sc1:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"toward the opposing third","id":"sh16","lens":"normal","motion_intent":"track_right","scene_id":"sc1","shot_size":"medium","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A call from the past!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"In the quiet hum of the train dispatch center, Jake stared at the flickering monitors, the weight of years pressing down on him."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"Another day, another shift. Just me and these old machines, I guess."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Suddenly, a shrill alarm pierced the silence, jolting him from his thoughts. It was a distress call, but it was impossible."},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_jake","text":"What the hell? This train was removed from the timetable thirty years ago!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Jake's heart raced as he listened intently, the voice on the other end crackling with fear. It was a ghost from the past, a haunting echo."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"This is Jake! Where are you? What happened?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The voice trembled, \"We’re trapped! The train won’t stop! It’s not supposed to be here!\""},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"Hold on! I’m sending help! Just stay calm!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As Jake scrambled to contact the authorities, a chill crept through the room. He felt a presence, an unseen force lurking."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"This can’t be happening. That train is a myth!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"He frantically typed on the keyboard, trying to pull up historical data. The train had derailed, or so the story went."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"Why now? Why this train?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Suddenly, the lights flickered, and the monitors went dark. Panic surged through Jake as he realized he was alone."},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_jake","text":"No, no! Not now!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"In the darkness, he heard the faint sound of a train whistle echoing through the dispatch center, sending shivers down his spine."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"It can’t be! It’s not real!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Desperately, he grabbed the emergency radio, hoping to reach the outside world. The voice returned, frantic and pleading."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"I’m here! Just hold on!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The voice cried out, \"It’s coming for us! It’s coming for you too!\" The words echoed ominously in the dark room."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"What do you mean? What’s coming?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Jake felt a cold sweat trickle down his back. The train was no longer just a ghost; it was a reality that threatened to consume him."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"I need to find you! Where are you?!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"But the line went dead, leaving Jake in a chilling silence, the weight of the past crashing down on him."},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_jake","text":"No! Don’t leave me!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Suddenly, the lights flickered back on, revealing a shadowy figure standing at the edge of the room, watching him."},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_jake","text":"Who’s there?! Show yourself!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The figure stepped forward, its face obscured, but Jake recognized the uniform. It was the conductor from the ghost train."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"You... you shouldn’t be here!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"\"You have to stop it, Jake! It’s not just a train; it’s a curse!\" The conductor's voice echoed with urgency."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"I’ll do whatever it takes!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"With newfound determination, Jake raced towards the control panel, ready to confront the darkness that had haunted him for decades."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_jake","text":"I won’t let this train take anyone else!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"mysterious","topic":"The Ghost Train","visuals":[{"character_ids":["dispatcher_jake"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"train_dispatch_center","tier":"medium"}]}