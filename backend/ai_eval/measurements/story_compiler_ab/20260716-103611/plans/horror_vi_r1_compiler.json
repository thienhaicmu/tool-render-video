cking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh1","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b2"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh2","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"low","axis":"sc2:primary","beat_ids":["b3"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh3","lens":"normal","motion_intent":"track_right","scene_id":"sc2","shot_size":"medium","visual_id":"v2"},{"angle":"high","axis":"sc3:primary","beat_ids":["b4"],"blocking":"establish participants and geography","camera_position":"profile","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh4","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh5","lens":"portrait","motion_intent":"reveal","scene_id":"sc3","shot_size":"extreme_close","visual_id":"v3"},{"angle":"low","axis":"sc4:primary","beat_ids":["b6"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh6","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b7"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh7","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b8"],"blocking":"establish participants and geography","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh8","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh9","lens":"normal","motion_intent":"track_right","scene_id":"sc5","shot_size":"medium","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc6:primary","beat_ids":["b10"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh10","lens":"wide","motion_intent":"reveal","scene_id":"sc6","shot_size":"wide","visual_id":"v1"},{"angle":"high","axis":"sc6:primary","beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh11","lens":"portrait","motion_intent":"reveal","scene_id":"sc6","shot_size":"close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Cảm giác kỳ lạ","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong phòng tối, những màn hình giám sát chập chờn trước mặt Minh. Anh nhấp cà phê, ánh sáng xanh nhạt nhòa trên khuôn mặt mệt mỏi. Tiếng quạt máy rì rào xung quanh như nhịp đập của thời gian. Minh cúi đầu kiểm tra các camera, đôi mắt đã quen thuộc với những hình ảnh đơn điệu."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh nhìn vào màn hình số bốn. Trong hành lang dài, anh thấy chính mình đang đi tuần tra. Nhưng có gì đó sai. Hình ảnh trên màn hình như một cái bóng của chính anh, di chuyển đều đặn, nhưng lặng lẽ trước thời gian."},{"emotion":"surprised","pose":"stand","speaker_id":"minh","text":"Sao có thể thế này?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Anh kiểm tra đồng hồ. Hình ảnh trên màn hình đi trước anh đúng mười phút. Mồ hôi lạnh toát ra sau lưng Minh. Một tiếng động lạ vang lên từ đâu đó trong tòa nhà, như tiếng bước chân nhẹ nhàng, nhưng không phải của anh."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Quay lại phòng bảo vệ, Minh cố gắng lý giải điều đang xảy ra. Anh tua lại đoạn video. Mỗi lần, bóng dáng anh lại đi trước mười phút. Những ngón tay anh run run khi bấm nút dừng."},{"emotion":"sad","pose":"stand","speaker_id":"minh","text":"Có ai đó trêu đùa mình sao?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chiếc điện thoại của Minh rung lên. Một tin nhắn không số hiện ra: \"Đừng quay lại.\" Tim Minh thắt lại. Anh nhìn quanh phòng, cảm giác bị theo dõi mỗi lúc một lớn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh quyết định đi theo những bước chân của mình trong video. Anh đến nhà kho bỏ hoang, nơi camera đã ghi lại. Mắt anh căng ra tìm kiếm, nhưng chỉ có bóng tối và tĩnh lặng. Đột nhiên, một bóng đen di chuyển nhanh qua góc mắt anh."},{"emotion":"surprised","pose":"stand","speaker_id":"minh","text":"Ai đó?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Không có tiếng trả lời. Chỉ có sự im lặng đáp trả anh, như một bức tường vô hình. Minh bật đèn pin, ánh sáng xoáy vào bóng tối trước mặt, nhưng không thấy gì. Mỗi bước chân của anh vang vọng lại, như đang được ai đó lặng lẽ theo dõi."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh quay về. Cảm giác bất an vẫn không buông tha. Anh dừng lại, nhìn vào chiếc camera cuối cùng trên hành lang. Hình ảnh trên màn hình... không còn chỉ là anh nữa. Một bóng hình khác đứng sau anh, khuôn mặt mờ mịt, nhưng đôi mắt đen sâu thẳm."},{"emotion":"angry","pose":"stand","speaker_id":"minh","text":"Đó là ai?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng động cuối cùng vang lên, như cái gì rơi xuống đất. Căn phòng tối lại, chỉ còn tiếng bước chân xa dần. Minh đứng lặng, môi trường xung quanh chẳng còn gì ngoài bóng tối và im lặng."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Những màn hình giám sát trở lại bình thường. Minh ngồi đó, ánh mắt mờ mịt. Anh không biết mình đã thoát khỏi điều gì, hay điều gì vẫn đang theo dõi mình. Chỉ có bóng tối là chắc chắn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bên ngoài, đêm vẫn tiếp tục trôi, không một dấu hiệu của ngày mai."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"horror","topic":"Bóng Đêm Trong Phòng Giám Sát","visuals":[{"character_ids":["minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_giam_sat","tier":"medium"},{"character_ids":["minh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"hanh_lang_dai","tier":"medium"},{"character_ids":["minh"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_bao_ve","tier":"medium"},{"character_ids":["minh"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"nha_kho_bo_hang","tier":"medium"}]}