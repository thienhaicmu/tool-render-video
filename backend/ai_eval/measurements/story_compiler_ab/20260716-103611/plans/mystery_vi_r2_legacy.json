 đã từng rất yêu thích những chiếc đồng hồ này."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Khi lục tìm, Thanh tìm thấy một chiếc đồng hồ lớn, giống hệt chiếc trong bức vẽ."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Có lẽ chiếc đồng hồ này chứa đựng một ký ức quan trọng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Khi mở chiếc đồng hồ, một luồng ánh sáng mạnh phát ra, khiến Thanh choáng váng."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Cái gì đang xảy ra?"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thanh thấy mình đứng trong một công viên, nơi em trai đã từng chơi."},{"emotion":"sad","pose":"stand","speaker_id":"thanh","text":"Tôi nhớ nơi này, em trai tôi đã từng rất thích đến đây."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"happy","pose":"wave","speaker_id":"","text":"Trong giấc mơ, Thanh thấy em trai mình đang cười và vẫy tay."},{"emotion":"surprised","pose":"stand","speaker_id":"thanh","text":"Em trai! Em đang ở đâu?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Giọng nói của em trai vang lên trong gió: \"Anh hãy tìm tôi ở nơi mà thời gian dừng lại.\""},{"emotion":"surprised","pose":"stand","speaker_id":"thanh","text":"Nơi nào? Tôi không hiểu!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Khi tỉnh dậy, Thanh thấy mình ở quán cà phê, nơi anh thường gặp em trai."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Có lẽ tôi cần quay lại đây để tìm manh mối tiếp theo."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tại quán cà phê, Thanh gặp một người đàn ông lạ, người có vẻ biết về em trai anh."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Ông có biết em trai tôi không?"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"point","speaker_id":"","text":"Người đàn ông chỉ vào một chiếc đồng hồ trên tường, nói: \"Chiếc đồng hồ này có thể giúp bạn.\""},{"emotion":"surprised","pose":"stand","speaker_id":"thanh","text":"Làm thế nào? Nó có gì đặc biệt?"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"\"Nó giữ lại những ký ức của những người đã mất,\" người đàn ông giải thích."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi cần nó!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thanh quyết định mua chiếc đồng hồ, hy vọng nó sẽ dẫn anh đến em trai."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi sẽ không từ bỏ!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Khi rời quán, Thanh cảm thấy một sức mạnh mới mẻ tràn đầy trong lòng."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi sẽ tìm thấy em trai tôi!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b17","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Về đến nhà, Thanh mở chiếc đồng hồ mới, ánh sáng lại phát ra."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Hãy cho tôi biết em trai tôi đang ở đâu!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b18","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một hình ảnh mờ ảo hiện lên, cho thấy em trai đang đứng bên một chiếc đồng hồ lớn."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi sẽ đến đó ngay!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b19","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thanh cảm thấy trái tim mình đập mạnh, anh biết mình sắp tìm thấy em trai."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi sẽ không bao giờ từ bỏ hy vọng!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh19","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b20","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuối cùng, Thanh đã tìm thấy manh mối quan trọng nhất trong cuộc đời mình."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi sẽ tìm thấy em trai, dù có phải đi đến đâu!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh20","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b21","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Với quyết tâm trong lòng, Thanh bước ra khỏi nhà, sẵn sàng cho cuộc hành trình mới."},{"emotion":"normal","pose":"stand","speaker_id":"thanh","text":"Tôi sẽ không bao giờ từ bỏ!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh21","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b22","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Và như vậy, hành trình tìm kiếm em trai bắt đầu, đầy hy vọng và quyết tâm."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ký ức trong đồng hồ sẽ dẫn lối cho tôi!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh22","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"}],"tone":"mysterious","topic":"Ký ức trong đồng hồ","visuals":[{"character_ids":["thanh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"xưởng","tier":"medium"},{"character_ids":["thanh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"căn_nhà","tier":"medium"},{"character_ids":["thanh"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"công_viên","tier":"medium"},{"character_ids":["thanh"],"id":"v4","negative_prompt":"","prom