xtreme_close","visual_id":"v3"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nguyễn Văn, một người cha ít nói, ngồi trong phòng khách, nhìn vào bức tranh gia đình. Ánh mắt ông đầy nỗi nhớ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Con gái ông, Nguyễn Hạnh, sắp tốt nghiệp. Ông hứa sẽ nấu món phở mà vợ ông thường làm trong ngày đặc biệt này."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nguyễn Văn bước vào bếp, nhìn thấy các nguyên liệu. Ông cảm thấy hồi hộp, nhưng cũng đầy quyết tâm."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông bắt đầu nấu nước dùng, nhớ lại những ngày vợ ông đứng bên cạnh, cùng nhau chuẩn bị món phở."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mùi hương phở bắt đầu lan tỏa trong bếp. Ông cảm thấy như vợ mình đang ở bên cạnh, động viên ông."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nguyễn Văn cắt rau thơm, nhớ lại những kỷ niệm đẹp bên vợ. Ông tự nhủ phải làm thật tốt cho con gái."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Món phở quyết định!","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thời gian trôi qua, ông lo lắng không biết món phở có ngon như vợ đã từng nấu không."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuối cùng, món phở cũng hoàn thành. Ông nhìn vào nồi phở, lòng đầy hy vọng nhưng cũng không tránh khỏi lo lắng."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày tốt nghiệp đến, Nguyễn Hạnh đứng trên sân khấu, ánh mắt rạng rỡ. Ông Nguyễn Văn đứng dưới, lòng đầy tự hào."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"happy","pose":"stand","speaker_id":"nguyen_hanh","text":"Con cảm ơn ba đã luôn bên con! Hôm nay con tốt nghiệp, con rất vui!"},{"emotion":"happy","pose":"stand","speaker_id":"nguyen_van","text":"Ba luôn tự hào về con. Hãy nhớ rằng ba sẽ luôn ủng hộ con."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Sau buổi lễ, Nguyễn Hạnh trở về nhà, mùi phở thơm ngào ngạt. Cô cảm thấy hồi hộp và vui mừng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Nguyễn Văn bưng tô phở ra, ánh mắt ông lấp lánh. Ông không biết con gái sẽ phản ứng thế nào."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"happy","pose":"stand","speaker_id":"nguyen_hanh","text":"Ba ơi, phở này là của ba nấu sao? Ngon quá!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"happy","pose":"stand","speaker_id":"nguyen_van","text":"Ba đã cố gắng hết sức, hy vọng con thích!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Nguyễn Văn nhìn con gái ăn phở, lòng ông tràn đầy hạnh phúc. Ông biết rằng mình đã giữ lời hứa với vợ."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Họ cùng nhau thưởng thức món phở, kỷ niệm một ngày đặc biệt. Tình yêu gia đình mãi mãi không phai nhạt."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"}],"tone":"cảm động","topic":"Người cha nấu phở cho con gái tốt nghiệp","visuals":[{"character_ids":["nguyen_van"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"living_room","tier":"medium"},{"character_ids":["nguyen_van"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"kitchen","tier":"medium"},{"character_ids":["nguyen_hanh","nguyen_van"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"graduation_ceremony","tier":"medium"}]}