eveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh6","lens":"normal","motion_intent":"track_left","scene_id":"sc5","shot_size":"medium","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Ngày đặc biệt","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mùi thơm của hành phi và nước dùng thoảng qua nhà bếp nhỏ. Trên bàn, công thức món phở viết tay của vợ được đặt cẩn thận bên cạnh một nồi nước sôi sùng sục. Ông Minh chăm chú khuấy đều nồi nước dùng, đôi mắt đăm chiêu như đang nói chuyện với quá khứ."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Ngày mai là ngày đặc biệt, con bé sẽ vui lắm."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ánh đèn vàng rực rỡ làm nổi bật tấm ảnh gia đình treo trên tường. Ông Minh ngồi trầm ngâm trên ghế sofa, tay lật qua từng trang album ảnh. Giọng ông khẽ thì thầm như đang chia sẻ với vợ."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Ngọc Lan đã trưởng thành rồi. Em chắc sẽ tự hào về con bé."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trống trường ngân vang, học sinh tỏa ra như bầy chim. Ngọc Lan cầm bằng tốt nghiệp trên tay, nụ cười rạng rỡ nhưng mắt thoáng chút ưu tư. Cô tìm kiếm một hình bóng quen thuộc giữa đám đông."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc_lan","text":"Bố, bố có thấy không? Con đã làm được!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Căn bếp ấm áp, tiếng nước sôi, mùi thơm của phở lan tỏa. Ông Minh cẩn thận bày biện bàn ăn, nhớ lại những lần vợ nấu món này. Ông dừng lại, lặng lẽ nhìn bát phở trước mặt."},{"emotion":"surprised","pose":"stand","speaker_id":"ngoc_lan","text":"Bố... Bố đã làm phở?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Bố giữ lời hứa với mẹ con."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngọc Lan ngồi bên cạnh bố, cảm xúc trào dâng. Cô nhấp một thìa phở, hương vị quen thuộc khiến cô nhớ về những bữa ăn gia đình đầm ấm ngày xưa. Một giọt nước mắt lăn trên má cô, hòa tan mọi khoảng cách với bố."},{"emotion":"happy","pose":"stand","speaker_id":"ngoc_lan","text":"Cảm ơn bố. Con thấy mẹ đang mỉm cười."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Chúng ta luôn bên nhau, dù có chuyện gì đi nữa."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bữa ăn kết thúc trong tĩnh lặng ấm áp. Phía ngoài cửa sổ, ánh trăng sáng soi rọi cả hai, như một lời hứa mãi mãi chẳng phai nhạt."}],"motion":"pan_left","narration":"","pause_after":1.6,"pose":"stand","reading_speed":0.88,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"ấm áp","topic":"Một bữa ăn gia đình","visuals":[{"character_ids":["minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"nha_bep_sang","tier":"medium"},{"character_ids":["minh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_khach_toi","tier":"medium"},{"character_ids":["ngoc_lan"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"truong_hoc_chieu","tier":"medium"},{"character_ids":["minh"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"nha_bep_toi","tier":"medium"},{"character_ids":["minh","ngoc_lan"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"ban_an_gia_dinh","tier":"medium"}]}