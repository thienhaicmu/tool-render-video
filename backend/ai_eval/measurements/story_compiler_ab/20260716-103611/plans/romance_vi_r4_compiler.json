,"beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"toward the opposing third","id":"sh11","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b12"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"environmental","id":"sh12","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b13"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh13","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b14"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh14","lens":"normal","motion_intent":"track_right","scene_id":"sc5","shot_size":"medium","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh15","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"","id":"b1","lines":[],"motion":"pan_up","narration":"Ngoài trời mưa rơi nặng hạt, gió rít qua từng khe cửa sổ. Ánh đèn neon nhấp nháy trên trần nhà, chiếu sáng khuôn mặt căng thẳng của Mai và An. Cả hai đã từng yêu nhau, nhưng giờ đây, chỉ có sự im lặng giữa họ.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"An, em nghĩ mình cần chuẩn bị cho tình huống khẩn cấp tối nay."},{"emotion":"normal","pose":"stand","speaker_id":"an","text":"Đúng, anh cũng nghĩ vậy."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[],"motion":"zoom_out","narration":"Những từ ngữ ngắn gọn, hờ hững trôi qua. Mối quan hệ của họ đã từng ấm áp, nhưng giờ đây trở nên xa lạ.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[],"motion":"pan_up","narration":"Đồng hồ tích tắc từng giây. Một cuộc gọi khẩn cấp vang lên phá tan bầu không khí cứng nhắc. Một đứa trẻ bị tai nạn giao thông đang được chuyển đến.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Chúng ta phải chuẩn bị phòng mổ ngay."},{"emotion":"normal","pose":"stand","speaker_id":"an","text":"Được, anh sẽ đi gọi đội ngũ hỗ trợ."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[],"motion":"pan_left","narration":"Cả hai cùng lao vào công việc, kỹ năng và kinh nghiệm giúp họ làm việc nhịp nhàng. Không còn là những người yêu cũ, lúc này họ chỉ là hai bác sĩ với chung một mục tiêu.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[],"motion":"pan_up","narration":"Đèn mổ sáng rực, tiếng máy móc kêu đều đều. An và Mai cẩn thận từng bước, trao đổi ngắn gọn nhưng hiệu quả. Đứa trẻ nằm bất động, sự sống treo trên sợi chỉ mỏng manh.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"an","text":"Mai, cần phải giữ bình tĩnh."},{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Em biết. Chúng ta sẽ cứu được bé."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[],"motion":"zoom_out","narration":"Những giọt mồ hôi rơi xuống, trái tim của cả hai đập mạnh, hòa nhịp với sự sống đang được giành giật.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[],"motion":"pan_up","narration":"Tiếng mưa ngoài kia vẫn dội vào tường bệnh viện. Cuộc phẫu thuật kết thúc thành công, đứa trẻ đã an toàn. Mai và An nhìn nhau, không còn sự căng thẳng.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Chúng ta đã làm được."},{"emotion":"normal","pose":"stand","speaker_id":"an","text":"Ừ, em giỏi lắm."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[],"motion":"pan_left","narration":"Một khoảnh khắc yên bình giữa tiếng mưa, ánh mắt họ gặp nhau, hồi tưởng lại những ngày tháng đã qua.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[],"motion":"pan_up","narration":"Trời đã ngớt mưa, gió nhẹ thổi qua làm khô những lối đi ướt át. An và Mai đứng dưới mái hiên, nhìn vào khoảng không xa xăm.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"an","text":"Mai, anh xin lỗi vì những hiểu lầm trước đây."},{"emotion":"normal","pose":"stand","speaker_id":"mai","text":"Em cũng vậy, An. Có lẽ chúng ta cần nói chuyện nhiều hơn."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[],"motion":"zoom_out","narration":"Sự hòa giải lặng lẽ như dòng nước mưa vừa tạnh, mang theo hẹn ước về một hội ngộ mới, không phải trong phòng trực, mà trong cuộc sống thường nhật.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"","topic":"","visuals":[{"character_ids":[],"id":"v1","negative_prompt":"","prompt":"","setting_id":"benh_vien","tier":"medium"},{"character_ids":[],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_truc","tier":"medium"},{"character_ids":[],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_mo","tier":"medium"},{"character_ids":[],"id":"v4","negative_prompt":"","prompt":"","setting_id":"hanh_lang_benh_vien","tier":"medium"},{"character_ids":[],"id":"v5","negative_prompt":"","prompt":"","setting_id":"san_benh_vien","tier":"medium"}]}