k_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b14"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh14","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"high","axis":"sc5:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh15","lens":"normal","motion_intent":"track_right","scene_id":"sc5","shot_size":"medium","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"environmental","id":"sh16","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"","id":"b1","lines":[],"motion":"pan_up","narration":"Bên trong cửa hàng đồng hồ cũ kỹ, ánh nắng chiếu rọi qua ô cửa kính, tạo thành những vệt sáng dài trên sàn gỗ. Ngày nào Nguyễn cũng cần mẫn với những chiếc đồng hồ hỏng, nhưng hôm nay có điều gì đó khác lạ.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Sao trong chiếc đồng hồ này lại có hình ảnh của một đứa trẻ?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[],"motion":"pan_right","narration":"Giữa những bánh răng và dây cót, Nguyễn nhìn thấy một mảnh ký ức mờ ảo - hình một cậu bé đứng dưới cây liễu. Anh chưa bao giờ thấy điều tương tự. Tim anh đập nhanh hơn, cảm giác như đã tìm thấy điều gì quan trọng.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[],"motion":"pan_up","narration":"Buổi chiều, Nguyễn ngồi trong quán cà phê, trước mặt là một quyển sổ tay. Anh ghi chép cẩn thận từng chi tiết về mảnh ký ức trong chiếc đồng hồ.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Mình phải tìm cách giải mã những ký ức này."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[],"motion":"zoom_in","narration":"Bên cạnh tiếng ồn ào của quán, Nguyễn tập trung suy nghĩ về em trai mình, người đã mất tích cách đây năm năm. Anh tự hỏi liệu có liên quan gì không.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[],"motion":"pan_up","narration":"Nguyễn tiếp tục công việc, mỗi chiếc đồng hồ hỏng đều chứa đựng một phần ký ức của chủ nhân. Những mảnh ghép bắt đầu hiện lên rõ nét hơn.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Phải có cách nào đó để ghép các mảnh lại với nhau."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[],"motion":"pan_right","narration":"Những hình ảnh về một con đường quê, một cây cầu gỗ, và cuối cùng là khuôn mặt quen thuộc của em trai anh. Những ký ức đan xen, tạo nên bức tranh hoàn chỉnh.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[],"motion":"pan_up","narration":"Nguyễn theo manh mối đến một nhà kho bỏ hoang, nơi những ký ức chỉ dẫn. Trời tối, anh cẩn thận bước vào, ánh đèn pin le lói trong bóng tối.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Có ai ở đây không?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[],"motion":"zoom_in","narration":"Tiếng động nhỏ vang lên từ góc phòng. Trái tim Nguyễn đập thình thịch. Anh tiến lại gần và thấy em trai mình, mảnh khảnh và tiều tụy.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Anh... đến đây vì em sao?"},{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Phải, anh đã tìm thấy em."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[],"motion":"pan_up","narration":"Cửa hàng đồng hồ giờ sáng đèn, hai anh em làm việc cùng nhau, sửa chữa từng chiếc đồng hồ yêu thích. Cả hai đều hiểu rằng ký ức luôn ở đó, chỉ cần biết cách tìm ra.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Cảm ơn anh, nhờ anh mà em đã được trở về."},{"emotion":"normal","pose":"stand","speaker_id":"nguyen","text":"Chỉ cần em ở đây, mọi thứ đều xứng đáng."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[],"motion":"zoom_out","narration":"Thời gian đôi khi giấu đi những điều quan trọng, nhưng cũng là chìa khóa mang mọi thứ trở về đúng chỗ của nó.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"","topic":"","visuals":[{"character_ids":[],"id":"v1","negative_prompt":"","prompt":"","setting_id":"cua_hang_ong_ho","tier":"medium"},{"character_ids":[],"id":"v2","negative_prompt":"","prompt":"","setting_id":"quan_ca_phe_nho","tier":"medium"},{"character_ids":[],"id":"v3","negative_prompt":"","prompt":"","setting_id":"cua_hang_ong_ho_vai_ngay_sau","tier":"medium"},{"character_ids":[],"id":"v4","negative_prompt":"","prompt":"","setting_id":"nha_kho_bo_hoang","tier":"medium"},{"character_ids":[],"id":"v5","negative_prompt":"","prompt":"","setting_id":"cua_hang_ong_ho_mot_thang_sau","tier":"medium"}]}