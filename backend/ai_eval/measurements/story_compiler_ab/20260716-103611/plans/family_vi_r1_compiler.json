[{"angle":"eye_level","axis":"sc1:primary","beat_ids":["b1"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh1","lens":"wide","motion_intent":"reveal","scene_id":"sc1","shot_size":"wide","visual_id":"v1"},{"angle":"over_shoulder","axis":"sc2:primary","beat_ids":["b2"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh2","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh3","lens":"portrait","motion_intent":"reveal","scene_id":"sc3","shot_size":"close","visual_id":"v3"},{"angle":"low","axis":"sc4:primary","beat_ids":["b4"],"blocking":"establish participants and geography","camera_position":"profile","composition":"negative_space","eyeline":"toward the opposing third","id":"sh4","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"close","visual_id":"v4"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng dao va vào thớt vang lên trong căn bếp yên tĩnh. Ông Minh, người cha ít nói, đứng bên bếp với cuốn sổ tay cũ kỹ đặt trước mặt. Món phở của bà Lan - vợ ông đã mất, là một tâm điểm trong gia đình. Hôm nay, ông đang cố gắng thực hiện điều bà đã làm hàng trăm lần."},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Nước dùng phải trong... và thịt bò phải mềm."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông mở nắp nồi, hơi nước bốc lên nghi ngút, mang theo hương thơm của hồi và quế. Nhưng đó không chỉ là mùi, mà là ký ức của từng bữa cơm gia đình."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Linh bước vào phòng khách, đôi mắt sáng lên khi thấy cha mình đang bận rộn trong bếp. Cô nhớ như in lời hứa của cha trong ngày giỗ của mẹ, rằng ông sẽ nấu món phở cho buổi lễ tốt nghiệp của cô."},{"emotion":"happy","pose":"stand","speaker_id":"linh","text":"Ba, hôm nay ba nấu phở hả?"},{"emotion":"normal","pose":"stand","speaker_id":"ong_minh","text":"Ừ, ba đang cố gắng làm theo công thức của mẹ."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Linh nhìn cha, sự kiên trì của ông làm cô cảm thấy ấm áp. Nhưng trong lòng cô, có chút lo lắng không biết kết quả ra sao."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Thử món phở!","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày lễ tốt nghiệp, Linh trong chiếc áo choàng xanh, ngồi quanh bàn ăn cùng với bạn bè và người thân. Mọi người xôn xao, nhưng Linh chỉ chăm chú nhìn vào bát phở trước mặt. Bàn tay cô run nhẹ, nắm chặt đôi đũa."},{"emotion":"normal","pose":"stand","speaker_id":"linh","text":"Ba, để con thử trước nhé."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cô múc một thìa nước dùng, đưa lên miệng. Vị ngọt ngào đậm đà cùng hương thơm quen thuộc khiến cô ngưng lại một khoảnh khắc."},{"emotion":"surprised","pose":"stand","speaker_id":"linh","text":"Giống phở của mẹ quá!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông Minh mỉm cười, ánh mắt dịu dàng nhìn con gái. Người cha ít nói đã thực hiện lời hứa, mang lại món ăn đầy kỷ niệm cho con vào ngày đặc biệt này."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trời bắt đầu tối, ánh đèn từ trong nhà hắt ra sân trước. Linh và ông Minh cùng đứng bên nhau, gió nhẹ nhàng thổi qua."},{"emotion":"happy","pose":"stand","speaker_id":"linh","text":"Cảm ơn ba, vì đã nấu món phở này."},{"emotion":"sad","pose":"stand","speaker_id":"ong_minh","text":"Ba chỉ muốn mẹ con ở đây cùng chúng ta."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Linh cầm tay cha, cả hai đứng lặng im, nhưng không cần nói thêm gì nữa. Món phở không chỉ là hương vị, mà là sự kết nối vô hình giữa quá khứ và hiện tại, là tình yêu gia đình mãi mãi đọng lại."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"}],"tone":"nostalgic","topic":"Ký ức gia đình qua món phở","visuals":[{"character_ids":["ong_minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"nha_bep","tier":"medium"},{"character_ids":["linh","ong_minh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_khach","tier":"medium"},{"character_ids":["linh"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_an","tier":"medium"},{"character_ids":["linh","ong_minh"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"ngoai_san","tier":"medium"}]}