osition":"leading_lines","eyeline":"environmental","id":"sh2","lens":"normal","motion_intent":"track_right","scene_id":"sc1","shot_size":"medium","visual_id":"v1"},{"angle":"high","axis":"sc2:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"environmental","id":"sh4","lens":"portrait","motion_intent":"reveal","scene_id":"sc2","shot_size":"extreme_close","visual_id":"v2"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b5"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"push_in","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"low","axis":"sc2:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh6","lens":"normal","motion_intent":"track_left","scene_id":"sc2","shot_size":"medium","visual_id":"v2"},{"angle":"high","axis":"sc3:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"centered","eyeline":"toward the opposing third","id":"sh8","lens":"normal","motion_intent":"track_right","scene_id":"sc3","shot_size":"medium","visual_id":"v3"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh9","lens":"wide","motion_intent":"pull_out","scene_id":"sc3","shot_size":"wide","visual_id":"v3"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Bữa ăn gia đình","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ánh nắng chiếu qua cửa sổ, phản chiếu trên mặt bàn bếp đầy nguyên liệu. Tiếng dao băm băm vang lên trong không gian yên tĩnh. Ông Minh, người cha trầm lặng, đang tập trung cắt thịt bò."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Được rồi, mình phải làm như cô ấy đã làm thôi..."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông Minh nhìn lên bức ảnh cũ treo trên tường. Đó là vợ ông, Lan, với nụ cười rạng rỡ. Hứa với con gái sẽ nấu món phở trong ngày tốt nghiệp, ông quyết tâm làm theo cách Lan từng chỉ dẫn."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Từng giọt mồ hôi lăn dài trên trán Minh khi ông chăm chú đọc cuốn sổ tay của vợ. Mùi thơm của nước dùng bắt đầu lan tỏa khắp căn nhà."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Làm sao em có thể nấu ngon như vậy nhỉ?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông lật từng trang cẩn thận, tìm lại ký ức về những lần Lan đứng bên bếp kể chuyện cuộc sống. Quyết tâm trong ông càng lớn khi nghe tiếng bước chân con gái từ ngoài vào."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thảo, con gái, vừa về từ trường, ánh mắt lộ rõ vẻ mong đợi. Cô nhìn cha đang cặm cụi trong bếp, lòng dâng lên một niềm cảm động khó tả."},{"emotion":"surprised","pose":"stand","speaker_id":"thao","text":"Ba, ba đang làm gì vậy?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Ba hứa sẽ nấu phở cho con mà."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thảo bước vào bếp, nhìn ông Minh với ánh mắt tràn đầy sự kinh ngạc và cảm phục. Cô nhớ lại mẹ mình từng nói rằng cha rất ít nói, nhưng mỗi hành động của ông đều thấm đẫm tình yêu."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bàn ăn được chuẩn bị gọn gàng. Minh cẩn thận rót nước dùng vào từng tô, khói bốc lên nghi ngút. Thảo ngồi xuống, mắt lấp lánh niềm vui."},{"emotion":"happy","pose":"stand","speaker_id":"thao","text":"Món phở này, như mẹ nấu vậy."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ông Minh mỉm cười, trong lòng nhẹ nhõm khi thấy con gái hạnh phúc. Ông đã giữ được lời hứa với Lan, và với chính mình, rằng tình yêu đôi khi không cần lời nói."},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Cảm ơn con, Thảo."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Dưới ánh đèn vàng ấm áp, bữa ăn gia đình đong đầy tình yêu thương, như thể Lan vẫn đang ở đây, ngồi cùng họ."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"}],"tone":"ấm áp","topic":"Bữa ăn gia đình","visuals":[{"character_ids":["minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"kitchen","tier":"medium"},{"character_ids":["minh","thao"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"living_room","tier":"medium"},{"character_ids":["minh","thao"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"dining_room","tier":"medium"}]}