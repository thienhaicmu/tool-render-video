"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh6","lens":"normal","motion_intent":"track_left","scene_id":"sc2","shot_size":"medium","visual_id":"v2"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b7"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh7","lens":"portrait","motion_intent":"static","scene_id":"sc2","shot_size":"close","visual_id":"v2"},{"angle":"low","axis":"sc3:primary","beat_ids":["b8"],"blocking":"establish participants and geography","camera_position":"profile","composition":"symmetrical","eyeline":"environmental","id":"sh8","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v1"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh9","lens":"wide","motion_intent":"pull_out","scene_id":"sc3","shot_size":"wide","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A dark secret revealed","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The lighthouse had stood dark against the horizon for forty years when Elias took the keeper's job."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"The villagers called it cursed; he whispered it was merely quiet."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"On his first night, lantern swaying as he ascended the spiral stairs, Elias discovered an old logbook, its cover worn by salt air."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"The name inside was Mara, the previous keeper. Its final entry had been ripped away."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Night after night, Elias nurtured the lamp back to life, its beam cutting through the black sea."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Yet, precisely at 3:07, the light would flicker, a spectral breath dimming its glow."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"It was as if something unseen brushed between the lamp and the endless waves."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"And then, in the nocturnal winds, he heard it — a woman's voice, calling a name lost to time."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The storm hammered against the lighthouse, waves hurling themselves at its base."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"A ship's horn wailed from the fog, a sound of distress swallowed by the tempest."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Heart pounding, Elias dashed to the lamp, but it dimmed to nothing, plunging the room into darkness."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"In the gloom, she appeared — Mara, her form pale and translucent, framed against the glass."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"She had drowned on such a night, forty years past, unable to ignite the lamp and save the souls at sea."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Her spirit lingered, bound by her unfinished task."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A ghostly reunion","id":"b5","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"elias","text":"Mara... you stayed."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Resolute, Elias reached for her hand, feeling its chill as if through a veil."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Together, they turned the great lens, straining against time itself, coaxing life back into the wick."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The beam surged to life, slicing through the storm."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Across the water, the ship's horn cried out again, this time grateful, alive."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"It steered clear of the rocks, the danger past."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As dawn painted the sky in pastel hues, the lamp remained aglow, steadfast in its duty."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mara was gone, her vigil finally at an end."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"elias","text":"Elias sat on the gallery, the sea before him a tranquil silver."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"For the first time, the lighthouse felt not like a relic of sorrow, but a beacon of hope, finally set free."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"mysterious","topic":"The lighthouse keeper and the ghost","visuals":[{"character_ids":["elias"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"lighthouse","tier":"medium"},{"character_ids":["elias","mara"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"lighthouse","tier":"medium"}]}