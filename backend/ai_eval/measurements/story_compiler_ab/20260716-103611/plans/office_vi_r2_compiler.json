d the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"high","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh6","lens":"wide","motion_intent":"pull_out","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"centered","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"environmental","id":"sh8","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh9","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b10"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh10","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh11","lens":"portrait","motion_intent":"track_right","scene_id":"sc5","shot_size":"close","visual_id":"v2"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Quyết định quan trọng","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ánh sáng ban mai len lỏi qua cửa sổ, chiếu vào bàn làm việc của Minh. Những tờ giấy tán loạn, chứng từ chưa xử lý xong chất đống. Minh cầm tách cà phê, nhìn vào màn hình máy tính, tâm trí rối bời với quyết định nghỉ việc."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"minh","text":"Sao báo cáo này lại chính xác thế này?"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cô nhớ rõ đã sơ suất trong một số hạng mục nhưng giờ đây mọi thứ đều hoàn hảo. Minh mở từng file, từng email cũ để tìm hiểu."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh lén nhìn quanh, ánh mắt dừng lại ở bàn của Hùng, người luôn giữ thái độ điềm đạm. Cô tiến lại gần, lòng đầy nghi hoặc."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Hùng, có phải cậu đã sửa lại báo cáo của mình không?"},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Ừ, chỉ là vài lỗi nhỏ thôi mà, không vấn đề gì đâu."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh đứng lặng, ngạc nhiên lẫn biết ơn. Nhưng một câu hỏi khác hiện lên trong đầu cô. Tại sao anh không bao giờ nói ra?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng rì rầm trong văn phòng bỗng dưng lớn hơn khi Minh bước vào hành lang. Cô thấy mọi người bàn tán về một lỗi lớn trong dự án mà Hùng đang phụ trách."},{"emotion":"normal","pose":"stand","speaker_id":"dong_nghiep","text":"Hùng có thể gặp rắc rối lớn với lỗi này."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh biết rõ Hùng không thể mắc sai lầm như vậy. Một cảm giác lo lắng dâng lên trong cô. Liệu đó có phải là lỗi của cô?"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong căn phòng họp trầm tư, Hùng ngồi trước mặt quản lý. Minh đứng ngoài cửa, nghe từng lời buộc tội. Cô không thể để Hùng chịu trách nhiệm cho lỗi lầm của mình."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Đó là lỗi của tôi. Chính tôi đã làm sai, không phải Hùng."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Mọi ánh mắt đổ dồn về phía Minh. Sự im lặng bao trùm cả phòng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Cô chắc chứ, Minh?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Vâng, tôi đã nhầm lẫn trong dữ liệu. Hùng chỉ cố giúp tôi."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sau cuộc họp, Minh quay lại bàn làm việc của mình. Cô cảm thấy nhẹ nhõm, nhưng cũng đầy hối hận. Hùng bước vào phòng, trao cho Minh nụ cười đồng cảm."},{"emotion":"happy","pose":"stand","speaker_id":"hung","text":"Không sao đâu. Chúng ta luôn có thể làm tốt hơn mà."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Minh mỉm cười. Lòng cô đầy quyết tâm để không lặp lại sai lầm trong tương lai. Dù sẽ rời khỏi công ty, cô đã học được một bài học quý giá về trách nhiệm và tình đồng nghiệp."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"}],"tone":"tâm trạng","topic":"Quyết định nghỉ việc","visuals":[{"character_ids":["minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"van_phong_sang","tier":"medium"},{"character_ids":["minh","hung"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_lam_viec","tier":"medium"},{"character_ids":["minh","dong_nghiep"],"id":"v3","negative_prompt":"","prompt":