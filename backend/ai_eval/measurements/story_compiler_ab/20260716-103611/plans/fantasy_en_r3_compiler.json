_space","eyeline":"environmental","id":"sh18","lens":"portrait","motion_intent":"reveal","scene_id":"sc4","shot_size":"extreme_close","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b19"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh19","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b20"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh20","lens":"normal","motion_intent":"track_left","scene_id":"sc5","shot_size":"medium","visual_id":"v5"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b21"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh21","lens":"portrait","motion_intent":"static","scene_id":"sc5","shot_size":"close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"","id":"b1","lines":[],"motion":"pan_up","narration":"In a cluttered studio, maps covered every wall, each a testament to Odara's craft. The scent of ink mixed with the musty aroma of old parchment. Her quill danced across the page, sketching coastlines that never existed, yet each stroke birthed new land.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"odara","text":"Just a line here... and there, and voilà."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[],"motion":"static","narration":"Magic hummed under her fingertips. She paused, hearing whispers of waves crashing against unseen shores. Every lie she drew became truth.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[],"motion":"pan_up","narration":"Odara stood at the edge of a newly born island, the air salty and thick with mystery. Palm trees swayed, their leaves whispering secrets. The island shimmered with an otherworldly glow, proof of her power.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"happy","pose":"stand","speaker_id":"odara","text":"Another masterpiece."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[],"motion":"pan_up","narration":"But as she marveled, a figure emerged from the jungle—a being of sand and sea.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"isla","text":"Why have you created me?"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[],"motion":"pan_left","narration":"Isla, the island's soul, radiated curiosity and confusion. Her eyes, deep as the ocean, searched Odara's face for answers.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"odara","text":"I suppose... because I can."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[],"motion":"pan_up","narration":"Days passed, and Odara returned to Isla's shores, her sketchbook in hand. The night sky mirrored the deep ocean below, a canvas of infinite possibilities. Yet her hand hesitated.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"isla","text":"There's something you must see."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[],"motion":"pan_up","narration":"Isla led Odara to a hidden cove, where the stars were reflected perfectly in the calm waters. A place of pure, untouched beauty.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"odara","text":"It's... incredible."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[],"motion":"pan_left","narration":"But Isla's gaze grew solemn, the ocean breeze carrying a plea.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"isla","text":"Erase me, Odara. I am a dream that never should have been."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[],"motion":"pan_up","narration":"Back in her studio, Odara's heart weighed heavy with Isla's request. The quill in her hand felt foreign, like a betrayer's weapon. She dipped it in ink, hesitating over a fresh map.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b17","lines":[{"emotion":"normal","pose":"stand","speaker_id":"odara","text":"If that's what you truly wish."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b18","lines":[],"motion":"pan_up","narration":"Her hand moved with purpose, each line dissolving the island's existence like mist in morning light. The map faded, and with it, Isla's whispered presence.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b19","lines":[],"motion":"pan_up","narration":"As dawn broke, Odara set down her quill, the studio awash in golden light. She felt the weight lift, leaving a tender ache—a memory of a creation both wondrous and fragile.","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh19","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b20","lines":[{"emotion":"normal","pose":"stand","speaker_id":"odara","text":"Perhaps some dreams are meant to remain dreams."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh20","source_audio":"mute