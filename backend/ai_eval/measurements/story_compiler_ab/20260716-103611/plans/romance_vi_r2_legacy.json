te","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Lan, em có thể giúp tôi kiểm tra lại hồ sơ bệnh nhân không?"},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Được, nhưng chúng ta cần phải nhanh chóng, có vẻ như đêm nay sẽ rất bận rộn."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Khi cơn bão bắt đầu ập đến, tiếng sấm vang rền, không khí trong bệnh viện trở nên căng thẳng hơn bao giờ hết."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Chúng ta cần chuẩn bị cho trường hợp khẩn cấp. Có thể sẽ có nhiều bệnh nhân đến đây."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Tôi sẽ chuẩn bị dụng cụ y tế. Hãy chắc chắn rằng mọi thứ đều sẵn sàng!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","s