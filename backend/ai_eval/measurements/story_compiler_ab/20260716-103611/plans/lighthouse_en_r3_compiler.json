visual_id":"v3"},{"angle":"low","axis":"sc3:primary","beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh11","lens":"normal","motion_intent":"track_left","scene_id":"sc3","shot_size":"medium","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b12"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"environmental","id":"sh12","lens":"portrait","motion_intent":"static","scene_id":"sc3","shot_size":"close","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b13"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh13","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v1"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b14"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"environmental","id":"sh14","lens":"portrait","motion_intent":"pull_out","scene_id":"sc4","shot_size":"close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The lighthouse had been dark for forty years when Elias took the keeper's job."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"The village called it cursed; he called it quiet."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"On his first night, climbing the spiral stairs with a lantern, he found the old logbook of the previous keeper, Mara, its final entry torn out."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"For weeks Elias tended the restored lamp, its beam sweeping the black water."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"But every night at 3:07, the light would flicker and dim on its own, as if something passed between it and the sea."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"He began to hear a voice in the wind — a woman, calling a name that was not his."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"One storm-lashed evening, a ship's horn wailed offshore, lost in the fog."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Elias raced to the lamp, but it died completely."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A ghost appears!","id":"b8","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"In the darkness he saw her: Mara, pale and translucent, standing at the glass."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"She had drowned that night forty years ago, unable to light the lamp in time, and had kept vigil ever since — trapped by her failure."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"elias","text":"I understand now, Mara. Let us light the way together!"},{"emotion":"sad","pose":"stand","speaker_id":"mara","text":"Thank you, Elias. I have waited so long for this moment."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Elias took her spectral hand and together they turned the great lens by force, coaxing a spark back into the wick."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The beam blazed out through the storm. On the water, the ship's horn answered — grateful, alive — and steered safe past the rocks."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"At dawn the lamp still burned. Mara was gone, her vigil finally ended."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Elias sat on the gallery, the sea calm and silver, and for the first time the lighthouse felt not cursed, but free."}],"motion":"zoom_out","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"mysterious","topic":"The Lighthouse Keeper","visuals":[{"character_ids":["elias"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"lighthouse","tier":"medium"},{"character_ids":["mara"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"lighthouse","tier":"medium"},{"character_ids":["elias","mara"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"lighthouse","tier":"medium"}]}