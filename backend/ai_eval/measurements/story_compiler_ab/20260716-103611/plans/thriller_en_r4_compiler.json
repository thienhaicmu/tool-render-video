id":"v2"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"negative_space","eyeline":"toward the opposing third","id":"sh6","lens":"portrait","motion_intent":"reveal","scene_id":"sc3","shot_size":"extreme_close","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh8","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh9","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"low","axis":"sc5:primary","beat_ids":["b10"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh10","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"environmental","id":"sh11","lens":"portrait","motion_intent":"pull_out","scene_id":"sc5","shot_size":"close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A mysterious call!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The room hummed with the soft murmur of radios and the rhythmic clatter of keys. Under the dim glow of monitors, Jack, the night dispatcher, leaned back in his chair, eyes focused on the screen."},{"emotion":"surprised","pose":"stand","speaker_id":"jack","text":"Control room, this is Train 113, we need assistance."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Jack's heart skipped. Train 113 hadn't been on the roster for decades. He checked again, eyes narrowing at the impossibility."},{"emotion":"surprised","pose":"stand","speaker_id":"jack","text":"Train 113, can you confirm your location?"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Silence crackled through the speakers, then the radio sputtered back to life."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The cabin shuddered, dust swirling in the beams of an old flashlight. A woman’s voice, tense yet determined, spoke into the radio."},{"emotion":"normal","pose":"stand","speaker_id":"sarah","text":"We’re in the old mountain tunnel. Tracks are blocked, passengers panicking."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Jack recognized the tunnel—a relic from the past, sealed off, forgotten. He felt a chill."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The entrance loomed, cloaked in shadows, the air heavy with age. Jack stood before the rusted gate, flashlight in hand, heart pounding."},{"emotion":"normal","pose":"stand","speaker_id":"jack","text":"I’m here. Tell me what you see."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Inside, the train sat like a ghost, its paint peeling, windows fogged with the breath of time."},{"emotion":"normal","pose":"stand","speaker_id":"sarah","text":"Lights are dimming. Please, hurry."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The inside was a time capsule, seats torn, a teddy bear abandoned on the floor. Jack moved cautiously, his footsteps echoing like whispers through history."},{"emotion":"normal","pose":"stand","speaker_id":"jack","text":"We can't let them fade away."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"He reached the engine, fingers finding the forgotten levers, the train groaning to life as power flickered and surged."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hours later, dawn crept in, painting the room in soft gold. Jack slumped in his chair, exhausted but relieved."},{"emotion":"happy","pose":"stand","speaker_id":"sarah","text":"Thank you, Jack. We all made it."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The line fell silent. Jack stared at the screen, the cursor blinking steadily as if in quiet applause."}],"motion":"zoom_out","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"tense","topic":"Train 113","visuals":[{"character_ids":["jack"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"train_dispatch_center","tier":"medium"},{"character_ids":["sarah"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"train_cabin","tier":"medium"},{"character_ids":["jack"],"id":"v3","negative_pr