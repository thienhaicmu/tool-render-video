ze":"wide","visual_id":"v2"},{"angle":"low","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh6","lens":"wide","motion_intent":"push_in","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"environmental","id":"sh8","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"low","axis":"sc4:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh9","lens":"normal","motion_intent":"track_right","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"high","axis":"sc5:primary","beat_ids":["b10"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh10","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v1"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b11"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh11","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Câu chuyện bắt đầu!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng tích tắc của những chiếc đồng hồ cũ vang vọng khắp cửa hàng nhỏ. Hùng, một thợ sửa đồng hồ điêu luyện, đang chăm chú tháo rời từng chi tiết của một chiếc đồng hồ bỏ túi cũ kỹ. Hùng vẫn nhớ rõ cái ngày em trai mình, Minh, biến mất không dấu vết."},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Tại sao mỗi chiếc đồng hồ này đều có một câu chuyện?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Khi kim đồng hồ chạy ngược, một hình ảnh thoáng qua hiện lên trong tâm trí Hùng: Minh đang cười, đứng dưới bóng cây trước sân nhà. Hùng giật mình, đặt chiếc đồng hồ xuống."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trở về căn hộ tối, Hùng nhìn chằm chằm vào bức tường trắng, phủ đầy hình ảnh và ghi chú về những chiếc đồng hồ anh đã sửa. Ở giữa bức tường là hình của Minh, nụ cười tươi tắn nhưng xa vời."},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Minh, anh sẽ tìm thấy em."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bất ngờ, một vệt sáng lóe lên từ hình ảnh của Minh, khiến Hùng chú ý đến một ký hiệu anh chưa từng thấy trước đó."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sáng hôm sau, Hùng gặp Lan, bạn thân của anh và Minh, tại một quán cà phê ấm cúng. Tiếng nhạc nhẹ nhàng lấp đầy không gian."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Hùng, trông anh mệt mỏi quá. Có chuyện gì sao?"},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Lan, mỗi đồng hồ anh sửa đều có một phút ký ức của chủ nhân. Minh đã để lại một dấu vết."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Anh nghĩ đó có thể là manh mối gì không?"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hùng và Lan đi theo ký hiệu bí ẩn dẫn họ tới một con hẻm tối. Những chiếc đèn đường chập chờn, bóng tối dày đặc bao trùm lấy hai người. Tim Hùng đập mạnh khi họ bắt gặp một cánh cửa cũ kỹ, kêu cọt kẹt khi mở ra."},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Đây phải là nơi đó."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bên trong căn phòng nhỏ tối tăm, họ tìm thấy một chiếc hộp sắt đã gỉ sét. Khi mở ra, một cuốn sổ tay và một chiếc đồng hồ cũ xuất hiện, bên cạnh là tấm ảnh Minh."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Minh từng ở đây sao?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Quay trở lại cửa hàng, Hùng nhìn vào chiếc đồng hồ cuối cùng mà Minh để lại. Anh mở nó ra, cảm nhận từng phút giây kỷ niệm chảy qua. Cuốn sổ tay tiết lộ lý do Minh rời xa, một cuộc sống mới, một hy vọng."},{"emotion":"normal","pose":"stand","speaker_id":"hung","text":"Em đã tìm thấy con đường của mình."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Chương mới bắt đầu!","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hùng mỉm cười nhẹ nhõm, biết rằng hành trình tìm kiếm Minh không kết thúc ở đây mà chỉ mới bắt đầu một chương mới trong cuộc đời anh."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"mysterious","topic":"Cuộc tìm kiếm Minh","visuals":[{"character_ids":["hung"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"cua_hang_dong_ho","tier":"medium"},{"character_ids":["hung","minh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"can_ho_hung","tier":"medium"},{"character_ids":["hung","lan"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"quan_ca_phe","tier":"medium"},{"character_ids":["hung","lan"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"con_hemm_toi","tier":"medium"}]}