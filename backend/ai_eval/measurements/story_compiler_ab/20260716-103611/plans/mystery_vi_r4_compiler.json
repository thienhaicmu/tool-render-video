","eyeline":"environmental","id":"sh16","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Ký ức kỳ lạ","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cửa hàng nhỏ nằm lặng lẽ giữa dãy phố tấp nập, ánh sáng vàng nhạt từ những chiếc đèn cũ mờ hắt lên những chiếc đồng hồ đủ loại. Thanh âm tích tắc như nhịp điệu bất tận, nhưng hôm ấy, điều gì đó khác thường đã diễn ra."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"thang","text":"Sao mỗi chiếc đồng hồ này lại có một mảnh ký ức lạ?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thắng, thợ sửa đồng hồ lâu năm, đã tìm thấy trong mỗi chiếc đồng hồ hỏng mình sửa một khoảnh khắc sống động của những người không quen biết. Đôi mắt anh nhìn chăm chú vào kim đồng hồ, nhịp tim bỗng nhanh hơn. Anh biết rằng mình đã chạm vào điều gì đó kỳ lạ."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tối đó, Thắng trải những mảnh ký ức trên bàn, ánh đèn vàng nhạt chiếu lên chúng. Một hình ảnh hiện lên rõ ràng, là em trai của anh, Hoàng, người đã mất tích từ lâu."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"sad","pose":"stand","speaker_id":"thang","text":"Làm sao những mảnh ghép này lại đưa về Hoàng?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bất ngờ, một mảnh ký ức xuất hiện, cho thấy cảnh Hoàng đứng trên một con phố lạ, có tiếng cười và ánh đèn neon nhấp nháy."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thắng bước đi giữa những ngã tư đông đúc, mùi thức ăn đường phố và tiếng nhạc vang vọng. Con phố này giống hệt trong mảnh ký ức. Sự căng thẳng như những sợi dây đàn kéo căng trong lòng anh."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"thang","text":"Mình phải tìm ra Hoàng, dù có gặp phải khó khăn nào."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Anh bước vào một quán cà phê nhỏ, nơi ánh sáng ấm áp và tiếng nhạc nhẹ nhàng. Mọi người trò chuyện nhè nhẹ, nhưng tai anh chỉ nghe thấy một cái tên quen thuộc."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"nguoila","text":"Anh tìm Hoàng? Anh ta có đến đây thường xuyên."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"thang","text":"Làm ơn, anh có thể chỉ cho tôi nơi Hoàng ở không?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Người lạ nhìn Thắng với đôi mắt hiểu biết, rồi chỉ ra ngoài cửa sổ, nơi một con hẻm nhỏ khuất bóng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Thắng bước sâu vào con hẻm, nơi bóng tối nhấn chìm mọi thứ. Bỗng, một bóng dáng quen thuộc xuất hiện. Đó là Hoàng, đang cắm cúi sửa một chiếc xe máy cũ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Cuộc hội ngộ bất ngờ","id":"b14","lines":[{"emotion":"happy","pose":"stand","speaker_id":"thang","text":"Hoàng! Anh đã tìm thấy em!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"hoang","text":"Anh Thắng? Sao anh lại ở đây?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hai anh em ôm chầm lấy nhau giữa bóng tối và ánh đèn đường yếu ớt. Những ký ức từ những chiếc đồng hồ đã dẫn Thắng đến một kết thúc bất ngờ và hạnh phúc hơn mọi điều anh tưởng tượng. Những mảnh ký ức ấy, tựa như những ngôi sao nhỏ, đã kết nối lại những sợi dây đứt nối giữa họ."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"mysterious","topic":"Ký ức từ những chiếc đồng hồ","visuals":[{"character_ids":["thang"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"cua_hang_dong_ho","tier":"medium"},{"character_ids":["thang"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"nha_rieng_thang","tier":"medium"},{"character_ids":["thang"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"pho_la","tier":"medium"},{"character_ids":["thang","nguoila"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"quan_ca_phe","tier":"medium"},{"character_ids":["thang","hoang"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"con_hemm_nho","tier":"medium"}]}