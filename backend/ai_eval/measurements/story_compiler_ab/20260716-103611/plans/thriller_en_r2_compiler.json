ary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc2:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh4","lens":"normal","motion_intent":"track_right","scene_id":"sc2","shot_size":"medium","visual_id":"v2"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh6","lens":"portrait","motion_intent":"reveal","scene_id":"sc3","shot_size":"extreme_close","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b8"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh8","lens":"portrait","motion_intent":"track_left","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"eye_level","axis":"sc4:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"leading_lines","eyeline":"environmental","id":"sh9","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v4"},{"angle":"low","axis":"sc5:primary","beat_ids":["b10"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh10","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A voice from the past!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The dim glow of monitors flickered across the cluttered control room. James, the night dispatcher, sipped stale coffee, eyes scanning the train schedules. Suddenly, static erupted from the radio, followed by a voice crackling with desperation."},{"emotion":"surprised","pose":"stand","speaker_id":"voice","text":"Control, this is Train 482! We're running out of time!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James froze, the mug trembling in his hand. Train 482 hadn't been on any schedule for decades. He leaned closer, adjusting the frequency to clear the interference."},{"emotion":"surprised","pose":"stand","speaker_id":"james","text":"Train 482, repeat your message. You shouldn't be on this line."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The voice returned, urgent and fragmented, the sound of an old steam engine echoing behind it."},{"emotion":"normal","pose":"stand","speaker_id":"voice","text":"Passengers... need help! The tunnel ahead—it's not safe!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James's pulse quickened. He pulled up archived records, dust-covered and forgotten, revealing the train's final route. It was scheduled to pass through the old Black Hollow Tunnel, abandoned after a collapse thirty years ago."},{"emotion":"normal","pose":"stand","speaker_id":"james","text":"I'm sending help. Hang tight. What's your location?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James sped towards the tunnel, phone pressed to his ear. The forest loomed around him, shadows swallowing the road. The dispatcher coordinated with local authorities, the urgency of the situation mounting with every passing second."},{"emotion":"normal","pose":"stand","speaker_id":"voice","text":"It's freezing... lights going out..."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James arrived, the tunnel's maw gaping like a forgotten relic. He could feel the icy breath of history brushing against his skin. The silence was heavy, oppressive, as if the past itself held its breath."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Flashlight in hand, James ventured into the tunnel's depths. The beam cut through the dark, revealing rusted tracks and eerie silence."},{"emotion":"angry","pose":"stand","speaker_id":"james","text":"Train 482, do you copy?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A haunting vision!","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Suddenly, the air shimmered, and for a fleeting moment, he saw them—a spectral train and passengers, translucent figures locked in eternal panic."},{"emotion":"normal","pose":"stand","speaker_id":"voice","text":"Thank you... we're free."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The vision faded, leaving only dust motes dancing in the light. James stood there, breathless, knowing he'd witnessed something beyond explanation. The past had spoken and, finally, found peace."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Back at the control room, dawn spilled golden light across the consoles. James sat, tracing his fingers over faded documents, the radio silent now."},{"emotion":"normal","pose":"stand","speaker_id":"james","text":"Some ghosts just need to be heard."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"tense","topic":"Train 482 Incident","visuals":[{"character_ids":["james","voice"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"train_control_room","tier":"medium"},{"character_ids":["james","voice"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"control_room_intensifies","tier":"medium"},{"character_ids":["james","voice"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"deserted_tunnel_entrance","tier":"medium"},{"character_ids":["james","voice"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"tunnel_depths","tier":"medium"},{"character_ids":["james"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"control_room_dawn","tier":"medium"}]}