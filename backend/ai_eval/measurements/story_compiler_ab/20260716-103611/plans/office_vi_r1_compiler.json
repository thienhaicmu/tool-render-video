sition":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh14","lens":"wide","motion_intent":"push_in","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"high","axis":"sc4:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh15","lens":"normal","motion_intent":"track_left","scene_id":"sc4","shot_size":"medium","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b16"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"environmental","id":"sh16","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"low","axis":"sc5:primary","beat_ids":["b17"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh17","lens":"normal","motion_intent":"track_right","scene_id":"sc5","shot_size":"medium","visual_id":"v5"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b18"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh18","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"high","axis":"sc5:primary","beat_ids":["b19"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh19","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"extreme_close","visual_id":"v5"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Sự thật được phơi bày!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Âm thanh tiếng gõ bàn phím vang lên giữa những tách cà phê sớm. Lan đứng trước bàn làm việc, nhìn chằm chằm vào máy tính của mình. Trên màn hình, một email đọc được tiêu đề: \"Sai sót trong báo cáo tài chính cuối năm.\""}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Sao có thể? Mình đã kiểm tra rất kỹ."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan gõ một email xin lỗi gửi cho sếp. Trong lòng có chút lo lắng, nhưng quyết tâm rời công ty đã khiến cô nhẹ lòng."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Buổi trưa, Lan đi dọc hành lang, tình cờ nghe thấy tiếng xì xào từ phòng họp. Cô dừng lại, hơi nghiêng đầu để nghe rõ hơn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"dong_nghiep_1","text":"Có lẽ là lỗi của Lan. Cô ấy sắp nghỉ, ai mà quan tâm."},{"emotion":"normal","pose":"stand","speaker_id":"dong_nghiep_2","text":"Nhưng Tùng đã sửa nhiều lần rồi. Không hiểu sao anh ấy lại bị quở trách."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan đứng chết trân. Tùng, đồng nghiệp trầm lặng ngồi cách cô hai bàn, đã âm thầm sửa lỗi cho cô suốt bao năm qua. Cảm giác lẫn lộn giữa biết ơn và xấu hổ trỗi dậy trong cô."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuối giờ làm, Lan mời Tùng đi uống cà phê. Đối mặt với sự thật là việc khó, nhưng cô cần phải biết."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Tùng, anh đã sửa lỗi cho tôi suốt thời gian qua phải không?"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"tung","text":"Ừ, chỉ là những điều nhỏ nhặt thôi. Tôi không muốn cô gặp rắc rối."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trái tim Lan nặng trĩu. Cô nhìn Tùng, người chỉ cười nhẹ như thể việc làm này không đáng kể."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Tôi sẽ làm rõ việc này với sếp. Anh không đáng bị đổ lỗi."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày hôm sau, Lan đứng trước sếp, cảm giác căng thẳng bao trùm. Cô hít một hơi sâu, chuẩn bị cho điều sắp nói."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Thưa sếp, lỗi trong báo cáo là của tôi. Tùng chỉ giúp tôi sửa. Anh ấy không liên quan."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"sep","text":"Thật vậy sao? Tôi sẽ xem xét lại vấn đề."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sếp gật đầu, ánh mắt có phần dịu lại. Lan thở phào, cảm giác như một gánh nặng đã được gỡ bỏ."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngày cuối cùng của Lan ở công ty. Cô đi dọc hành lang như một hành động cuối cùng của một chương đã khép lại. Cô thấy Tùng đứng ở lối ra, ánh mắt đầy ý nghĩa."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b17","lines":[{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Cảm ơn anh, Tùng. Tôi nợ anh nhiều lắm."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b18","lines":[{"emotion":"happy","pose":"stand","speaker_id":"tung","text":"Hãy thành công ở nơi mới nhé, Lan."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b19","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan mỉm cười, mở cửa ra khỏi công ty, lòng nhẹ nhàng và tự tin hơn bao giờ hết."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh19","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"}],"tone":"cảm động","topic":"Câu chuyện về sự trung thực và lòng biết ơn","visuals":[{"character_ids":["lan"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"van_phong","tier":"medium"},{"character_ids":["lan","dong_nghiep_1","dong_nghiep_2"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"},{"character_ids":["lan","tung"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"quan_ca_phe","tier":"medium"},{"character_ids":["lan","sep"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"phong_seo","tier":"medium"},{"character_ids":["lan","tung"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"}]}