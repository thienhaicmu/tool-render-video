eat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"centered","eyeline":"environmental","id":"sh15","lens":"normal","motion_intent":"track_right","scene_id":"sc4","shot_size":"medium","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc5:primary","beat_ids":["b16"],"blocking":"establish participants and geography","camera_position":"profile","composition":"negative_space","eyeline":"environmental","id":"sh16","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v2"},{"angle":"high","axis":"sc5:primary","beat_ids":["b17"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"symmetrical","eyeline":"environmental","id":"sh17","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"extreme_close","visual_id":"v2"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b18"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh18","lens":"wide","motion_intent":"push_in","scene_id":"sc5","shot_size":"wide","visual_id":"v2"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Bắt đầu kỳ lạ!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trần, người bảo vệ ca đêm, ngồi một mình trong phòng tối, chỉ có ánh sáng từ màn hình camera. Đêm nay, mọi thứ đều im lặng đến kỳ lạ. Anh chăm chú nhìn vào màn hình, nơi các camera ghi lại từng góc của khu nhà."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một chiếc đồng hồ cũ tích tắc trên tường. Trần nhận xét khung hình của camera góc hành lang. Như thể có ai đó vừa bước qua trước mắt. Nhưng hành lang đang trống trơn."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"tran","text":"Sao lại thế này...?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Anh cúi xuống nhìn kỹ. Trên màn hình, một bóng người xuất hiện; chính là Trần, đang đi qua hành lang đó. Nhưng điều kỳ lạ là người trên màn hình dường như đang di chuyển trước anh đúng mười phút."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trần đứng dậy, bước ra khỏi phòng, đi về phía hành lang mà anh vừa thấy trên màn hình. Tiếng bước chân của anh vang vọng, hòa cùng nhịp đập bất thường của tim mình. Mỗi bước chân như kéo dài không dứt."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Anh đến, nhìn xung quanh. Tất cả đều vắng lặng, không một bóng người. Nhưng cảm giác bị theo dõi không biến mất."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"tran","text":"Có ai ở đây không?"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chỉ có tiếng vang của chính giọng nói anh đáp lại. Trần quay gót trở về phòng giám sát, nhưng cảm giác bất an vẫn bám theo từng bước."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trở lại trước màn hình, Trần kiểm tra lại đoạn video. Anh nhấn tua nhanh, hình ảnh trên màn hình tiếp tục hiện ra chính anh, làm những việc mà anh chưa làm. Cứ như thể anh đang bị theo dõi từ tương lai."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"tran","text":"Mình đang mơ sao...?"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Tiếng gõ cửa làm cắt ngang suy nghĩ. Trần quay lại, nhưng lối vào trống không. Anh lùi lại, mắt vẫn không rời khỏi màn hình, nơi mà hình ảnh của anh tiếp tục di chuyển, đi vào căn phòng khác."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trần không còn sự lựa chọn, anh theo dấu hình ảnh của mình trên màn hình, dẫn đến phòng kho tối tăm. Cánh cửa gỗ kẽo kẹt mở ra dưới tay anh."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bên trong, chỉ có bóng tối. Nhưng anh cảm thấy sự hiện diện của một ai đó. Một tiếng thở dài nhẹ nhàng vang lên phía sau lưng anh."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"tran","text":"Ai đó...?"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Anh quay lại, và đối mặt với chính mình. Một phiên bản khác của Trần, đứng đó, nhìn anh với đôi mắt trống rỗng. Cánh cửa phòng kho đột ngột sầm lại, nhốt anh bên trong với chính bản sao của mình."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một tuần sau, tòa nhà vẫn hoạt động bình thường. Không ai biết về sự mất tích của Trần, ngoại trừ những người bảo vệ khác. Họ thường nghe tiếng bước chân và tiếng thì thầm trong đêm, nhưng không ai biết đó là âm thanh của điều gì."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b17","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Các camera vẫn tiếp tục quay. Nhưng giờ đây, trên màn hình, chỉ có những bóng người không rõ nét, cứ đi qua đi lại như một lời nhắc nhở lặng lẽ về sự hiện diện của những gì đã biến mất."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b18","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Câu hỏi vẫn còn lơ lửng trong không gian tối tăm của tòa nhà. Liệu có ai dám đi tìm câu trả lời?"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"}],"tone":"horror","topic":"Trần và bóng ma","visuals":[{"character_ids":["tran"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_giam_sat","tier":"medium"},{"character_ids":["tran"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"hanh_lang","tier":"medium"},{"character_ids":["tran"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_kho","tier":"medium"}]}