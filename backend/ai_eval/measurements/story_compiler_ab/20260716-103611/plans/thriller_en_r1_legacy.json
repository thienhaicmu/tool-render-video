ion":"leading_lines","eyeline":"toward the opposing third","id":"sh14","lens":"normal","motion_intent":"track_left","scene_id":"sc1","shot_size":"medium","visual_id":"v1"},{"angle":"over_shoulder","axis":"sc1:primary","beat_ids":["b15"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh15","lens":"portrait","motion_intent":"static","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"high","axis":"sc1:primary","beat_ids":["b16"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"negative_space","eyeline":"toward the opposing third","id":"sh16","lens":"normal","motion_intent":"track_right","scene_id":"sc1","shot_size":"medium","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"A call from the past!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"In the heart of the bustling train dispatch center, James sat surrounded by screens, his eyes scanning the endless streams of data."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"Another day, another train schedule to manage. Nothing unusual ever happens here."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Suddenly, the radio crackled to life, breaking the monotony. James leaned closer, his heart racing."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"This is Dispatcher James. Go ahead with your call!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"A voice, distorted and shaky, emerged from the static. It sent chills down James's spine."},{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Help! We’re trapped on the Midnight Express! It’s not on the schedule!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James's mind raced. The Midnight Express had been removed from the timetable thirty years ago. How could it be operational?"},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"Where are you located? I need your coordinates!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The voice faltered, then whispered, \"We’re stuck in the tunnel! It’s dark… and something is coming!\""},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"Stay calm! I’m sending help. Hold on!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James’s fingers flew over the controls as he scrambled to locate the train. Panic surged through him."},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_james","text":"This can't be happening! The Midnight Express was a ghost!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As he searched, the radio crackled again, but this time the voice was different, more menacing."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"You shouldn’t have called us, James. We’re not ready to leave yet..."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James felt a cold sweat trickle down his back. Who were they? What did they mean?"},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_james","text":"Who are you? What do you want?"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The response sent a chill through him, \"We want to finish what we started. The train never stopped for a reason.\""},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_james","text":"I won’t let you! I’ll stop you!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Suddenly, alarms blared throughout the dispatch center. James's heart sank as he realized the gravity of the situation."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"No! Not now! I have to save them!"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"With determination, James activated the emergency protocols, sending a rescue team towards the tunnel."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"I’m sending help! You’re not alone!"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As he watched the rescue team’s progress on the screen, James felt a flicker of hope ignite within him."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"Hold on! They’re coming!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"But the voice returned, darker this time, \"You can’t save them, James. They belong to us now.\""},{"emotion":"angry","pose":"stand","speaker_id":"","text":"No! I won’t let you take them!"}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"James's heart raced as he realized the sinister truth: the Midnight Express was a vessel of lost souls."},{"emotion":"angry","pose":"stand","speaker_id":"dispatcher_james","text":"I will stop this! I will find a way!"}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As the rescue team entered the tunnel, the radio fell silent. James held his breath, praying for their safety."},{"emotion":"normal","pose":"stand","speaker_id":"dispatcher_james","text":"Please, come back!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Finally, the radio crackled back to life, but it was not the voice he expected. It was silence, heavy and foreboding."},{"emotion":"surprised","pose":"stand","speaker_id":"dispatcher_james","text":"No... what happened?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"mysterious","topic":"The Echo of the Forgotten Train","visuals":[{"character_ids":["dispatcher_james"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"dispatch_center","tier":"medium"}]}