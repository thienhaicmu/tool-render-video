ocus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong một bệnh viện đông đúc, Minh và Lan, hai bác sĩ trẻ, tình cờ gặp lại nhau sau nhiều năm."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Minh! Lâu quá không gặp, anh vẫn khỏe chứ?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Lan! Anh vẫn ổn, nhưng công việc thì bận rộn quá."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ từng là một cặp đôi, nhưng những hiểu lầm đã khiến họ chia tay."},{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Em vẫn nhớ những kỷ niệm đẹp của chúng ta."},{"emotion":"sad","pose":"stand","speaker_id":"minh","text":"Anh cũng vậy, nhưng có lẽ mọi thứ đã quá muộn."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Bỗng dưng, một cơn bão lớn ập đến, khiến bệnh viện trở nên hỗn loạn."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Chúng ta phải giúp đỡ bệnh nhân ngay bây giờ!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Đúng vậy, hãy cùng nhau làm việc nhé!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ nhanh chóng phối hợp để chăm sóc các bệnh nhân trong phòng chờ."},{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Có một đứa trẻ bị thương nặng, chúng ta phải đưa nó vào phòng cấp cứu!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Để anh giúp em, chúng ta cần nhanh chóng!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong phòng cấp cứu, họ làm việc không ngừng nghỉ để cứu đứa trẻ."},{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Tim đứa trẻ yếu quá, chúng ta cần thêm máu!"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Đừng lo, anh sẽ gọi người mang máu ngay!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuối cùng, sau nhiều nỗ lực, họ đã cứu sống đứa trẻ."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Chúng ta đã làm được! Cảm ơn anh, Minh!"},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Em cũng vậy, Lan. Chúng ta đã cùng nhau vượt qua thử thách này."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sau cơn bão, họ ngồi lại trong phòng chờ, cảm thấy nhẹ nhõm."},{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Anh có nghĩ rằng chúng ta có thể bắt đầu lại không?"},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Nếu em muốn, anh sẽ không từ chối."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"romantic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Khởi đầu mới!","id":"b8","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Họ nhìn nhau, ánh mắt tràn đầy hy vọng và tình yêu."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Chúng ta sẽ cùng nhau xây dựng lại mọi thứ, đúng không?"},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Đúng vậy, bắt đầu từ hôm nay!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"happy","pose":"stand","speaker_id":"","text":"Tình yêu của họ đã được thử thách và giờ đây, họ trở lại bên nhau."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Em rất hạnh phúc khi có anh bên cạnh."},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Và anh cũng vậy, Lan. Chúng ta sẽ không bao giờ để hiểu lầm chia cắt nữa."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"romantic","topic":"Tình yêu trong bão tố","visuals":[{"character_ids":["minh","lan"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"hospital","tier":"medium"},{"character_ids":["minh","lan"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"waiting_room","tier":"medium"},{"character_ids":["minh","lan"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"emergency_room","tier":"medium"}]}