"angle":"over_shoulder","axis":"sc1:primary","beat_ids":["b1"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh1","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b2"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh2","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"low","axis":"sc3:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v3"},{"angle":"high","axis":"sc4:primary","beat_ids":["b4"],"blocking":"establish participants and geography","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh4","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v4"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b5"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh5","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v5"},{"angle":"over_shoulder","axis":"sc6:primary","beat_ids":["b6"],"blocking":"establish participants and geography","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh6","lens":"wide","motion_intent":"reveal","scene_id":"sc6","shot_size":"wide","visual_id":"v6"},{"angle":"eye_level","axis":"sc7:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc7","shot_size":"wide","visual_id":"v7"},{"angle":"low","axis":"sc8:primary","beat_ids":["b8"],"blocking":"establish participants and geography","camera_position":"profile","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh8","lens":"wide","motion_intent":"reveal","scene_id":"sc8","shot_size":"wide","visual_id":"v8"},{"angle":"over_shoulder","axis":"sc8:primary","beat_ids":["b9"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"rule_of_thirds","eyeline":"environmental","id":"sh9","lens":"wide","motion_intent":"pull_out","scene_id":"sc8","shot_size":"wide","visual_id":"v8"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Bão đang tới!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Khoa cấp cứu bệnh viện lúc nửa đêm, ánh đèn neon nhấp nháy, tiếng còi xe cấp cứu vang lên từng hồi. Những giọt mưa nặng trĩu rơi xuống cửa kính, như những giọt nước mắt chưa kịp lau."},{"emotion":"angry","pose":"stand","speaker_id":"ha","text":"Minh, sao anh lại ở đây? Không phải ca trực của anh."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Hà, chúng ta cần tất cả mọi người tối nay. Bão đang tới gần."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong ánh sáng lờ mờ của phòng điều trị, hai người đứng đối diện nhau, giữa họ là một cậu bé đang nằm bất động. Tiếng mưa rơi càng lúc càng nặng."},{"emotion":"sad","pose":"stand","speaker_id":"ha","text":"Cậu bé này cần phẫu thuật gấp, nhưng máy móc không đủ."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Chúng ta sẽ tìm cách. Em còn nhớ cách làm việc chung chứ?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đèn phòng phẫu thuật mờ nhạt chiếu sáng khuôn mặt căng thẳng của Hà và Minh. Tiếng mưa ngoài kia vẫn không ngừng, như nhắc nhở họ về thời gian ít ỏi."},{"emotion":"normal","pose":"stand","speaker_id":"ha","text":"Anh giữ nhịp tim ổn định, em sẽ chuẩn bị dụng cụ."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Được, cùng nhau nhé."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trên hành lang vắng lặng, Hà và Minh bước cạnh nhau, hơi thở dồn dập. Bức tường màu trắng lạnh lẽo mà quen thuộc."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Ngày xưa chúng ta đã từng hứa với nhau điều gì nhỉ?"},{"emotion":"sad","pose":"stand","speaker_id":"ha","text":"Những điều hứa hẹn giờ đã xa rồi."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v4"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Căn phòng nghỉ nhỏ với chiếc bàn gỗ cũ kỹ và vài ly cà phê còn nghi ngút hơi. Tiếng mưa dội vào mái tôn tạo thành bản hòa tấu não nề."},{"emotion":"sad","pose":"stand","speaker_id":"ha","text":"Anh không biết em đã tổn thương thế nào khi anh ra đi."},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Hà, anh xin lỗi. Anh đã sai khi rời bỏ em mà không nói lời nào."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v5"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cậu bé đã qua cơn nguy kịch, nằm ngủ bình yên trên giường, hơi thở nhẹ nhàng như gió thoảng. Ánh sáng từ ngoài cửa chiếu vào tạo ra một không gian yên bình."},{"emotion":"happy","pose":"stand","speaker_id":"ha","text":"Chúng ta đã cứu được cậu bé."},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Và có lẽ, chúng ta có thể cứu vãn cả quá khứ."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v6"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trời vẫn mưa, nhưng bầu trời đã dịu lại, như báo hiệu ngày mới sẽ đến. Hà và Minh đứng dưới mái hiên, nhìn những giọt mưa rơi xuống."},{"emotion":"normal","pose":"stand","speaker_id":"ha","text":"Liệu có thể bắt đầu lại không?"},{"emotion":"normal","pose":"stand","speaker_id":"minh","text":"Chúng ta có thể thử. Miễn là em cho anh cơ hội."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v7"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Chiếc xe của Minh đậu dưới tán cây, những chiếc lá rung rinh theo gió. Hà bước chậm rãi, mỗi bước là một quyết định nhỏ nhặt."},{"emotion":"normal","pose":"stand","speaker_id":"ha","text":"Được, chúng ta sẽ thử lại. Lần này, không ai bỏ đi nữa."},{"emotion":"happy","pose":"stand","speaker_id":"minh","text":"Anh hứa."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v8"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cửa xe đóng lại, tiếng động nhẹ nhàng nhưng đầy ý nghĩa. Một cuộc hành trình mới bắt đầu, giữa con bão của cuộc đời, họ đã tìm thấy nhau một lần nữa."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v8"}],"tone":"dramatic","topic":"Cuộc sống và tình yêu trong bệnh viện","visuals":[{"character_ids":["ha","minh"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"benh_vien_khoa_cap_cuu","tier":"medium"},{"character_ids":["ha","minh"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"phong_dieu_tri","tier":"medium"},{"character_ids":["ha","minh"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"phong_phau_thuat_du_bi","tier":"medium"},{"character_ids":["ha","minh"],"id":"v4","negative_prompt":"","prompt":"","setting_id":"hanh_lang_benh_vien","tier":"medium"},{"character_ids":["ha","minh"],"id":"v5","negative_prompt":"","prompt":"","setting_id":"phong_nghi_nhan_vien","tier":"medium"},{"character_ids":["ha","minh"],"id":"v6","negative_prompt":"","prompt":"","setting_id":"phong_benh_nhan","tier":"medium"},{"character_ids":["ha","minh"],"id":"v7","negative_prompt":"","prompt":"","setting_id":"san_benh_vien","tier":"medium"},{"character_ids":["ha","minh"],"id":"v8","negative_prompt":"","prompt":"","setting_id":"bai_dau_xe_benh_vien","tier":"medium"}]}