composition":"rule_of_thirds","eyeline":"environmental","id":"sh8","lens":"portrait","motion_intent":"static","scene_id":"sc4","shot_size":"close","visual_id":"v3"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b9"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh9","lens":"wide","motion_intent":"reveal","scene_id":"sc5","shot_size":"wide","visual_id":"v1"},{"angle":"low","axis":"sc5:primary","beat_ids":["b10"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh10","lens":"wide","motion_intent":"pull_out","scene_id":"sc5","shot_size":"wide","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Bắt đầu kinh hoàng!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đêm đã khoác chiếc áo tối mịt lên khu nhà máy. Tiếng động cơ xa xa như giấc mơ mờ nhạt. Tại phòng bảo vệ, Hải ngồi trầm ngâm trước màn hình camera giám sát. Một ánh sáng nhấp nháy trên màn hình bắt đầu thu hút anh."},{"emotion":"surprised","pose":"stand","speaker_id":"hai","text":"Cái gì đây?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trên màn hình, hình ảnh anh đang đi tuần tra, nhưng điều kỳ lạ là anh đang ngồi đây. Giọt mồ hôi lạnh chảy dài trên trán. Anh nhấn nút tua nhanh để kiểm tra."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hải bước nhanh dọc hành lang, ánh đèn neon hắt lên bóng anh dài lướt qua tường. Mỗi bước chân dường như thách thức cái bóng kỳ lạ kia. Tiếng dội bước chân của anh vang vọng, như thể có ai đó đang theo sau."},{"emotion":"surprised","pose":"stand","speaker_id":"hai","text":"Sao có thể thế được?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đôi mắt tìm kiếm, nhưng chỉ có tường và bóng tối đáp lại. Anh quay về phòng bảo vệ, nhưng linh cảm không lành cứ đeo bám."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hải ngồi lại trước màn hình. Hình ảnh trên camera giật mình sống động. Mười phút trước, anh thấy mình dừng lại trước cánh cửa kho, nơi chỉ có anh có chìa khóa. Anh nín thở."},{"emotion":"angry","pose":"stand","speaker_id":"hai","text":"Không thể nào!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Đột nhiên, màn hình tối đen. Không thể tin được, anh đứng bật dậy, nhìn quanh phòng bảo vệ trống rỗng. Sự im lặng như giam cầm anh."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trái tim Hải đập mạnh khi anh đến cửa kho. Cánh cửa mở toang, ánh sáng từ bên trong chiếu ra vầng tối. Anh bước vào, không gian lạnh lẽo và im lặng đến ma quái."},{"emotion":"surprised","pose":"stand","speaker_id":"hai","text":"Ai đó?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Không có tiếng trả lời. Nhưng từ trong bóng tối, tiếng bước chân vang lên, từng nhịp như đồng hồ tíc tắc."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Hải quay về phòng bảo vệ, tay run rẩy khóa chặt cửa. Trên màn hình, hình ảnh anh xuất hiện lại, vẫn đang đi tuần tra một cách bí ẩn. Anh nhận ra, anh không thể thoát khỏi chính mình."},{"emotion":"sad","pose":"stand","speaker_id":"hai","text":"Chuyện này... sẽ không bao giờ kết thúc..."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Ngoài cửa, tiếng gió hú như tiếng cười của đêm đen. Hải ngồi đó, chờ bóng tối đến một lần nữa."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"hồi hộp","topic":"Câu chuyện kinh dị tại nhà máy","visuals":[{"character_ids":["hai"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"phong_bao_ve","tier":"medium"},{"character_ids":["hai"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"hanh_lang_nha_may","tier":"medium"},{"character_ids":["hai"],"id":"v3","negative_prompt":"","prompt":"","settin