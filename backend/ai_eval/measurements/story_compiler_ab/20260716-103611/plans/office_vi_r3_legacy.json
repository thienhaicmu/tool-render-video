"toward the opposing third","id":"sh16","lens":"portrait","motion_intent":"static","scene_id":"sc6","shot_size":"close","visual_id":"v3"},{"angle":"over_shoulder","axis":"sc6:primary","beat_ids":["b17"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh17","lens":"normal","motion_intent":"track_right","scene_id":"sc6","shot_size":"medium","visual_id":"v3"},{"angle":"high","axis":"sc6:primary","beat_ids":["b18"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh18","lens":"wide","motion_intent":"pull_out","scene_id":"sc6","shot_size":"wide","visual_id":"v3"},{"angle":"eye_level","axis":"sc7:primary","beat_ids":["b19"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh19","lens":"wide","motion_intent":"reveal","scene_id":"sc7","shot_size":"wide","visual_id":"v2"},{"angle":"low","axis":"sc7:primary","beat_ids":["b20"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh20","lens":"wide","motion_intent":"push_in","scene_id":"sc7","shot_size":"wide","visual_id":"v2"},{"angle":"high","axis":"sc8:primary","beat_ids":["b21"],"blocking":"establish participants and geography","camera_position":"front","composition":"leading_lines","eyeline":"toward the opposing third","id":"sh21","lens":"wide","motion_intent":"reveal","scene_id":"sc8","shot_size":"wide","visual_id":"v1"},{"angle":"eye_level","axis":"sc8:primary","beat_ids":["b22"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"environmental","id":"sh22","lens":"portrait","motion_intent":"static","scene_id":"sc8","shot_size":"close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong một văn phòng hiện đại, Lan đang ngồi bên bàn làm việc, ánh mắt lo lắng nhìn vào màn hình máy tính."},{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Mình đã làm sai ở đâu nhỉ? Tại sao mọi thứ lại trở nên khó khăn như vậy?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"hieu","text":"Lan, mình thấy có vấn đề trong báo cáo của bạn. Bạn có chắc chắn đã kiểm tra kỹ chưa?"},{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Mình đã kiểm tra rồi, Hiếu. Có thể có sai sót nhưng mình không nghĩ nó nghiêm trọng đến vậy."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan cảm thấy áp lực khi nghe Hiếu nói. Cô biết rằng mình đã mắc lỗi nhưng không thể nhớ ra được."},{"emotion":"angry","pose":"stand","speaker_id":"hieu","text":"Mọi người đang bàn tán về bạn. Họ nghĩ bạn không đủ năng lực để hoàn thành công việc."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"sad","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"sad","pose":"stand","speaker_id":"","text":"Trong phòng nghỉ, Lan ngồi một mình, tay cầm tách cà phê, lòng đầy nỗi lo lắng."},{"emotion":"happy","pose":"stand","speaker_id":"hieu","text":"Lan, mình biết bạn đang gặp khó khăn. Nhưng hãy tin mình, mọi người đều có lúc sai lầm."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"lan","text":"Cảm ơn Hiếu, mình sẽ cố gắng hơn. Nhưng mình không thể không cảm thấy có điều gì đó không ổn."},{"emotion":"happy","pose":"stand","speaker_id":"hieu","text":"Hãy để mình giúp bạn. Chúng ta có thể cùng nhau xem lại báo cáo."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Trong phòng họp, Lan và Hiếu đang trình bày báo cáo trước mặt quản lý Anh."},{"emotion":"angry","pose":"stand","speaker_id":"anh","text":"Tôi không hài lòng với những gì tôi thấy trong báo cáo này. Ai là người chịu trách nhiệm?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Tôi... Tôi đã làm hết sức mình. Nhưng có thể có ai đó đã sửa đổi mà tôi không biết."},{"emotion":"angry","pose":"stand","speaker_id":"anh","text":"Nếu bạn không thể giải thích, tôi sẽ phải xem xét lại vị trí của bạn trong công ty."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Sự thật bị che giấu!","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan cảm thấy như có điều gì đó bí ẩn đang diễn ra. Cô quyết định điều tra."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Tôi sẽ tìm ra sự thật. Ai đó đang cố tình đổ lỗi cho tôi."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b9","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan bắt đầu theo dõi Hiếu, cô nhận thấy anh thường xuyên vào phòng làm việc vào ban đêm."},{"emotion":"surprised","pose":"stand","speaker_id":"lan","text":"Tại sao Hiếu lại làm vậy? Có phải anh ta đang che giấu điều gì không?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh9","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b10","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Một đêm, Lan quyết định ở lại làm việc muộn để theo dõi Hiếu."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Mình phải tìm ra sự thật này. Không thể để mình bị đổ tội mãi."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh10","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b11","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Khi Hiếu bước vào, Lan nghe thấy anh nói chuyện với một người khác qua điện thoại."},{"emotion":"normal","pose":"stand","speaker_id":"hieu","text":"Đúng rồi, tôi đã sửa lại báo cáo của Lan. Không ai biết điều này cả."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh11","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b12","lines":[{"emotion":"surprised","pose":"stand","speaker_id":"","text":"Lan cảm thấy như thế giới sụp đổ. Cô không thể tin được điều mình vừa nghe."},{"emotion":"sad","pose":"stand","speaker_id":"lan","text":"Tại sao Hiếu lại làm vậy? Tại sao lại phản bội tôi?"}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh12","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b13","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan quyết định đối mặt với Hiếu. Cô không thể để anh ta thoát khỏi tội ác này."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Hiếu, tại sao bạn lại làm như vậy? Bạn đã sửa đổi báo cáo của tôi!"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh13","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"action","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b14","lines":[{"emotion":"angry","pose":"stand","speaker_id":"hieu","text":"Tôi không có lựa chọn nào khác! Bạn không đủ khả năng để hoàn thành công việc!"},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cả hai người họ bắt đầu tranh cãi, không khí trở nên căng thẳng."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh14","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"dark","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b15","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Quản lý Anh bước vào, nghe thấy cuộc tranh cãi và yêu cầu cả hai dừng lại."},{"emotion":"angry","pose":"stand","speaker_id":"anh","text":"Dừng lại! Tôi muốn nghe sự thật từ cả hai người."}],"motion":"pan_left","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh15","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b16","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan quyết định kể lại mọi chuyện, từ những gì cô đã phát hiện ra về Hiếu."},{"emotion":"angry","pose":"stand","speaker_id":"lan","text":"Tôi không thể chấp nhận việc mình bị đổ lỗi cho những sai lầm mà người khác gây ra!"}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh16","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b17","lines":[{"emotion":"sad","pose":"stand","speaker_id":"hieu","text":"Tôi xin lỗi, Lan. Tôi đã sai khi làm như vậy. Tôi chỉ muốn bảo vệ vị trí của mình."},{"emotion":"sad","pose":"stand","speaker_id":"","text":"Hiếu cúi đầu, cảm thấy hối hận về hành động của mình."}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh17","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b18","lines":[{"emotion":"normal","pose":"stand","speaker_id":"anh","text":"Tôi sẽ xem xét lại mọi thứ. Cả hai bạn cần phải làm việc cùng nhau để khắc phục."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Quản lý Anh cố gắng giữ bình tĩnh trong tình huống căng thẳng này."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh18","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v3"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b19","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Sau cuộc họp, Lan và Hiếu quyết định hợp tác để cải thiện tình hình."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Chúng ta cần làm việc cùng nhau để không ai phải chịu thiệt thòi nữa."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh19","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b20","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Lan cảm thấy nhẹ nhõm khi biết sự thật đã được phơi bày. Cô quyết tâm sẽ không để điều này xảy ra lần nữa."},{"emotion":"happy","pose":"stand","speaker_id":"hieu","text":"Mình sẽ không bao giờ phản bội bạn nữa. Chúng ta sẽ cùng nhau vượt qua mọi khó khăn."}],"motion":"zoom_in","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh20","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b21","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Cuối cùng, Lan và Hiếu đã tìm lại được sự tin tưởng và quyết tâm làm việc chăm chỉ hơn."},{"emotion":"happy","pose":"stand","speaker_id":"lan","text":"Cảm ơn bạn đã giúp mình. Chúng ta sẽ cùng nhau tiến xa hơn."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh21","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b22","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Câu chuyện của họ không chỉ là về công việc, mà còn là về tình bạn và sự trung thực trong cuộc sống."},{"emotion":"normal","pose":"stand","speaker_id":"","text":"Họ đã học được rằng sự thật luôn là điều cần thiết để xây dựng mối quan hệ bền vững."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh22","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"dramatic","topic":"Sự thật ẩn giấu","visuals":[{"character_ids":["lan","hieu"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"office","tier":"medium"},{"character_ids":["lan","hieu"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"breakroom","tier":"medium"},{"character_ids":["lan","anh"],"id":"v3","negative_prompt":"","prompt":"","setting_id":"meetingroom","tier":"medium"}]}