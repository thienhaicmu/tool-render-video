_id":""}],"shots":[{"angle":"high","axis":"sc1:primary","beat_ids":["b1"],"blocking":"establish participants and geography","camera_position":"front","composition":"negative_space","eyeline":"toward the opposing third","id":"sh1","lens":"portrait","motion_intent":"reveal","scene_id":"sc1","shot_size":"close","visual_id":"v1"},{"angle":"eye_level","axis":"sc2:primary","beat_ids":["b2"],"blocking":"establish participants and geography","camera_position":"three_quarter","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh2","lens":"wide","motion_intent":"reveal","scene_id":"sc2","shot_size":"wide","visual_id":"v2"},{"angle":"over_shoulder","axis":"sc3:primary","beat_ids":["b3"],"blocking":"establish participants and geography","camera_position":"front","composition":"rule_of_thirds","eyeline":"toward the opposing third","id":"sh3","lens":"wide","motion_intent":"reveal","scene_id":"sc3","shot_size":"wide","visual_id":"v1"},{"angle":"high","axis":"sc3:primary","beat_ids":["b4"],"blocking":"hold the active speaker on the dominant third","camera_position":"profile","composition":"leading_lines","eyeline":"environmental","id":"sh4","lens":"portrait","motion_intent":"static","scene_id":"sc3","shot_size":"close","visual_id":"v1"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b5"],"blocking":"hold the active speaker on the dominant third","camera_position":"front","composition":"centered","eyeline":"toward the opposing third","id":"sh5","lens":"normal","motion_intent":"track_right","scene_id":"sc3","shot_size":"medium","visual_id":"v1"},{"angle":"eye_level","axis":"sc3:primary","beat_ids":["b6"],"blocking":"hold the active speaker on the dominant third","camera_position":"three_quarter","composition":"negative_space","eyeline":"environmental","id":"sh6","lens":"wide","motion_intent":"pull_out","scene_id":"sc3","shot_size":"wide","visual_id":"v1"},{"angle":"over_shoulder","axis":"sc4:primary","beat_ids":["b7"],"blocking":"establish participants and geography","camera_position":"front","composition":"symmetrical","eyeline":"toward the opposing third","id":"sh7","lens":"wide","motion_intent":"reveal","scene_id":"sc4","shot_size":"wide","visual_id":"v2"},{"angle":"eye_level","axis":"sc5:primary","beat_ids":["b8"],"blocking":"establish participants and geography","camera_position":"profile","composition":"rule_of_thirds","eyeline":"environmental","id":"sh8","lens":"portrait","motion_intent":"reveal","scene_id":"sc5","shot_size":"close","visual_id":"v1"}],"timeline":[{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":true,"hook_text":"Seeds from the future!","id":"b1","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Beneath the translucent dome, crimson sands stretch towards a horizon lit by the dim glow of two moons. Aaron, the last human gardener on Mars, kneels beside rows of stunted greenery, his hands caked in the rust-red soil. He wipes sweat from his brow, eyes fixated on a new package delivered that morning."},{"emotion":"surprised","pose":"stand","speaker_id":"aaron","text":"Who sends seeds to a barren planet?"}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh1","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b2","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"He slices open the package, revealing a collection of small, fragile seeds. Each is meticulously labeled with names like 'Elara' and 'Juno'. More intriguingly, names paired with numbers, birth dates yet to come."},{"emotion":"normal","pose":"stand","speaker_id":"aaron","text":"Control, I received seeds labeled with future names. Any idea what this is?"},{"emotion":"normal","pose":"stand","speaker_id":"control","text":"Nothing on our records, Aaron. Investigate further. Stay cautious."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh2","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"calm","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b3","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Days pass as Aaron plants the seeds, each sprouting in record time, vibrant stems breaking through the soil. They pulse with an inner light, casting an ethereal glow in the dusk."},{"emotion":"happy","pose":"stand","speaker_id":"aaron","text":"These plants... they're growing faster than anything I've seen."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh3","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b4","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"As the garden flourishes, Aaron begins to notice a pattern. The plants emit faint sounds, whispers like soft-spoken secrets. He leans closer, straining to hear."}],"motion":"static","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh4","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"tense","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"center","hold_sec":0.0,"hook":false,"hook_text":"","id":"b5","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"One night, as Martian winds howl against the dome, Aaron hears a distinct word from the plants—his own name, clear and resonant."},{"emotion":"surprised","pose":"stand","speaker_id":"aaron","text":"What are you trying to tell me?"}],"motion":"pan_right","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh5","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"mysterious","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b6","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"The plants respond with a gentle hum, each leaf vibrating in harmony. Suddenly, a vision consumes him—a future where Mars thrives with life, a buzzing metropolis. The seeds, a gift from a time yet to be."}],"motion":"zoom_out","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh6","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"epic","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"wide","hold_sec":0.0,"hook":false,"hook_text":"","id":"b7","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Back in the lab, Aaron logs his findings, heart racing with the enormity of his discovery. The seeds, messages from descendants unknown, a promise of a thriving world."},{"emotion":"normal","pose":"stand","speaker_id":"aaron","text":"Control, the seeds... they're a blueprint for Mars' future."},{"emotion":"surprised","pose":"stand","speaker_id":"control","text":"Unbelievable. Your work is just beginning, Aaron."}],"motion":"pan_up","narration":"","pause_after":0.0,"pose":"stand","reading_speed":1.0,"shot_id":"sh7","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v2"},{"bgm_cue":"under","bgm_intensity":"med","bgm_mood":"hopeful","char_anchor":"none","char_motion":"fade","char_scale":"medium","emotion":"normal","focus":"close","hold_sec":0.0,"hook":false,"hook_text":"","id":"b8","lines":[{"emotion":"normal","pose":"stand","speaker_id":"","text":"Aaron looks out at the garden, a living testament to human tenacity and hope. The seeds are more than just plants—they are the whispers of tomorrow, already taking root today."}],"motion":"pan_up","narration":"","pause_after":1.6,"pose":"stand","reading_speed":1.0,"shot_id":"sh8","source_audio":"mute","speaker_id":"","text_anchor":"auto","transition_in":"cut","visual_id":"v1"}],"tone":"mysterious","topic":"The Last Gardener on Mars","visuals":[{"character_ids":["aaron"],"id":"v1","negative_prompt":"","prompt":"","setting_id":"mars_garden_dome","tier":"medium"},{"character_ids":["aaron","control"],"id":"v2","negative_prompt":"","prompt":"","setting_id":"mars_garden_lab","tier":"medium"}]}