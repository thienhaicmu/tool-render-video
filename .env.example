# =============================================================================
# AI Video Render Studio — Environment Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — this file is safe to commit.
# Loaded by: run-backend-v2.ps1 and run-backend.ps1
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000

# UI version served by ui_gate.py: "v2" (React) | "legacy" (static HTML)
STATIC_UI_VERSION=v2

# -----------------------------------------------------------------------------
# AI CLOUD — Groq (recommended primary provider)
# Sign up: https://console.groq.com — free tier 500K tokens/day
# -----------------------------------------------------------------------------
AI_CLOUD_ENABLED=1
AI_CLOUD_PROVIDER=groq

# Get your key at: https://console.groq.com/keys
AI_CLOUD_API_KEY=<>

# Groq model options:
#   llama-3.1-8b-instant      — fastest, free tier, good for most tasks
#   llama-3.3-70b-versatile   — highest quality, recommended for production
#   mixtral-8x7b-32768        — long context window (32K tokens)
#   gemma2-9b-it              — Google Gemma, strong reasoning
AI_CLOUD_MODEL=llama-3.1-8b-instant

# Alternative: OpenAI (set provider to "openai" and use OpenAI key)
# AI_CLOUD_PROVIDER=openai
# AI_CLOUD_API_KEY=sk-YOUR_OPENAI_KEY_HERE
# AI_CLOUD_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# WHISPER — local transcription (no API cost, runs offline)
# Larger model = better accuracy but slower + more VRAM
# tiny | base | small | medium | large | large-v2 | large-v3
# -----------------------------------------------------------------------------
SUBTITLE_PER_PART_MODEL=small

# -----------------------------------------------------------------------------
# FFMPEG — leave blank to auto-detect system FFmpeg
# Uncomment and set if FFmpeg is not on PATH
# -----------------------------------------------------------------------------
# FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe

# Max seconds before FFmpeg is killed (default 3600 = 1 hour)
FFMPEG_TIMEOUT_SECONDS=3600

# NVENC hardware encoder sessions (consumer GPU limit: 3-5)
# NEVER exceed your GPU's actual limit — exceeding kills ALL active renders
NVENC_MAX_SESSIONS=3

# -----------------------------------------------------------------------------
# RENDER CONCURRENCY
# Recommended: cpu_count / 2 — leave headroom for the OS and UI
# -----------------------------------------------------------------------------
MAX_RENDER_JOBS=2

# -----------------------------------------------------------------------------
# DOWNLOAD — yt-dlp settings
# -----------------------------------------------------------------------------
# Max seconds to wait for a YouTube download before giving up
YTDLP_WALLCLOCK_TIMEOUT=300

# HTTP/SOCKS proxy for yt-dlp (leave blank if not needed)
# YTDLP_PROXY=http://127.0.0.1:7890

# Path to Netscape-format cookies file (for age-restricted / member-only videos)
# YTDLP_COOKIEFILE=C:\path\to\youtube_cookies.txt

# Read cookies directly from a logged-in browser — no manual export needed.
# Priority: YTDLP_COOKIEFILE takes precedence if both are set.
# Options: chrome | edge | firefox | brave | chromium | opera | vivaldi
# The browser must be installed and you must be logged in to YouTube.
# YTDLP_COOKIES_FROM_BROWSER=chrome

# -----------------------------------------------------------------------------
# ANTHROPIC — optional, used by caption_engine.py as fallback
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# -----------------------------------------------------------------------------
# OLLAMA — local LLM server (offline alternative to Groq)
# Install: https://ollama.com — run: ollama pull llama3.2:3b
# Only used when AI_CLOUD_ENABLED=0 or as internal caption fallback
# -----------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# -----------------------------------------------------------------------------
# AI PIPELINE — S3 feature flags
# These modules run offline (heuristic + local ML) — no API cost
# Set to "0" to disable individual modules for debugging or performance
# -----------------------------------------------------------------------------
S3_RETENTION_ENABLED=1
HOOK_INTELLIGENCE_ENABLED=1
BEST_MOMENT_INTELLIGENCE_ENABLED=1
DIVERSITY_INTELLIGENCE_ENABLED=1
STRUCTURE_INTELLIGENCE_ENABLED=1
CREATOR_DNA_ENABLED=1
CLIP_SCORING_ENABLED=1
S3_PLATFORM_INTELLIGENCE_ENABLED=1

# Retention predictor tuning (advanced — leave defaults unless you know why)
S3_RETENTION_MIN_SCORE=50
S3_RETENTION_BASE_SCORE=65.0

# -----------------------------------------------------------------------------
# AI PIPELINE — S4 experimental features
# All OFF by default — enable one at a time and validate output
# -----------------------------------------------------------------------------
S4_CANDIDATE_INTELLIGENCE_ENABLED=0
S4_RETENTION_PROXY_ENABLED=0
S4_SPEAKER_AWARE_CUTS_ENABLED=0
S4_THUMBNAIL_QUALITY_ENABLED=0
S4_CONTENT_INTELLIGENCE_ENABLED=0

# -----------------------------------------------------------------------------
# SUBTITLE TUNING
# WPS = words per second (max reading speed before wrapping)
# WORDS = max words per subtitle block
# -----------------------------------------------------------------------------
SUBTITLE_MAX_WPS=3.8
SUBTITLE_MAX_WORDS=7

# WhisperX word-alignment supported languages (comma-separated)
WHISPERX_ALIGN_LANGS=en,de,fr,es,it,ja,zh,nl,uk,pt,vi

# -----------------------------------------------------------------------------
# AUDIO
# -----------------------------------------------------------------------------
# Auto-clean intermediate audio files after render: "1" | "0"
AUDIO_CLEANUP_AUTO=1

# Duck background music under voice: "1" | "0"
BGM_DUCKING_ENABLED=1

# -----------------------------------------------------------------------------
# TTS — text-to-speech (XTTS local voice cloning)
# -----------------------------------------------------------------------------
XTTS_TIMEOUT_SEC=120
XTTS_MAX_SESSIONS=1
SSML_HUMANIZER_ENABLED=1

# -----------------------------------------------------------------------------
# SCENE DETECTION
# -----------------------------------------------------------------------------
TRANSNETV2_ENABLED=1
TRANSNETV2_THRESHOLD=0.5
SCENE_ADAPTIVE_ENABLED=1
SILENCE_SCORING_ENABLED=1

# -----------------------------------------------------------------------------
# MOTION CROP
# -----------------------------------------------------------------------------
POSE_EYE_ANCHOR_ENABLED=1

# -----------------------------------------------------------------------------
# PREVIEW SESSIONS
# How long (hours) a preview session is kept before auto-eviction
# -----------------------------------------------------------------------------
PREVIEW_SESSION_TTL_HOURS=6

# -----------------------------------------------------------------------------
# MAINTENANCE
# -----------------------------------------------------------------------------
# How often (seconds) the cleanup daemon runs (default 1800 = 30 min)
CLEANUP_INTERVAL_SEC=1800
LOG_KEEP_LAST=30
LOG_KEEP_DAYS=10

# -----------------------------------------------------------------------------
# DEBUG — keep all OFF in normal use
# -----------------------------------------------------------------------------
RENDER_DEBUG_LOG=0
S3_DEBUG_ENABLED=0

# ⛔ DANGER — unauthenticated shell execution endpoint
# NEVER enable unless you are actively debugging on a private machine
# NEVER enable on any machine accessible from a network
# ENABLE_DEVTOOLS=1
