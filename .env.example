# =============================================================================
# AI Video Render Studio — Environment Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — this file is safe to commit.
# Loaded by: run-backend-v2.ps1 and run-backend.ps1
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000

# UI version served by ui_gate.py: "v2" (React) | "legacy" (static HTML)
STATIC_UI_VERSION=v2

# -----------------------------------------------------------------------------
# AI CLOUD — Groq (recommended primary provider)
# Sign up: https://console.groq.com — free tier 500K tokens/day
# -----------------------------------------------------------------------------
AI_CLOUD_ENABLED=1
AI_CLOUD_PROVIDER=groq

# Get your key at: https://console.groq.com/keys
AI_CLOUD_API_KEY=<>

# Groq model options:
#   llama-3.1-8b-instant      — fastest, free tier, good for most tasks
#   llama-3.3-70b-versatile   — highest quality, recommended for production
#   mixtral-8x7b-32768        — long context window (32K tokens)
#   gemma2-9b-it              — Google Gemma, strong reasoning
AI_CLOUD_MODEL=llama-3.1-8b-instant

# Alternative: OpenAI (set provider to "openai" and use OpenAI key)
# AI_CLOUD_PROVIDER=openai
# AI_CLOUD_API_KEY=sk-YOUR_OPENAI_KEY_HERE
# AI_CLOUD_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# WHISPER — local transcription (no API cost, runs offline)
# Larger model = better accuracy but slower + more VRAM
# tiny | base | small | medium | large | large-v2 | large-v3
# -----------------------------------------------------------------------------
SUBTITLE_PER_PART_MODEL=small

# -----------------------------------------------------------------------------
# FFMPEG — leave blank to auto-detect system FFmpeg
# Uncomment and set if FFmpeg is not on PATH
# -----------------------------------------------------------------------------
# FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe

# Max seconds before FFmpeg is killed (default 3600 = 1 hour)
FFMPEG_TIMEOUT_SECONDS=3600

# NVENC hardware encoder sessions (consumer GPU limit: 3-5)
# NEVER exceed your GPU's actual limit — exceeding kills ALL active renders
NVENC_MAX_SESSIONS=3

# -----------------------------------------------------------------------------
# RENDER CONCURRENCY
# Recommended: cpu_count / 2 — leave headroom for the OS and UI
# -----------------------------------------------------------------------------
MAX_RENDER_JOBS=2

# -----------------------------------------------------------------------------
# DOWNLOAD — yt-dlp settings
# -----------------------------------------------------------------------------
# Max seconds to wait for a YouTube download before giving up
YTDLP_WALLCLOCK_TIMEOUT=300

# HTTP/SOCKS proxy for yt-dlp (leave blank if not needed)
# YTDLP_PROXY=http://127.0.0.1:7890

# Path to Netscape-format cookies file (for age-restricted / member-only videos)
# YTDLP_COOKIEFILE=C:\path\to\youtube_cookies.txt

# Read cookies directly from a logged-in browser — no manual export needed.
# Priority: YTDLP_COOKIEFILE takes precedence if both are set.
# Options: chrome | edge | firefox | brave | chromium | opera | vivaldi
# The browser must be installed and you must be logged in to YouTube.
# YTDLP_COOKIES_FROM_BROWSER=chrome

# -----------------------------------------------------------------------------
# GEMINI — API keys + quota rotation pool
# -----------------------------------------------------------------------------
# GEMINI_API_KEY = single server-side key (fallback for single-key setups).
# GEMINI_API_KEYS = comma-separated POOL. Free-tier keys are ~20 requests/day
# each; on a 429 the code rotates to the next key and cools the exhausted one, so
# N keys ≈ N × the daily cap. When GEMINI_API_KEYS is set, GEMINI_API_KEY defaults
# to its first entry. Applies to both the render path and the ai_eval harness.
# GEMINI_API_KEY=AIza_or_AQ_YOUR_KEY
# GEMINI_API_KEYS=key1,key2,key3
# Seconds a key is skipped after a 429 before it is retried (default 1800).
# GEMINI_KEY_COOLDOWN_SEC=1800
# Generation model. Hardcoded fallback is gemini-2.5-flash (free-tier safe).
# D-2 (2026-07-02): gemini-3.5-flash measured better on the recap A/B (n=3,
# +0.416 weighted, faithfulness +0.667) and has its own per-model daily quota.
# GEMINI_DEFAULT_MODEL=gemini-3.5-flash

# -----------------------------------------------------------------------------
# ANTHROPIC — optional, used by caption_engine.py as fallback
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# -----------------------------------------------------------------------------
# OLLAMA — local LLM server (offline alternative to Groq)
# Install: https://ollama.com — run: ollama pull llama3.2:3b
# Only used when AI_CLOUD_ENABLED=0 or as internal caption fallback
# -----------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# -----------------------------------------------------------------------------
# AI PIPELINE — S3 feature flags
# These modules run offline (heuristic + local ML) — no API cost
# Set to "0" to disable individual modules for debugging or performance
# -----------------------------------------------------------------------------
S3_RETENTION_ENABLED=1
HOOK_INTELLIGENCE_ENABLED=1
BEST_MOMENT_INTELLIGENCE_ENABLED=1
DIVERSITY_INTELLIGENCE_ENABLED=1
STRUCTURE_INTELLIGENCE_ENABLED=1
CREATOR_DNA_ENABLED=1
CLIP_SCORING_ENABLED=1
S3_PLATFORM_INTELLIGENCE_ENABLED=1

# Retention predictor tuning (advanced — leave defaults unless you know why)
S3_RETENTION_MIN_SCORE=50
S3_RETENTION_BASE_SCORE=65.0

# -----------------------------------------------------------------------------
# AI PIPELINE — S4 experimental features
# All OFF by default — enable one at a time and validate output
# -----------------------------------------------------------------------------
S4_CANDIDATE_INTELLIGENCE_ENABLED=0
S4_RETENTION_PROXY_ENABLED=0
S4_SPEAKER_AWARE_CUTS_ENABLED=0
S4_THUMBNAIL_QUALITY_ENABLED=0
S4_CONTENT_INTELLIGENCE_ENABLED=0

# -----------------------------------------------------------------------------
# SUBTITLE TUNING
# WPS = words per second (max reading speed before wrapping)
# WORDS = max words per subtitle block
# -----------------------------------------------------------------------------
SUBTITLE_MAX_WPS=3.8
SUBTITLE_MAX_WORDS=7

# WhisperX word-alignment supported languages (comma-separated)
WHISPERX_ALIGN_LANGS=en,de,fr,es,it,ja,zh,nl,uk,pt,vi

# -----------------------------------------------------------------------------
# AUDIO
# -----------------------------------------------------------------------------
# Auto-clean intermediate audio files after render: "1" | "0"
AUDIO_CLEANUP_AUTO=1

# Duck background music under voice: "1" | "0"
BGM_DUCKING_ENABLED=1

# -----------------------------------------------------------------------------
# TTS — text-to-speech (XTTS local voice cloning)
# -----------------------------------------------------------------------------
XTTS_TIMEOUT_SEC=120
XTTS_MAX_SESSIONS=1
SSML_HUMANIZER_ENABLED=1

# -----------------------------------------------------------------------------
# AI — RECAP STORY INTELLIGENCE (applies to render_format="recap")
# -----------------------------------------------------------------------------
# Pass-1 Story Understanding (StoryModel). ON by default; required for pass-2.
RECAP_TWO_PASS=1
# Pass-2 Editorial Blueprint — plans HOW to tell the recap (pacing, where to
# build tension, narrate vs. hold on original audio) FROM the StoryModel BEFORE
# scene selection. Runs one cheap LLM call (no transcript). Best-effort: on
# failure the recap falls back to single-call pacing (Sacred Contract #3).
# Enable for materially better recap pacing / suspense / narrate-vs-hold.
RECAP_EDITORIAL_PASS=1
# Duration anchor for the editorial-ON path (fix 2026-07-02): injects a HARD
# 10-25%-of-runtime total-length budget + 8s scene floor into pass-2/pass-3.
# Structural n=5 showed editorial-ON ranged 4%-96% of runtime without it.
# 0 = kill switch (revert to unanchored editorial prompts).
RECAP_DURATION_ANCHOR=1
# Deterministic duration-band reconciler (2026-07-02): after scene selection,
# cap scenes at 40s and drop non-essential scenes (never climax / holds) until
# the recap fits the 10-25% band. The GUARANTEE the prompt anchor can't give —
# measurement showed the LLM ignores even a HARD budget. 0 = kill switch.
RECAP_TRIM_TO_BAND=1
# StoryModel (pass-1) output-token budget. The default 8192 shares the budget
# with the thinking budget and TRUNCATES the StoryModel — dropping characters +
# plot beats (measured 2026-07: 0 chars / 0 beats at 8192 vs 8 / 14 at 16384).
# 16384 restores the full whole-film understanding pass-2 + scene selection need.
GEMINI_STORY_MAX_TOKENS=16384
# Keep the thinking budget well below max_output_tokens so thinking can't starve
# the JSON output (the failure mode at the 8192/8192 default). 2048 reliably
# yields a full StoryModel.
GEMINI_STORY_THINKING_BUDGET=2048
# Per-episode narration refinement (P1-2): when 1, re-author each episode's
# narration in a focused LLM call so later scenes don't degrade (the whole-film
# call authors all narration at once). Costs +1 LLM call per episode. Default 0
# (OFF) — recap byte-identical; flip to A/B once a reliable eval is available.
RECAP_PER_EPISODE_NARRATION=0

# -----------------------------------------------------------------------------
# AI — CLIP STORY INTELLIGENCE (applies to render_format="clips")
# -----------------------------------------------------------------------------
# Env default for running the Comprehension stage on the clip path (grounds clip
# selection in a whole-source StoryModel → conflict/peak-landing clips rank
# higher). Sacred Contract #2: the per-job ``use_story_intelligence`` field
# default stays False; this env only provides a fallback when the payload didn't
# opt in. Default 0 = OFF (byte-identical to baseline; adds no LLM call). Set to
# 1 to enable globally. Costs +1 Comprehension LLM call per clip render.
CLIP_STORY_INTELLIGENCE_DEFAULT=0
# Near-duplicate clip removal (P1-3): drop any clip whose [start,end] overlaps a
# higher-scored kept clip by >= this IoU (heavy span overlap = duplicate).
# Partial-overlap different-hook clips survive. 0 disables. Default 0.7.
CLIP_DEDUP_IOU=0.7
# Deterministic speech-density ranking signal (P1-1'): when 1, measure each
# clip's speech density from the transcript (chars/sec, relative min-max across
# the job's clips) instead of the LLM's self-reported value. Only the
# speech_density ranking weight (0.10) is affected. Default 0 (OFF) — ranking
# byte-identical; flip to A/B once a reliable eval is available.
RANKING_DETERMINISTIC_SPEECH_DENSITY=0
# Focused clip prompt (P1-4): when 1, the clip-selection LLM call asks ONLY for a
# reasoning field + clips (un-fused) instead of also emitting subtitle/camera/
# audio/overlay plans — the render engine resolves those. Sharper selection
# focus at the cost of the AI's coarse sub-plan hints. Default 0 (OFF) — prompt
# byte-identical; flip to A/B once a reliable eval is available.
CLIP_PROMPT_FOCUSED=0

# -----------------------------------------------------------------------------
# SCENE DETECTION
# -----------------------------------------------------------------------------
TRANSNETV2_ENABLED=1
TRANSNETV2_THRESHOLD=0.5
SCENE_ADAPTIVE_ENABLED=1
SILENCE_SCORING_ENABLED=1

# -----------------------------------------------------------------------------
# MOTION CROP
# -----------------------------------------------------------------------------
POSE_EYE_ANCHOR_ENABLED=1

# -----------------------------------------------------------------------------
# PREVIEW SESSIONS
# How long (hours) a preview session is kept before auto-eviction
# -----------------------------------------------------------------------------
PREVIEW_SESSION_TTL_HOURS=6

# -----------------------------------------------------------------------------
# MAINTENANCE
# -----------------------------------------------------------------------------
# How often (seconds) the cleanup daemon runs (default 1800 = 30 min)
CLEANUP_INTERVAL_SEC=1800
LOG_KEEP_LAST=30
LOG_KEEP_DAYS=10

# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# STORY MODE — V3 visual identity matching
# -----------------------------------------------------------------------------
# Use the approved V3 character manifest by default when it exists. Set to 0
# for a legacy-only rollback. Override the path when a larger approved manifest
# is promoted.
STORY_V3_MATCHING=1
STORY_V3_ONLY=1
STORY_V3_CHARACTER_MANIFEST=data/visual_library_v3_legacy_characters_approved_pilot.json
STORY_V3_SCENE_MANIFEST=data/visual_library_v3_legacy_scenes_approved_pilot.json

# DEBUG — keep all OFF in normal use
# -----------------------------------------------------------------------------
RENDER_DEBUG_LOG=0
S3_DEBUG_ENABLED=0

# ⛔ DANGER — unauthenticated shell execution endpoint
# NEVER enable unless you are actively debugging on a private machine
# NEVER enable on any machine accessible from a network
# ENABLE_DEVTOOLS=1
